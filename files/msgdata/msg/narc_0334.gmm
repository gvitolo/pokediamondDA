	</row>
	<row id="narc_0334_00020" index="20">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Væggen er meget klippefuld...\nKan en Pokémons angreb bestige den?</language>
	</row>
	<row id="narc_0334_00021" index="21">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Rock Climb kan ikke bruges, når du har\nnogen med dig.</language>
