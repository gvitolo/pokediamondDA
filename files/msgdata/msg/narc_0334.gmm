<body language="English">
	<row id="narc_0334_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dette træ ser ud til at kunne\nfældes! Vil du fælde det?</language>
	</row>
	<row id="narc_0334_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 0, 0} brugte Cut!\r</language>
	</row>
	<row id="narc_0334_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dette træ ser ud til at kunne\nfældes!</language>
	</row>
	<row id="narc_0334_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Denne klippe ser ud til at kunne\nknuses. Vil du bruge Rock Smash?</language>
	</row>
	<row id="narc_0334_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er en robust klippe, men en Pokémon\nkan måske knuse den.</language>
	</row>
	<row id="narc_0334_00005" index="5">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 0, 0} brugte Rock Smash!\r</language>
	</row>
	<row id="narc_0334_00006" index="6">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er en stor kampesten, men en Pokémon\nkan måske skubbe den til side.\rVil du bruge Strength?</language>
	</row>
	<row id="narc_0334_00007" index="7">
		<attribute name="window_context_name">garbage</attribute>
