	<row id="narc_0334_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er en stor kampesten, men en Pokémon\nkan måske skubbe den til side.</language>
	</row>
	<row id="narc_0334_00009" index="9">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Strength gør det muligt at flytte\nkampesten rundt.</language>
	</row>
	<row id="narc_0334_00010" index="10">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 0, 0} brugte Strength!\r</language>
	</row>
	<row id="narc_0334_00011" index="11">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 0, 0}s Strength gør det\nmuligt at flytte kampesten!</language>
	</row>
	<row id="narc_0334_00012" index="12">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vandet er dybt blåt...\nVil du surfe på det?</language>
	</row>
	<row id="narc_0334_00013" index="13">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 0, 0} brugte Surf!\r</language>
	</row>
	<row id="narc_0334_00014" index="14">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Surf kan ikke bruges, når du har\nnogen med dig.</language>
	</row>
	<row id="narc_0334_00015" index="15">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Tæt tåge hænger over området...\nVil du bruge Defog?</language>
	</row>
	<row id="narc_0334_00016" index="16">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 0, 0} brugte Defog!\r</language>
	</row>
	<row id="narc_0334_00017" index="17">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Tæt tåge hænger over området...\nKan en Pokémons angreb fjerne den?</language>
	</row>
	<row id="narc_0334_00018" index="18">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Væggen er meget klippefuld...\nVil du bruge Rock Climb?</language>
	</row>
	<row id="narc_0334_00019" index="19">
		<attribute name="window_context_name">used</attribute>
