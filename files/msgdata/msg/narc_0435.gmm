<?xml version='1.0' encoding='UTF-8'?>
<body language="English">
	<row id="narc_0435_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hohoho...\nDe kalder mig bedstemor Wilma.\rJeg kom herud alene fra\nen by med Dragon Tamers.\rJeg kan undervise den stærkeste af alle\nDrage-type flytter til det hårde\fPokémon af Sinnoh.\rVil du have mig til at undervise i det\nflytte til en af ​​dine Pokémons?</language>
	</row>
	<row id="narc_0435_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ah, det er dig igen...\rVil du have mig til at undervise det bedste\nDrage-type træk jeg kender til en af\fdin Pokémon?</language>
	</row>
	<row id="narc_0435_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Nå, måske hvis du ændrer dit\nsind, kom tilbage.</language>
	</row>
	<row id="narc_0435_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">jeg ser...\nJeg kan godt lide din sans for eventyr.\rDog ingen af ​​Pokémonerne med\ndu kan nu lære bevægelsen.</language>
	</row>
	<row id="narc_0435_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fint, fint, vælg nu Pokémon\nJeg burde lære flytningen til.</language>
	</row>
	<row id="narc_0435_00005" index="5">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Undskyld at skuffe dig...\rDen Pokémon du har kan lære dette\nflytte, men det er ikke kommet til tillid\fdu helt endnu...\rIndtil da kan jeg ikke få det til at lære\ndette træk.</language>
	</row>
	<row id="narc_0435_00006" index="6">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Undskyld at skuffe dig...\nAt Pokémon ikke kan lære dette træk.</language>
	</row>
	<row id="narc_0435_00007" index="7">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hmmmm...\rAt lære en flytning til et æg er\nen udfordring, der ligger uden for mig.</language>
	</row>
	<row id="narc_0435_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh? Det ved den Pokémon allerede\n{STRVAR_1 6, 0}.</language>
	</row>
