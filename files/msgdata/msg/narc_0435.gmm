	<row id="narc_0435_00016" index="16">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Draco Meteors destruktive kraft\ner ærefrygtindgydende.\rMen at bruge det vil også falde\nPokémons særlige angreb.</language>
	</row>
