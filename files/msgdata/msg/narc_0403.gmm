	<row id="narc_0403_00029" index="29">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Seks Pokémon migrerede sikkert til\nPokémon Diamond Game Card.</language>
	</row>
	<row id="narc_0403_00030" index="30">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Seks Pokémon migrerede sikkert til\nPokémon Pearl Game Card.</language>
	</row>
	<row id="narc_0403_00031" index="31">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pokémon kan migrere fra en Game Boy\nAdvance Game Pak kun én gang om dagen.\rDer er ikke gået en hel dag siden\nPokémon migrerede fra denne Game Pak.</language>
	</row>
	<row id="narc_0403_00032" index="32">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du bruger en anden Nintendo DS,\neller dets interne ur er blevet ændret.\rHvis spillets tidsindstilling ændres,\nvil du ikke være i stand til at migrere\fPokémon i yderligere 24 timer.\rVil du ændre dit spils\ntidsindstilling, så den matcher Nintendo DS?</language>
	</row>
	<row id="narc_0403_00033" index="33">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Spillets ur er blevet justeret.\rPokémon kan ikke fås til at migrere\ninden for 24 timer.</language>
	</row>
	<row id="narc_0403_00034" index="34">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pokémon KAN IKKE returneres til\nGame Boy Advance Game Pak.\rFå Pokémon til at migrere til\nPokémon Diamond Game Card?</language>
	</row>
	<row id="narc_0403_00035" index="35">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pokémon KAN IKKE returneres til\nGame Boy Advance Game Pak.\rFå Pokémon til at migrere til\nPokémon Pearl Game Card?</language>
	</row>
	<row id="narc_0403_00036" index="36">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gem mislykkedes...</language>
	</row>
	<row id="narc_0403_00037" index="37">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fejl ved læsning af Game Boy Advance\nGame Paks gemmefil.\rDer er muligvis ikke gemt en fil,\og heller ikke gemmefilen er beskadiget.</language>
	</row>
	<row id="narc_0403_00038" index="38">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Denne Pokémon har ikke tilladelse til at\nmigrere.</language>
	</row>
