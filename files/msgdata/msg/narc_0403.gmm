	<row id="narc_0403_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Få Pokémon til at migrere fra\n{STRVAR_1 3, 1}'s Ruby Game Pak?</language>
	</row>
	<row id="narc_0403_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Få Pokémon til at migrere fra\n{STRVAR_1 3, 1}'s Sapphire Game Pak?</language>
	</row>
	<row id="narc_0403_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Få Pokémon til at migrere fra\n{STRVAR_1 3, 1}'s Emerald Game Pak?</language>
	</row>
	<row id="narc_0403_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Få Pokémon til at migrere fra\n{STRVAR_1 3, 1}'s FireRed Game Pak?</language>
	</row>
	<row id="narc_0403_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Få Pokémon til at migrere fra\n{STRVAR_1 3, 1}'s LeafGreen Game Pak?</language>
	</row>
	<row id="narc_0403_00005" index="5">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er ikke seks Pokémon i\npc-boksene.</language>
	</row>
	<row id="narc_0403_00006" index="6">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vælg venligst de seks Pokémon\nder vil migrere.</language>
	</row>
	<row id="narc_0403_00007" index="7">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dette spilkort er allerede\nopført med seks migrerede Pokémons.\rDeltag venligst i et Catching\nshow i Pal Park.</language>
	</row>
	<row id="narc_0403_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et æg kan ikke migrere!</language>
	</row>
	<row id="narc_0403_00009" index="9">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Denne Pokémon kender et skjult træk.\nDen kan ikke migrere.</language>
	</row>
	<row id="narc_0403_00010" index="10">
		<attribute name="window_context_name">used</attribute>
		<language name="English">De seks valgte Pokémon vil migrere.</language>
	</row>
	<row id="narc_0403_00011" index="11">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pokémon KAN IKKE returneres til\nGame Boy Advance Game Pak. OK?</language>
	</row>
