	<row id="narc_0587_00203" index="203">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren udholder ethvert\angreb, hvilket efterlader 1 HP.\nDens chance for at fejle\nstiger, hvis den bruges i rækkefølge.</language>
	</row>
	<row id="narc_0587_00204" index="204">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren\nstirrer charmerende på fjenden,\ngør den mindre forsigtig.\nMålets angreb\n er kraftigt sænket.</language>
	</row>
	<row id="narc_0587_00205" index="205">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren ruller konstant\n ind i fjenden\nover fem omgange. Den\nbliver stærkere\nhver gang den rammer.</language>
	</row>
	<row id="narc_0587_00206" index="206">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et tilbageholdende angreb\nder forhindrer\nfjenden i at besvime.\nMålet efterlades\nmed mindst 1 HP.</language>
	</row>
	<row id="narc_0587_00207" index="207">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user enrages the\nfoe into confusion.\nHowever, it also\nsharply raises the\nfoe’s Attack stat.</language>
	</row>
	<row id="narc_0587_00208" index="208">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user restores its\nown HP by up to half\nof its maximum HP.\nIt may also be used\nto heal an ally’s HP.</language>
	</row>
	<row id="narc_0587_00209" index="209">
		<attribute name="window_context_name">used</attribute>
