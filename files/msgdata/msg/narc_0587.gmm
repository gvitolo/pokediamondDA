<?xml version="1.0"?>
<body language="English">
	<row id="narc_0587_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">\n\n\n\n</language>
	</row>
	<row id="narc_0587_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver fysisk\nhamret med en lang\nhale eller et forben,\netc.\n</language>
	</row>
	<row id="narc_0587_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is attacked\nwith a sharp chop.\nIt has a high\ncritical-hit ratio.\n</language>
	</row>
	<row id="narc_0587_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is slapped\nrepeatedly, back\nand forth, two to\nfive times in a row.\n</language>
	</row>
	<row id="narc_0587_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver ramt med\n byge af slag\nsom slår to til\nfem gange i træk.\n</language>
	</row>
	<row id="narc_0587_00005" index="5">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is slugged\nby a punch thrown\nwith muscle-packed\npower.\n</language>
	</row>
	<row id="narc_0587_00006" index="6">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Adskillige mønter\nkastes mod fjenden for at\nforvolde skade.\nPenge optjenes\nefter kamp.</language>
	</row>
	<row id="narc_0587_00007" index="7">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver slået\nmed en brændende knytnæve.\nDen kan forlade\nmålet med en forbrænding.\n</language>
	</row>
	<row id="narc_0587_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is punched\nwith an icy fist.\nIt may leave the\ntarget frozen.\n</language>
	</row>
	<row id="narc_0587_00009" index="9">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver slået\nmed en elektrificeret\nnæve. Det kan efterlade\nmålet med\nlammelse.</language>
	</row>
	<row id="narc_0587_00010" index="10">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hard, pointed, and\nsharp claws rake the\nfoe to inflict damage.\n\n</language>
	</row>
	<row id="narc_0587_00011" index="11">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Kæmpe, imponerende\ntang griber og\nklemmer fjenden.\n\n</language>
	</row>
	<row id="narc_0587_00012" index="12">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A vicious, tearing\nattack with pincers.\nThe foe will faint\ninstantly if this\nattack hits.</language>
	</row>
	<row id="narc_0587_00013" index="13">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et to-drejningsangreb.\nVinden ramte\nfjenden ved den anden\ndrejning. Den har et højt\nkritisk hit-forhold.</language>
	</row>
	<row id="narc_0587_00014" index="14">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En hektisk dans for at\nopløfte kampånden. Det hæver brugerens\nangrebsstat kraftigt.</language>
	</row>
	<row id="narc_0587_00015" index="15">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden skæres med en\ncythe eller en klo.\nDen kan også bruges\ntil at fælde tynde\ntræer.</language>
	</row>
	<row id="narc_0587_00016" index="16">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A gust of wind is\nwhipped up by wings\nand launched at the\nfoe to inflict damage.\n</language>
	</row>
	<row id="narc_0587_00017" index="17">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is struck\nwith large, imposing\nwings spread wide\nto inflict damage.\n</language>
	</row>
	<row id="narc_0587_00018" index="18">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden er blæst væk,\nfor at blive erstattet af\nandre Pokémon\ni dens parti. I \nvilden slutter kampen.</language>
	</row>
	<row id="narc_0587_00019" index="19">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren svæver og slår derefter på den anden\ndrejning. Den kan også\bruges til at flyve til\nhver kendt by.</language>
	</row>
	<row id="narc_0587_00020" index="20">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A long body or\ntentacles are used\nto bind and squeeze\nthe foe for two to\nfive turns.</language>
	</row>
	<row id="narc_0587_00021" index="21">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is slammed\nwith a long tail,\nvines, etc., to inflict\ndamage.\n</language>
	</row>
	<row id="narc_0587_00022" index="22">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is struck\nwith slender, whiplike\nvines to inflict\ndamage.\n</language>
	</row>
	<row id="narc_0587_00023" index="23">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is stomped\nwith a big foot.\nIt may also make the\ntarget flinch.\n</language>
	</row>
	<row id="narc_0587_00024" index="24">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is quickly\nkicked twice in\nsuccession using both\nfeet.\n</language>
	</row>
	<row id="narc_0587_00025" index="25">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is attacked\nby a kick launched\nwith muscle-packed\npower.\n</language>
	</row>
	<row id="narc_0587_00026" index="26">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user jumps up\nhigh, then strikes\nwith a kick. If the\nkick misses, the\nuser hurts itself.</language>
	</row>
	<row id="narc_0587_00027" index="27">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user cuts a\nquick spin and lashes\nout with a sharp\nkick.\n</language>
	</row>
	<row id="narc_0587_00028" index="28">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sand is hurled in the\nfoe’s face, reducing\nits accuracy.\n\n</language>
	</row>
	<row id="narc_0587_00029" index="29">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user sticks its\nhead out and rams\nstraight forward.\nIt may make the\nfoe flinch.</language>
	</row>
	<row id="narc_0587_00030" index="30">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is jabbed\nwith a sharply\npointed horn to\ninflict damage.\n</language>
	</row>
	<row id="narc_0587_00031" index="31">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver prikket\ngentagne gange med et\nhorn eller næb to til\nfem gange i træk.\n</language>
	</row>
	<row id="narc_0587_00032" index="32">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is stabbed\nwith a horn rotating\nlike a drill.\nThe foe instantly\nfaints if it hits.</language>
	</row>
	<row id="narc_0587_00033" index="33">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fysisk angreb\nhvor brugeren\nlader og smækker\nind mod fjenden med\n hele kroppen.</language>
	</row>
	<row id="narc_0587_00034" index="34">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren falder på\nfjenden med dens fulde\nkropsvægt.\nDet kan efterlade fjenden\nlammet.</language>
	</row>
	<row id="narc_0587_00035" index="35">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En lang krop eller vinstokke\nbruges til at pakke og\nklemme fjenden i\nto til fem omgange.\n</language>
	</row>
	<row id="narc_0587_00036" index="36">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et hensynsløst angreb på hele kroppen for\n at slå ind i fjenden.\nDet skader også\nbrugeren lidt.</language>
	</row>
	<row id="narc_0587_00037" index="37">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user rampages\nand attacks for two\nto three turns.\nIt then becomes\nconfused, however.</language>
	</row>
	<row id="narc_0587_00038" index="38">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A reckless, life-\nrisking tackle.\nIt also damages the\nuser by a fairly large\namount, however.</language>
	</row>
	<row id="narc_0587_00039" index="39">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user wags its tail\ncutely, making the\nfoe less wary.\nThe target’s Defense\nstat is lowered.</language>
	</row>
	<row id="narc_0587_00040" index="40">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is stabbed\nwith a poisonous\nbarb of some sort.\nIt may also poison\nthe target.</language>
	</row>
	<row id="narc_0587_00041" index="41">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is stabbed\ntwice by a pair of\nstingers.\nIt may also poison\nthe target.</language>
	</row>
	<row id="narc_0587_00042" index="42">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Skarpe nåle skydes\naf fjenden i hurtig\nfølge.\nDe rammer to til fem\ngange i træk.</language>
	</row>
	<row id="narc_0587_00043" index="43">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden får en\nskræmmende hilsen med\nskarpe øjne.\nMålets forsvar\nstat er reduceret.</language>
	</row>
	<row id="narc_0587_00044" index="44">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver bidt med\nondskabsfuldt skarpe hugtænder.\nDet kan få\nmålet til at ryste.\n</language>
	</row>
	<row id="narc_0587_00045" index="45">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user growls in an\nendearing way, making\nthe foe less wary.\nThe target’s Attack\nstat is lowered.</language>
	</row>
	<row id="narc_0587_00046" index="46">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden er skræmt,\nfor at blive erstattet af\nandre Pokémon i\nets parti. I \nvilden slutter kampen.</language>
	</row>
	<row id="narc_0587_00047" index="47">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En beroligende vuggevise\nsynges i en beroligende\nstemme, der sætter\nfjenden i en dyb\nsøvn.</language>
	</row>
	<row id="narc_0587_00048" index="48">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user generates\nodd sound waves from\nits body.\nIt may confuse the\ntarget.</language>
	</row>
	<row id="narc_0587_00049" index="49">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden rammes af en\destruktiv chok\nbølge, der altid\npåfører 20 HK skade.\n</language>
	</row>
	<row id="narc_0587_00050" index="50">
		<attribute name="window_context_name">used</attribute>
		<language name="English">For several turns,\nthis move prevents\nthe foe from using\nthe move it last\nused.</language>
	</row>
	<row id="narc_0587_00051" index="51">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver angrebet\nmed en spray af hård\nsyre. Det kan også\nsænke målets\nSp. Def stat.</language>
	</row>
	<row id="narc_0587_00052" index="52">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver angrebet\nmed små flammer.\nMålet kan også\nblive efterladt med en forbrænding.\n</language>
	</row>
	<row id="narc_0587_00053" index="53">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden er brændt\nmed en intens eksplosion\naf ild. Målet\nkan også efterlades med\na brænding.</language>
	</row>
	<row id="narc_0587_00054" index="54">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user cloaks its\nbody with a white mist\nthat prevents any of\nits stats from being\ncut for five turns.</language>
	</row>
	<row id="narc_0587_00055" index="55">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is blasted\nwith a forceful shot\nof water.\n\n</language>
	</row>
	<row id="narc_0587_00056" index="56">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is blasted by\na huge volume of\nwater launched under\ngreat pressure.\n</language>
	</row>
	<row id="narc_0587_00057" index="57">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den oversvømmer hele\nslagmarken med en\ngigantisk bølge.\nDen kan også bruges\ntil at krydse vand.</language>
	</row>
	<row id="narc_0587_00058" index="58">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is struck\nwith an icy-cold\nbeam of energy.\nIt may also freeze\nthe target solid.</language>
	</row>
	<row id="narc_0587_00059" index="59">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A howling blizzard is\nsummoned to strike\nthe foe.\nIt may also freeze\nthe target solid.</language>
	</row>
	<row id="narc_0587_00060" index="60">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is attacked\nwith a peculiar ray.\nIt may also leave the\ntarget confused.\n</language>
	</row>
	<row id="narc_0587_00061" index="61">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray af bobler\nskydes kraftigt ud\nat fjenden.\nDet kan også sænke\nmålets hastighedsstat.</language>
	</row>
	<row id="narc_0587_00062" index="62">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver ramt med en\nregnbuefarvet stråle.\nDet kan også sænke\nmålets angreb\nstat.</language>
	</row>
	<row id="narc_0587_00063" index="63">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden angribes\nmed en kraftig stråle.\nBrugeren skal hvile\nikke næste tur for at\ngenvinde sin energi.</language>
	</row>
	<row id="narc_0587_00064" index="64">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is jabbed\nwith a sharply\npointed beak or\nhorn.\n</language>
	</row>
	<row id="narc_0587_00065" index="65">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A corkscrewing\nattack with the\nsharp beak acting\nas a drill.\n</language>
	</row>
	<row id="narc_0587_00066" index="66">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren griber \nfjenden og \ndykker hensynsløst mod jorden.\nDet gør også\nbrugeren en smule ondt.</language>
	</row>
	<row id="narc_0587_00067" index="67">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et kraftfuldt lavt spark\nder får fjenden til\n at falde om. Det påfører\nstørre skade på\ntyngre fjender.</language>
	</row>
	<row id="narc_0587_00068" index="68">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A retaliation move\nthat counters any\nphysical attack,\ninflicting double the\ndamage taken.</language>
	</row>
	<row id="narc_0587_00069" index="69">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden kastes\nved hjælp af\ntyngdekraften. Det påfører\nskade svarende til\nbrugerens niveau.</language>
	</row>
	<row id="narc_0587_00070" index="70">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is slugged\nwith a punch thrown\nat maximum power.\nIt can also be used\nto move boulders.</language>
	</row>
	<row id="narc_0587_00071" index="71">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et næringsdrænende\angreb. Brugerens\nHP gendannes med\nhalvdelen af ​​skaden\naf målet.</language>
	</row>
	<row id="narc_0587_00072" index="72">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et næringsdrænende\angreb. Brugerens\nHP gendannes med\nhalvdelen af ​​skaden\naf målet.</language>
	</row>
	<row id="narc_0587_00073" index="73">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et frø er plantet på\nfjenden. Den stjæler\nnoget HP fra fjenden\nfor at helbrede brugeren på\nhver gang.</language>
	</row>
	<row id="narc_0587_00074" index="74">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user’s body is\nforced to grow all at\nonce. It raises the\nSp. Atk stat.\n</language>
	</row>
	<row id="narc_0587_00075" index="75">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A sharp-edged leaf is\nlaunched to slash at\nthe foe. It has a\nhigh critical-hit\nratio.</language>
	</row>
	<row id="narc_0587_00076" index="76">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A two-turn attack.\nThe user gathers\nlight, then blasts a\nbundled beam on the\nsecond turn.</language>
	</row>
	<row id="narc_0587_00077" index="77">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A cloud of poisonous\ndust is scattered on\nthe foe.\nIt may poison the\ntarget.</language>
	</row>
	<row id="narc_0587_00078" index="78">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user scatters a\ncloud of paralyzing\npowder.\nIt may paralyze the\ntarget.</language>
	</row>
	<row id="narc_0587_00079" index="79">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user scatters a\nbig cloud of sleep-\ninducing dust around\nthe foe.\n</language>
	</row>
	<row id="narc_0587_00080" index="80">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user attacks by\nscattering petals for\ntwo to three turns.\nThe user then\nbecomes confused.</language>
	</row>
	<row id="narc_0587_00081" index="81">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden er bundet med\nsilke, der blæses ud af\brugerens mund.\nDet reducerer\nmålets hastighedsstat.</language>
	</row>
	<row id="narc_0587_00082" index="82">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is stricken\nby a shock wave.\nThis attack always\ninflicts 40 HP\ndamage.</language>
	</row>
	<row id="narc_0587_00083" index="83">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe becomes\ntrapped within a\nfierce vortex of fire\nthat rages for two\nto five turns.</language>
	</row>
	<row id="narc_0587_00084" index="84">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et stød af elektricitet\nkastet mod fjenden\nfor at påføre skade.\nDet kan også lade\nfjenden blive lammet.</language>
	</row>
	<row id="narc_0587_00085" index="85">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A strong electric\nblast is loosed at\nthe foe.\nIt may also leave the\nfoe paralyzed.</language>
	</row>
	<row id="narc_0587_00086" index="86">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A weak electric\ncharge is launched at\nthe foe.\nIt causes paralysis if\nit hits.</language>
	</row>
	<row id="narc_0587_00087" index="87">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ond torden\nfalder på fjenden\nfor at påføre skade.\nDet kan også efterlade\nmålet lammet.</language>
	</row>
	<row id="narc_0587_00088" index="88">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren samler op\nog kaster en lille\nsten mod fjenden for at\ngribe.\n</language>
	</row>
	<row id="narc_0587_00089" index="89">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren udløser et\nærskælv, der rammer\nalle Pokémon'erne i\nslaget.\n</language>
	</row>
	<row id="narc_0587_00090" index="90">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren åbner en\nskæring i jorden\nog taber fjenden.\nMålet besvimer øjeblikkeligt, hvis det rammer.</language>
	</row>
	<row id="narc_0587_00091" index="91">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user burrows,\nthen attacks on the\nsecond turn.\nIt can also be used\nto exit dungeons.</language>
	</row>
	<row id="narc_0587_00092" index="92">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A move that leaves\nthe target badly\npoisoned.\nIts poison damage\nworsens every turn.</language>
	</row>
	<row id="narc_0587_00093" index="93">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden rammes af en\nsvag telekinetisk\nkraft. Det kan også\nefterlade fjenden\nforvirret.</language>
	</row>
	<row id="narc_0587_00094" index="94">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden rammes af en\nstærk telekinetisk\nkraft. Det kan også\nreducere fjendens\nSp. Def stat.</language>
	</row>
	<row id="narc_0587_00095" index="95">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren anvender\nhypnotiske forslag\nfor at få målet\ntil at falde i en dyb\nsøvn.</language>
	</row>
	<row id="narc_0587_00096" index="96">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren mediterer\nfor at vække kraften\ndybt inde i sin krop\nog hæve sin Attack\nstat.</language>
	</row>
	<row id="narc_0587_00097" index="97">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user relaxes and\nlightens its body to\nmove faster.\nIt sharply boosts\nthe Speed stat.</language>
	</row>
	<row id="narc_0587_00098" index="98">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren kaster sig ud mod\nfjenden med en hastighed\nder gør den næsten\nusynlig. Den slår helt sikkert\nførst.</language>
	</row>
	<row id="narc_0587_00099" index="99">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mens dette træk er i\nbrug, får det angreb\nkraft, hver gang\nbrugeren bliver ramt i kamp.\n</language>
	</row>
	<row id="narc_0587_00100" index="100">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brug den til at flygte fra\nalle vilde Pokémons.\nDen kan også bruges\ntil at fordreje til det sidste\nPoké Center, du besøgte.</language>
	</row>
	<row id="narc_0587_00101" index="101">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren får fjenden til at se et fatamorgana.\nDet påfører skade\nsvarende til brugerens\nniveau.</language>
	</row>
	<row id="narc_0587_00102" index="102">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren kopierer det\ntræk, der sidst blev brugt af\nfjenden. Trækket kan\nbruges i resten\naf kampen.</language>
	</row>
	<row id="narc_0587_00103" index="103">
		<attribute name="window_context_name">used</attribute>
		<language name="English">An earsplitting\nscreech is emitted to\nsharply reduce the\nfoe’s Defense stat.\n</language>
	</row>
	<row id="narc_0587_00104" index="104">
		<attribute name="window_context_name">used</attribute>
		<language name="English">By moving rapidly, the\nuser makes illusory\ncopies of itself to\nraise its evasiveness.\n</language>
	</row>
	<row id="narc_0587_00105" index="105">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A self-healing move.\nThe user restores its\nown HP by up to half\nof its max HP.\n</language>
	</row>
	<row id="narc_0587_00106" index="106">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user stiffens all\nthe muscles in its\nbody to raise its\nDefense stat.\n</language>
	</row>
	<row id="narc_0587_00107" index="107">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user compresses\nits body to make\nitself look smaller.\nThe user’s evasion\nstat is boosted.</language>
	</row>
	<row id="narc_0587_00108" index="108">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren frigiver en\nskjulende sky af\nrøg eller blæk.\nDet reducerer fjendens\nøjagtighed.</language>
	</row>
	<row id="narc_0587_00109" index="109">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is exposed\nto a sinister ray\nthat triggers\nconfusion.\n</language>
	</row>
	<row id="narc_0587_00110" index="110">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user withdraws\nits body into its hard\nshell, raising its\nDefense stat.\n</language>
	</row>
	<row id="narc_0587_00111" index="111">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user curls up to\nconceal weak spots\nand raise its Defense\nstat.\n</language>
	</row>
	<row id="narc_0587_00112" index="112">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user throws up a\nsturdy wall that\nsharply raises its\nDefense stat.\n</language>
	</row>
	<row id="narc_0587_00113" index="113">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En vidunderlig mur af\nlys er sat op for at\nundertrykke skader fra\nsærlige angreb i\nfem omgange.</language>
	</row>
	<row id="narc_0587_00114" index="114">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren opretter en\nhaze, der eliminerer\nhver statændring\nem alle de Pokémon\n, der er involveret i kamp.</language>
	</row>
	<row id="narc_0587_00115" index="115">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En vidunderlig mur af\nlys er sat op for at\nundertrykke skade fra\nfysiske angreb i\nfem omgange.</language>
	</row>
	<row id="narc_0587_00116" index="116">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user takes a\ndeep breath and\nfocuses to raise the\ncritical-hit ratio of\nits attacks.</language>
	</row>
	<row id="narc_0587_00117" index="117">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user endures\nattacks for two\nturns, then strikes\nback to cause double\nthe damage taken.</language>
	</row>
	<row id="narc_0587_00118" index="118">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user waggles a\nfinger and stimulates\nthe brain into\nrandomly using nearly\nany move.</language>
	</row>
	<row id="narc_0587_00119" index="119">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren modarbejder\nfjenden ved at efterligne\ndet træk, der sidst blev brugt\naf fjenden.</language>
	</row>
	<row id="narc_0587_00120" index="120">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user blows up to\ninflict damage on all\nPokémon in battle.\nThe user faints upon\nusing this move.</language>
	</row>
	<row id="narc_0587_00121" index="121">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A large egg is hurled\nwith maximum force at\nthe foe to inflict\ndamage.\n</language>
	</row>
	<row id="narc_0587_00122" index="122">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden slikkes med\n lang tunge, hvilket forårsager\ndaskade.\nDet kan også lamme\nmålet.</language>
	</row>
	<row id="narc_0587_00123" index="123">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is attacked\nwith a discharge of\nfilthy gases.\nIt may also poison\nthe target.</language>
	</row>
	<row id="narc_0587_00124" index="124">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Uhygiejnisk slam\nkastes mod fjenden.\nDet kan også forgifte\nmålet.\n</language>
	</row>
	<row id="narc_0587_00125" index="125">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user clubs the\nfoe with a bone.\nIt may also make the\ntarget flinch.\n</language>
	</row>
	<row id="narc_0587_00126" index="126">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver angrebet\nmed en intens eksplosion\naf altopslugende ild.\nDen kan også forlade\nmålet med en forbrænding.</language>
	</row>
	<row id="narc_0587_00127" index="127">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user charges the\nfoe at an awesome\nspeed.\nIt can also be used\nto climb a waterfall.</language>
	</row>
	<row id="narc_0587_00128" index="128">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is clamped\nand squeezed by\nthe user’s very thick\nand sturdy shell for\ntwo to five turns.</language>
	</row>
	<row id="narc_0587_00129" index="129">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Stjerneformede stråler bliver\nskudt mod fjenden.\nDette angreb\nmisser aldrig.\n</language>
	</row>
	<row id="narc_0587_00130" index="130">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren stikker sit\nhoved ind for at hæve sit\nforsvar i den første\ndrejning, og ramler derefter fjenden i det næste sving.</language>
	</row>
	<row id="narc_0587_00131" index="131">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Skarpe pigge\naffyres mod fjenden for at\nslå to til fem\ngange i hurtig rækkefølge.</language>
	</row>
	<row id="narc_0587_00132" index="132">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is attacked\nwith long, creeping\ntentacles or vines.\nIt may also lower the\ntarget’s Speed.</language>
	</row>
	<row id="narc_0587_00133" index="133">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user temporarily\nempties its mind to\nforget its concerns.\nIt sharply raises the\nuser’s Sp. Def stat.</language>
	</row>
	<row id="narc_0587_00134" index="134">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user distracts\nthe foe by bending a\nspoon.\nIt may lower the\ntarget’s accuracy.</language>
	</row>
	<row id="narc_0587_00135" index="135">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user restores\nits own HP by up to\nhalf of its max HP.\nMay be used in the\nfield to heal HP.</language>
	</row>
	<row id="narc_0587_00136" index="136">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden angribes\nmed et knæ spark fra\nspring. Hvis den misser,\nkommer brugeren\ni stedet for såret.</language>
	</row>
	<row id="narc_0587_00137" index="137">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user intimidates\nthe foe with the\npattern on its belly\nto cause paralysis.\n</language>
	</row>
	<row id="narc_0587_00138" index="138">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et angreb, der virker\ikke på en sovende\nfjende. Den absorberer halvdelen af\nden skade, der er forårsaget for at\nhele brugerens HP.</language>
	</row>
	<row id="narc_0587_00139" index="139">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A cloud of poison gas\nis sprayed in the\nfoe’s face.\nIt may poison the\ntarget.</language>
	</row>
	<row id="narc_0587_00140" index="140">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Runde genstande\nkastes mod fjenden for at\nslå to til fem\ngange i træk.\n</language>
	</row>
	<row id="narc_0587_00141" index="141">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et bloddrænende\anfald. Brugerens\nHP gendannes med\nhalvdelen af ​​skaden\naf målet.</language>
	</row>
	<row id="narc_0587_00142" index="142">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Med et skræmmende ansigt\ntvinger brugeren et\nkkys på fjenden.\nDet kan få\nmålet til at falde i søvn.</language>
	</row>
	<row id="narc_0587_00143" index="143">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A second-turn attack\nmove with a high\ncritical-hit ratio.\nIt may also make the\ntarget flinch.</language>
	</row>
	<row id="narc_0587_00144" index="144">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren forvandler\ntil en kopi af\nfjenden lige ned til\nat have det samme træk\nsæt.</language>
	</row>
	<row id="narc_0587_00145" index="145">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A spray of countless\nbubbles is jetted at\nthe foe.\nIt may also lower the\ntarget’s Speed stat.</language>
	</row>
	<row id="narc_0587_00146" index="146">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver ramt med et\nrytmisk affyret\nslag, der også\nkan efterlade den forvirret.\n</language>
	</row>
	<row id="narc_0587_00147" index="147">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user scatters\nbursts of spores\nthat induce sleep.\n\n</language>
	</row>
	<row id="narc_0587_00148" index="148">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user flashes a\nlight that cuts the\nfoe’s accuracy.\nIt can also be used\nto illuminate caves.</language>
	</row>
	<row id="narc_0587_00149" index="149">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is attacked\nwith an odd, hot\nenergy wave.\nThe attack varies in\nintensity.</language>
	</row>
	<row id="narc_0587_00150" index="150">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user just flops\nand splashes around\nto no effect at all...\n\n</language>
	</row>
	<row id="narc_0587_00151" index="151">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user alters its\ncellular structure to\nliquefy itself,\nsharply raising its\nDefense stat.</language>
	</row>
	<row id="narc_0587_00152" index="152">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is hammered\nwith a large pincer.\nThis move has a high\ncritical-hit ratio.\n</language>
	</row>
	<row id="narc_0587_00153" index="153">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user explodes to\ninflict damage on all\nPokémon in battle.\nThe user faints upon\nusing this move.</language>
	</row>
	<row id="narc_0587_00154" index="154">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden rives med\nskarpe kløer eller\ncythes i to til\nfem gange i hurtig\nfølge.</language>
	</row>
	<row id="narc_0587_00155" index="155">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user throws the\nbone it holds. The\nbone loops to hit the\nfoe twice, coming and\ngoing.</language>
	</row>
	<row id="narc_0587_00156" index="156">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user goes to\nsleep for two turns.\nIt fully restores the\nuser’s HP and heals\nany status problem.</language>
	</row>
	<row id="narc_0587_00157" index="157">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Store kampesten\nkastes mod fjenden for at\nforvolde skade.\nDet kan også få\nmålet til at vige.</language>
	</row>
	<row id="narc_0587_00158" index="158">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren bider hårdt\nikke fjenden med sine\nskarpe forreste hugtænder.\nDet kan også få\nmålet til at ryste.</language>
	</row>
	<row id="narc_0587_00159" index="159">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user reduces its\npolygon count to\nmake itself more\njagged, raising the\nAttack stat.</language>
	</row>
	<row id="narc_0587_00160" index="160">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user changes its\ntype to become the\nsame type as one of\nits moves.\n</language>
	</row>
	<row id="narc_0587_00161" index="161">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren slår med\n samtidig tre-\nstråleangreb. Kan også\nlamme, brænde eller\nfryse målet.</language>
	</row>
	<row id="narc_0587_00162" index="162">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren hugger hårdt\ikke fjenden med sine\nskarpe forreste hugtænder.\nDet skærer målets\nHP til det halve.</language>
	</row>
	<row id="narc_0587_00163" index="163">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The foe is attacked\nwith a slash of\nclaws, etc.\nIt has a high\ncritical-hit ratio.</language>
	</row>
	<row id="narc_0587_00164" index="164">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user makes a\ncopy of itself using\nsome of its HP.\nThe copy serves as\nthe user’s decoy.</language>
	</row>
	<row id="narc_0587_00165" index="165">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et angreb, der\nbruges i desperation\kun hvis brugeren\nikke har PP. Det gør også lidt ondt\nbrugeren.</language>
	</row>
	<row id="narc_0587_00166" index="166">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det gør det muligt for brugeren\n at lære et træk brugt\naf fjenden.\nNår det er brugt, forsvinder træk\nSkitsen.</language>
	</row>
	<row id="narc_0587_00167" index="167">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A consecutive three-\nkick attack that\nbecomes more\npowerful with each \nsuccessive hit.</language>
	</row>
	<row id="narc_0587_00168" index="168">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren angriber og\nstjæler fjendens holdt\nitem samtidigt.\nDen kan ikke stjæle, hvis\brugeren har en genstand.</language>
	</row>
	<row id="narc_0587_00169" index="169">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren fanger\nfjenden med en tynd,\ngøj silke, så den ikke kan\nflygte fra kamp.\n</language>
	</row>
	<row id="narc_0587_00170" index="170">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user senses the\nfoe’s movements\nwith its mind to\nensure its next\nattack does not miss.</language>
	</row>
	<row id="narc_0587_00171" index="171">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A sleeping foe is\nshown a nightmare\nthat inflicts some\ndamage every turn.\n</language>
	</row>
	<row id="narc_0587_00172" index="172">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren dækker\nselv i ild og\nlader mod fjenden.\nDen kan også forlade\nmålet med en forbrænding.</language>
	</row>
	<row id="narc_0587_00173" index="173">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et angreb, der kun kan\nbruges, hvis\brugeren er i søvn. Den\nhårde støj kan også\nfå fjenden til at ryste.</language>
	</row>
	<row id="narc_0587_00174" index="174">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et træk, der virker\nanderledes for\nSpøgelsestypen end for\nalle de andre typer.\n</language>
	</row>
	<row id="narc_0587_00175" index="175">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren flakser \nøjeløst for at angribe.\nDet bliver mere\nkraftigt, jo mindre HP\nbrugeren har.</language>
	</row>
	<row id="narc_0587_00176" index="176">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren ændrer dens\ntype for at gøre sig\nmodstandsdygtig over for den type\nangreb, den sidst tog.</language>
	</row>
	<row id="narc_0587_00177" index="177">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En hvirvel af luft bliver\nskudt mod fjenden for at\npåføre skade.\nDen har et højt\nkritisk hit-forhold.</language>
	</row>
	<row id="narc_0587_00178" index="178">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user releases\ncottonlike spores\nthat cling to the\nfoe, sharply reducing\nits Speed stat.</language>
	</row>
	<row id="narc_0587_00179" index="179">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fuldstændigt angreb\nder bliver mere\nkraftigt, jo mindre\nHP brugeren har.\n</language>
	</row>
	<row id="narc_0587_00180" index="180">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren mister sit\nagt i farten\nsenest brugt af fjenden\nved at skære 4 PP fra\nit.</language>
	</row>
	<row id="narc_0587_00181" index="181">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user attacks with\na chilling gust of\npowdery snow.\nIt may also freeze\nthe target.</language>
	</row>
	<row id="narc_0587_00182" index="182">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det gør det muligt for brugeren\n at undgå alle angreb.\nDens chance for at mislykkes\nstiger, hvis den bruges i rækkefølge.</language>
	</row>
	<row id="narc_0587_00183" index="183">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user throws a\npunch at blinding\nspeed.\nIt is certain to\nstrike first.</language>
	</row>
	<row id="narc_0587_00184" index="184">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user frightens\nthe foe with a scary\nface to sharply\nreduce its Speed\nstat.</language>
	</row>
	<row id="narc_0587_00185" index="185">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user draws up to\nthe foe disarmingly,\nthen throws a sucker\npunch.\nIt hits without fail.</language>
	</row>
	<row id="narc_0587_00186" index="186">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user kisses the\nfoe with a sweet,\nangelic cuteness that\ncauses confusion.\n</language>
	</row>
	<row id="narc_0587_00187" index="187">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user maximizes\nits Attack stat in\nexchange for HP\nequal to half its max\nHP.</language>
	</row>
	<row id="narc_0587_00188" index="188">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren angriber ved at\nslynge beskidt slam\nat fjenden.\nDet kan også forgifte\nmålet.</language>
	</row>
	<row id="narc_0587_00189" index="189">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren kaster mudder i\nfjendens ansigt for at\nforvolde skade og\nsænke dens nøjagtighed.\n</language>
	</row>
	<row id="narc_0587_00190" index="190">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user attacks by\nspraying ink in the\nfoe’s face or eyes.\nIt may also lower the\ntarget’s accuracy.</language>
	</row>
	<row id="narc_0587_00191" index="191">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren lægger en fælde\naf pigge ved fjendens fødder. Fælden\ngør ondt på fjender, der\nskifter ind i kamp.</language>
	</row>
	<row id="narc_0587_00192" index="192">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user fires an\nelectric blast like a\ncannon to inflict\ndamage and cause\nparalysis.</language>
	</row>
	<row id="narc_0587_00193" index="193">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gør det muligt for brugeren at\nhitte en spøgelsestype med\nhver form for bevægelse. Det giver også brugeren\n mulighed for at ramme en undvigende fjende.</language>
	</row>
	<row id="narc_0587_00194" index="194">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når dette træk er\nbrugt, hvis brugeren\nbesvimer, besvimer fjenden, der\nlandede knockouten\nhit også.</language>
	</row>
	<row id="narc_0587_00195" index="195">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Any Pokémon that\nhears this song\nfaints in three turns\nunless it switches\nout of battle.</language>
	</row>
	<row id="narc_0587_00196" index="196">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user attacks with\na gust of chilled air.\nIt also lowers the\ntarget’s Speed stat.\n</language>
	</row>
	<row id="narc_0587_00197" index="197">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det gør det muligt for brugeren\n at undgå alle angreb.\nDens chance for at mislykkes\nstiger, hvis den bruges i rækkefølge.</language>
	</row>
	<row id="narc_0587_00198" index="198">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user strikes at\nthe foe with a hard\nbone two to five\ntimes in a row.\n</language>
	</row>
	<row id="narc_0587_00199" index="199">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren sørger for\naviger mod fjenden.\nDet sikrer, at det næste\angreb ikke mislykkes\nfor at ramme målet.</language>
	</row>
	<row id="narc_0587_00200" index="200">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The user rampages\nand attacks for two\nto three turns.\nHowever, it then\nbecomes confused.</language>
	</row>
	<row id="narc_0587_00201" index="201">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A five-turn sand-\nstorm is summoned\nto hurt all combatant\ntypes except Rock, \nGround, and Steel.</language>
	</row>
	<row id="narc_0587_00202" index="202">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et næringsdrænende\angreb. Brugerens\nHP gendannes med\nhalvdelen af ​​skaden\naf målet.</language>
