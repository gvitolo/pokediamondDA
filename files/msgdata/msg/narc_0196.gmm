<body language="English">
	<row id="narc_0196_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Okay, tak for din tålmodighed!\nLad os begynde den visuelle konkurrence!\r</language>
	</row>
	<row id="narc_0196_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dexter: Bidrag nummer 1!\n{STRVAR_1 3, 0}!\r{STRVAR_1 3, 0} har deltaget i konkurrencen\nmed {STRVAR_1 0, 1}!\r</language>
	</row>
	<row id="narc_0196_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dexter: Bidrag nummer 2!\n{STRVAR_1 3, 0}!\r{STRVAR_1 3, 0} deltager i vores konkurrence med\n{STRVAR_1 0, 1}!\r</language>
	</row>
	<row id="narc_0196_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dexter: Bidrag nummer 3!\n{STRVAR_1 3, 0}!\r{STRVAR_1 3, 0} er med i konkurrencen med\n{STRVAR_1 0, 1}!\r</language>
	</row>
	<row id="narc_0196_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dexter: Tilmelding nummer 4!\n{STRVAR_1 3, 0}!\r{STRVAR_1 3, 0}s konkurrence håber ride\nmed {STRVAR_1 0, 1}!\r</language>
	</row>
	<row id="narc_0196_00005" index="5">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dansekonkurrencen er næste gang!\nEr alle klar til dette?!\r</language>
	</row>
