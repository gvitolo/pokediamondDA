<?xml version='1.0' encoding='UTF-8'?>
<body language="English">
	<row id="narc_0616_00000" index="0">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語" />
	</row>
	<row id="narc_0616_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I nogen tid efter dens fødsel var det\nvokser ved at få næring fra\nfrøet på ryggen.</language>
	</row>
	<row id="narc_0616_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når knoppen på ryggen starter\nhævelse, en sød aroma vifter til\nangive blomstens kommende blomstring.</language>
	</row>
	<row id="narc_0616_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Efter en regnvejrsdag, blomsten på\ndens ryg lugter stærkere. De\nduft tiltrækker andre Pokémon.</language>
	</row>
	<row id="narc_0616_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ilden på halespidsen er en\nmål for dens levetid. Hvis sundt,\ndens hale brænder intenst.</language>
	</row>
	<row id="narc_0616_00005" index="5">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I klippebjergene hvor\nCHARMELEON live, deres brændende\nhaler skinner om natten som stjerner.</language>
	</row>
	<row id="narc_0616_00006" index="6">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges, at CHARIZARD's brand\nbrænder varmere, hvis den har\noplevet hårde kampe.</language>
	</row>
	<row id="narc_0616_00007" index="7">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den skjuler sig i sin skal,\nslår derefter tilbage med tude af\nvand ved enhver lejlighed.</language>
	</row>
	<row id="narc_0616_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges at leve 10.000 år.\nDens lodne hale er populær som en\nsymbol på lang levetid.</language>
	</row>
	<row id="narc_0616_00009" index="9">
		<attribute name="window_context_name">used</attribute>
		<language name="English">De vandstråler, den sprutter fra\nraketkanonerne på dens granat\nkan slå igennem tykt stål.</language>
	</row>
	<row id="narc_0616_00010" index="10">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den frigiver en stank fra dens røde farve\nantenne til at afvise fjender. Det\nvokser ved at smelte gentagne gange.</language>
	</row>
	<row id="narc_0616_00011" index="11">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En stålhård skal beskytter dens\nøm krop. Det holder stille og roligt\nstrabadser, mens de afventer udviklingen.</language>
	</row>
	<row id="narc_0616_00012" index="12">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den elsker blomsternes honning og\nkan lokalisere blomsterpletter, der\nhar selv små mængder pollen.</language>
	</row>
	<row id="narc_0616_00013" index="13">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den spiser sin vægt i blade hver\ndag. Det afværger angribere med\nnålen på hovedet.</language>
	</row>
	<row id="narc_0616_00014" index="14">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mens man afventer udviklingen\ngemmer sig fra rovdyr under\nblade og i afkroge af grene.</language>
	</row>
	<row id="narc_0616_00015" index="15">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens bedste angreb involverer at flyve\nrundt i høj fart, slå med\ngiftnåle og flyver derefter af sted.</language>
	</row>
	<row id="narc_0616_00016" index="16">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er føjelig og foretrækker at undgå\nkonflikt. Hvis de bliver forstyrret,\nden kan voldsomt slå tilbage.</language>
	</row>
	<row id="narc_0616_00017" index="17">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den flyver over sit brede territorium ind\nsøge efter bytte, nedkæmpe det\nmed sine højt udviklede kløer.</language>
	</row>
	<row id="narc_0616_00018" index="18">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ved at slå med vingerne med alle sine\nmåske, kan PIDGEOT lave et vindstød af\nvind i stand til at bøje høje træer.</language>
	</row>
	<row id="narc_0616_00019" index="19">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Forsigtig i det yderste, dens\nhårdfør vitalitet lader den leve ind\nenhver form for miljø.</language>
	</row>
	<row id="narc_0616_00020" index="20">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det skærer, det vokser konstant\nhugtænder ved at gnave på hårde ting.\nDet kan tygge askevægge fra hinanden.</language>
	</row>
	<row id="narc_0616_00021" index="21">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den slår travlt med sine små vinger\nflyve. Ved hjælp af sit næb søger den\ni græs for bytte.</language>
	</row>
	<row id="narc_0616_00022" index="22">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har udholdenhed til at blive ved med at flyve\nhele dagen på sine brede vinger. Det\nkæmper ved at bruge sit skarpe næb.</language>
	</row>
	<row id="narc_0616_00023" index="23">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den sniger sig gennem græs uden\nlaver en lyd og slår\nintetanende bytte bagfra.</language>
	</row>
	<row id="narc_0616_00024" index="24">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mønsteret på maven er til\nintimidering. Det trækker fjender sammen\nmens de er frosset af frygt.</language>
	</row>
	<row id="narc_0616_00025" index="25">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis den mister knitrende kraft fra\nde elektriske poser på sin\nkinder, det er på vagt.</language>
	</row>
	<row id="narc_0616_00026" index="26">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kan miste 100.000 volt udbrud\naf elektricitet, øjeblikkeligt nedadgående\nfjender flere gange dens størrelse.</language>
	</row>
	<row id="narc_0616_00027" index="27">
		<attribute name="window_context_name">used</attribute>
		<language name="English">For at beskytte sig mod angribere,\ndet krøller sig sammen til en bold. Den bor i\ntørre områder med minimal nedbør.</language>
	</row>
	<row id="narc_0616_00028" index="28">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den krøller sig sammen og ruller så til fjender\nmed ryggen. Dens skarpe rygsøjler\npåføre alvorlig skade.</language>
	</row>
	<row id="narc_0616_00029" index="29">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Selvom den ikke foretrækker at kæmpe,\nselv en dråbe af giften det\nudskillelse fra modhager kan være dødelig.</language>
	</row>
	<row id="narc_0616_00030" index="30">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når den mærker fare, rejser den sig\nalle modhager på dens krop. Disse\nmodhager vokser langsommere end NIDORINOs.</language>
	</row>
	<row id="narc_0616_00031" index="31">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hele dens krop er pansret med\nhårde vægte. Det vil beskytte\nung i sin hule med sit liv.</language>
	</row>
	<row id="narc_0616_00032" index="32">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den scanner sine omgivelser ved\nløfter ørerne op af græsset.\nDets giftige horn er til beskyttelse.</language>
	</row>
	<row id="narc_0616_00033" index="33">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har et voldsomt gemyt og\nstikker fjender med sit horn, som\noser gift ved sammenstød.</language>
	</row>
	<row id="narc_0616_00034" index="34">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et sving med dens mægtige hale kan\nknække en telefonpæl, som om den var\nen tændstik.</language>
	</row>
	<row id="narc_0616_00035" index="35">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den flyver ved hjælp af vingerne på den\ntilbage for at samle måneskin. Denne\nPokémon er svær at finde.</language>
	</row>
	<row id="narc_0616_00036" index="36">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens hørelse er så akut, at den kan\nhøre en knappenål falde over en halv kilometer\nvæk. Den lever på stille bjerge.</language>
	</row>
	<row id="narc_0616_00037" index="37">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den styrer ildkugler. Som det\nvokser, dens seks haler splittes fra\nderes tips til at lave flere haler.</language>
	</row>
	<row id="narc_0616_00038" index="38">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens ni haler siges at være\ngennemsyret af en mystisk kraft.\nDen kan leve i tusind år.</language>
	</row>
	<row id="narc_0616_00039" index="39">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når den vakler, er den stor, rund\nøjne, begynder den at synge en vuggevise\ndet gør alle døsige.</language>
	</row>
	<row id="narc_0616_00040" index="40">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens fine pels føles sublim til\nrøre. Den kan udvide sin krop ved\nindånding af luft.</language>
	</row>
	<row id="narc_0616_00041" index="41">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kan ikke lide sollys og sover\ndybt inde i skove og huler\nindtil solnedgang.</language>
	</row>
	<row id="narc_0616_00042" index="42">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når først den begynder at suge blod, er den\nstopper ikke før den er fuld. Det\nfluer om natten på jagt efter bytte.</language>
	</row>
	<row id="narc_0616_00043" index="43">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den planter ofte sine rodfødder i\njord om dagen og søer\nfrø, når den går om natten.</language>
	</row>
	<row id="narc_0616_00044" index="44">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Honningen savler den fra munden\nlugter så grusomt, at det kan krølle\nnæser mere end en kilometer væk.</language>
	</row>
	<row id="narc_0616_00045" index="45">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens kronblade er de største i\nverden. Mens den går, spreder den sig\nekstremt allergifremkaldende pollen.</language>
	</row>
	<row id="narc_0616_00046" index="46">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Svampe ved navn tochukaso vokser\npå ryggen. De vokser med\nmed værten PARAS.</language>
	</row>
	<row id="narc_0616_00047" index="47">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det styres af en svamp\nvokset sig større end bugkroppen.\nDet siges at foretrække fugtige steder.</language>
	</row>
	<row id="narc_0616_00048" index="48">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens store øjne er faktisk klynger\naf små øjne. Om natten er dens slags\ntegnet af lys.</language>
	</row>
	<row id="narc_0616_00049" index="49">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den slår med vingerne for at sprede sig\nstøvlignende skæl. Skællene udvaskes\ngiftstoffer, hvis de kommer i kontakt med huden.</language>
	</row>
	<row id="narc_0616_00050" index="50">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon, der lever under jorden.\nPå grund af dets mørke habitat er det det\nfrastødes af stærkt sollys.</language>
	</row>
	<row id="narc_0616_00051" index="51">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens tre hoveder bevæger sig skiftevis,\nkøre den gennem hård jord til\ndybder på over 60 miles.</language>
	</row>
	<row id="narc_0616_00052" index="52">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er af natlig natur. Hvis det\nfår øje på noget skinnende, dets øjne\nglitter klart.</language>
	</row>
	<row id="narc_0616_00053" index="53">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En meget hovmodig Pokémon. Blandt\nfans, størrelsen af ​​juvelen i sin\npanden er et emne, der diskuteres meget.</language>
	</row>
	<row id="narc_0616_00054" index="54">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den husker aldrig at bruge den\nulige kræfter, så den vipper altid\ndens hoved i forvirring.</language>
	</row>
	<row id="narc_0616_00055" index="55">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens svømmefødder er veludviklede\nlemmer giver den chokerende fart. Det er det\nden bedste svømmer blandt Pokémon.</language>
	</row>
	<row id="narc_0616_00056" index="56">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever i trætopkolonier.\nHvis man bliver rasende, det hele\nkolonien hærger uden grund.</language>
	</row>
	<row id="narc_0616_00057" index="57">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bliver vred, hvis du ser dens øjne\nog bliver mere vred, hvis du løber. Hvis du\nslå det, det bliver endnu mere galt.</language>
	</row>
	<row id="narc_0616_00058" index="58">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon med en loyal natur.\nDen forbliver ubevægelig, indtil den er det\ngivet en ordre af sin træner.</language>
	</row>
	<row id="narc_0616_00059" index="59">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens stolte og kongelige udseende\nhar fanget hjerterne hos\nmennesker for længe siden.</language>
	</row>
	<row id="narc_0616_00060" index="60">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens hud er så tynd, dens indre\norganer er synlige. Den har problemer\ngår på sine nyvoksne fødder.</language>
	</row>
	<row id="narc_0616_00061" index="61">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Spiralmønsteret på maven\nsubtilt bølger. Stirrer på det\ngradvist forårsager døsighed.</language>
	</row>
	<row id="narc_0616_00062" index="62">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Med sine ekstremt hårde muskler,\nden kan blive ved med at svømme i Stillehavet\nOcean uden hvile.</language>
	</row>
	<row id="narc_0616_00063" index="63">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Selv mens den sover, opretholder den en\ntelepatisk radar. Den teleporterer\nnår den er truet.</language>
	</row>
	<row id="narc_0616_00064" index="64">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når den bruger sin psykiske kraft, er den\nudsender stærke alfabølger, der kan\nødelægge præcisionsenheder.</language>
	</row>
	<row id="narc_0616_00065" index="65">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens højt udviklede hjerne er tændt\npå linje med en supercomputer. Det kan den\nbruge alle former for psykiske evner.</language>
	</row>
	<row id="narc_0616_00066" index="66">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens muskler kramper dog aldrig\nmeget det træner. Den bor i\nbjerge væk fra mennesker.</language>
	</row>
	<row id="narc_0616_00067" index="67">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kan løfte en dumper med en\nhånd. Det hjælper at bruge den magt\nmennesker med tungt arbejde.</language>
	</row>
	<row id="narc_0616_00068" index="68">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det kan banke et tog, der flyver med en\nslag. Det er dog forfærdeligt kl\ndelikat arbejde med fingrene.</language>
	</row>
	<row id="narc_0616_00069" index="69">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det foretrækker varmt og fugtigt\nmiljøer. Det er hurtigt kl\nfanger bytte med sine vinstokke.</language>
	</row>
	<row id="narc_0616_00070" index="70">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon, der ser ud til at være en\nplante. Den fanger uforsigtigt bytte ved\noverhæld dem med et giftigt pulver.</language>
	</row>
	<row id="narc_0616_00071" index="71">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den samler væske i munden\nen honninglignende duft, hvilket virkelig er\nen syre, der opløser hvad som helst.</language>
	</row>
	<row id="narc_0616_00072" index="72">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den driver i havstrømme.\nUtallige fiskere er\nsåret af dens giftstikker.</language>
	</row>
	<row id="narc_0616_00073" index="73">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det advarer andre om fare ved\nblinkende de røde kugler\npå hovedet.</language>
	</row>
	<row id="narc_0616_00074" index="74">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er umuligt at skelne fra\nsten. Det slår mod andre ind\nhårdhedskonkurrencer.</language>
	</row>
	<row id="narc_0616_00075" index="75">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den vælter ned ad skråninger uden hensyn\naf eventuelle kropsdele, der afhugger.\nDen spiser et væld af sten dagligt.</language>
	</row>
	<row id="narc_0616_00076" index="76">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den vælter ned af bjerge og forlader\nriller fra top til base.\nHold dig fri af disse riller.</language>
	</row>
	<row id="narc_0616_00077" index="77">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens ben bliver stærke, mens den\njagter sin forælder. Den kører\ni marker og bjerge hele dagen.</language>
	</row>
	<row id="narc_0616_00078" index="78">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har en forbløffende acceleration.\nFra stilstand kan den nå\ntophastighed inden for 10 trin.</language>
	</row>
	<row id="narc_0616_00079" index="79">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Selvom den er langsom, er den dygtig til\nfisker med halen. Det gør den ikke\nføle smerte, hvis dens hale er bidt.</language>
	</row>
	<row id="narc_0616_00080" index="80">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Selvom det normalt er svagt bevidst\nsynes at blive inspireret, hvis\nSHELLDER på halen bider ned.</language>
	</row>
	<row id="narc_0616_00081" index="81">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Enhederne på dens sider genererer\nelektromagnetiske bølger, der holder det\nluftbårne. Den lever af elektricitet.</language>
	</row>
	<row id="narc_0616_00082" index="82">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er faktisk tre MAGNEMITE\nforbundet med magnetisme. En gruppe kan\nsatte en magnetisk storm i gang.</language>
	</row>
	<row id="narc_0616_00083" index="83">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kan ikke leve uden stilken den\nholder. Det er derfor, det forsvarer\nforfølge angriberne med sit liv.</language>
	</row>
	<row id="narc_0616_00084" index="84">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hjernerne i dens to hoveder vises\nat kommunikere følelser til hver enkelt\nandre med en telepatisk kraft.</language>
	</row>
	<row id="narc_0616_00085" index="85">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når DODUO udvikler sig til dette mærkelige\nrace, et af dens hoveder deler sig i\nto. Den kører næsten 40 km/t.</language>
	</row>
	<row id="narc_0616_00086" index="86">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon, der lever på isbjerge.\nDen svømmer i havet ved hjælp af spidsen\npå hovedet for at bryde is op.</language>
	</row>
	<row id="narc_0616_00087" index="87">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I sne, den rene hvide pels\nat dække dens krop skjuler den for\nrovdyr.</language>
	</row>
	<row id="narc_0616_00088" index="88">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det blev født, når slam i en beskidt\nåen blev udsat for månens\nRøntgenstråler. Det dukker op blandt snavs.</language>
	</row>
	<row id="narc_0616_00089" index="89">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En giftig væske siver fra dens krop.\nVæsken dræber øjeblikkeligt planter og\ntræer ved kontakt.</language>
	</row>
	<row id="narc_0616_00090" index="90">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den svømmer baglæns ved at åbne og\nlukker sine to skaller. Den er stor\ntungen bliver altid holdt ude.</language>
	</row>
	<row id="narc_0616_00091" index="91">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kæmper ved at beholde sin skal\ntæt lukket for beskyttelse og\nved at skyde pigge for at afvise fjender.</language>
	</row>
	<row id="narc_0616_00092" index="92">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon født af giftgasser.\nDet besejrer selv de største fjender\nved at indhylle dem i gas.</language>
	</row>
	<row id="narc_0616_00093" index="93">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den slikker med sin gasformige tunge\nat stjæle ofrets livskraft.\nDen lurer i mørket efter bytte.</language>
	</row>
	<row id="narc_0616_00094" index="94">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lurer i de skyggefulde hjørner\naf værelser, det afventer chancer til\nstjæle dets byttes livskraft.</language>
	</row>
	<row id="narc_0616_00095" index="95">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det svirrer gennem jorden\nved hjælp af sin lange og robuste krop.\nDen spiser altid, mens den graver.</language>
	</row>
	<row id="narc_0616_00096" index="96">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det kan fortælle, hvad folk er\ndrømmer ved at snuse med sin store\nnæse. Den elsker sjove drømme.</language>
	</row>
	<row id="narc_0616_00097" index="97">
		<attribute name="window_context_name">used</attribute>
		<language name="English">At se dens svingende pendul dåse\nfremkalde søvn på tre sekunder,\nselv hos en, der lige er vågnet.</language>
	</row>
	<row id="narc_0616_00098" index="98">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever i huler gravet på sand\nstrande. Dens tang vokser fuldt ud\ntilbage, hvis de er knækkede i kamp.</language>
	</row>
	<row id="narc_0616_00099" index="99">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den større tang har 10.000-\nhestekræfter styrke. Imidlertid er det\ner så tung, at det er svært at sigte.</language>
	</row>
	<row id="narc_0616_00100" index="100">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det ligner bare en Poké Ball.\nDet er farligt, fordi det kan\nelektrisk stød eller eksplodere ved berøring.</language>
	</row>
	<row id="narc_0616_00101" index="101">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er kendt at drive på vind, hvis det\ner oppustet til sprængfyldt med lagret\nelektricitet.</language>
	</row>
	<row id="narc_0616_00102" index="102">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens seks æg taler ved hjælp af\ntelepati. De kan hurtigt samles\nhvis de bliver adskilt.</language>
	</row>
	<row id="narc_0616_00103" index="103">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kaldes "The Walking Jungle".\nHvis et hoved bliver for stort, falder det\nslukket og bliver en EXEGGCUTE.</language>
	</row>
	<row id="narc_0616_00104" index="104">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når den tænker på sin døde mor,\ndet græder. Dens gråd gør\nkraniet det bærer rasle hult.</language>
	</row>
	<row id="narc_0616_00105" index="105">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fra sin fødsel, denne vilde Pokémon\nholder konstant knogler. Det er det\ndygtige til at bruge dem som våben.</language>
	</row>
	<row id="narc_0616_00106" index="106">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens ben kan strække sig dobbelt.\nFørstegangsfjender bliver overrasket over\ndens udvidelige rækkevidde.</language>
	</row>
	<row id="narc_0616_00107" index="107">
		<attribute name="window_context_name">used</attribute>
		<language name="English">De armvridende slag, den kaster\npulverisere selv beton. Den hviler\nefter tre minutters kamp.</language>
	</row>
	<row id="narc_0616_00108" index="108">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I stedet for hænder bruger den sin\ntungen, som er dobbelt så høj.\nDens klæbrige spyt griber hvad som helst.</language>
	</row>
	<row id="narc_0616_00109" index="109">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gasser, der er lettere end luft i kroppen\nholde det oppe. Gasserne ikke kun\nlugter, de er også eksplosive.</language>
	</row>
	<row id="narc_0616_00110" index="110">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den vokser ved at fodre på gasser\nfrigivet af affald. Skønt meget\nsjældne, trillinger er fundet.</language>
	</row>
	<row id="narc_0616_00111" index="111">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens krop er klædt i et tykt skind,\nog dets tackler vælter bygninger.\nDesværre er det ikke smart.</language>
	</row>
	<row id="narc_0616_00112" index="112">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens hjerne udviklede sig efter den stod op\nop på bagbenene. Dens borehorn\nborer tunneler gennem fast klippe.</language>
	</row>
	<row id="narc_0616_00113" index="113">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lægger flere æg om dagen og\nvil ikke dele dem med dem\nsom har ondskab i deres hjerter.</language>
	</row>
	<row id="narc_0616_00114" index="114">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er indhyllet af blå vinstokke.\nIngen har set ansigtet skjult\nbag denne vækst af vinstokke.</language>
	</row>
	<row id="narc_0616_00115" index="115">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den rejser sit afkom i maven\npose. Det slipper barnet ud til\nspille kun, når det føles sikkert.</language>
	</row>
	<row id="narc_0616_00116" index="116">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den laver sin rede i skyggen af\nkoraller. Hvis den mærker fare, er den\nspytter grumset blæk og flygter.</language>
	</row>
	<row id="narc_0616_00117" index="117">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens rygsøjler giver beskyttelse.\nDens finner og knogler er værdsat som\ntraditionelle medicin ingredienser.</language>
	</row>
	<row id="narc_0616_00118" index="118">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den svømmer med jævne 5 knob.\nHvis den mærker fare, vil den slå til\ntilbage med sit skarpe horn.</language>
	</row>
	<row id="narc_0616_00119" index="119">
		<attribute name="window_context_name">used</attribute>
		<language name="English">For at beskytte sin familie vil den kæmpe\nmed sit boreskarpe horn. Den lever\ni udhulede klipper i vandløb.</language>
	</row>
	<row id="narc_0616_00120" index="120">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis dens krop er revet, kan den vokse\ntilbage, hvis den røde kerne forbliver.\nKernen blinker ved midnat.</language>
	</row>
	<row id="narc_0616_00121" index="121">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I midten af ​​dens krop er en rød\nkerne, som sender mystiske\nradiosignaler til nattehimlen.</language>
	</row>
	<row id="narc_0616_00122" index="122">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Udstråling fra dens fingerspidser\nstørkner luften til usynlige vægge\nsom afviser selv hårde angreb.</language>
	</row>
	<row id="narc_0616_00123" index="123">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er næsten umuligt at parere\ndens angribende le. Dens\nbevægelser er som en ninjas.</language>
	</row>
	<row id="narc_0616_00124" index="124">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens råb lyder som menneskelig tale.\nDet er dog umuligt at sige\nhvad den forsøger at sige.</language>
	</row>
	<row id="narc_0616_00125" index="125">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Halvdelen af ​​alle strømafbrydelser opstår når\ndenne Pokémon dukker op ved magten\nplanter og spiser elektricitet.</language>
	</row>
	<row id="narc_0616_00126" index="126">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Født i tuden fra en vulkan,\ndens krop er dækket af flammer\nder skinner som solen.</language>
	</row>
	<row id="narc_0616_00127" index="127">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den griber byttet med sine tang\nindtil byttet er revet i halve.\nHvad den ikke kan rive, kaster den langt.</language>
	</row>
	<row id="narc_0616_00128" index="128">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når først den tager sigte på sin fjende, så er den\nlaver en hovedkulds opladning. Det er det\nberømt for sin voldelige natur.</language>
	</row>
	<row id="narc_0616_00129" index="129">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er ikke i stand til at svømme mod selv\nlangsomt bevægende strømme. Det altid\nsprøjter rundt af en eller anden grund.</language>
	</row>
	<row id="narc_0616_00130" index="130">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I oldtidens litteratur er der en\nregistrering af en GYARADOS, der raserede\nen landsby, hvor volden blussede op.</language>
	</row>
	<row id="narc_0616_00131" index="131">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den elsker at krydse havet med\nmennesker og Pokémon på ryggen.\nDen forstår menneskelig tale.</language>
	</row>
	<row id="narc_0616_00132" index="132">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det har evnen til at rekonstituere\nhele dens cellulære struktur til\nforvandle sig til, hvad den ser.</language>
	</row>
	<row id="narc_0616_00133" index="133">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En sjælden Pokémon, der tilpasser sig\nbarske miljøer ved at tage på\nforskellige evolutionære former.</language>
	</row>
	<row id="narc_0616_00134" index="134">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det har udviklet sig til at være egnet til\net vandlevende liv. Det kan usynligt\nsmelte væk i vand.</language>
	</row>
	<row id="narc_0616_00135" index="135">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den styrer 10.000 volt strøm\nog kan hæve al pelsen på sin\nkrop, som var det skarpe nåle.</language>
	</row>
	<row id="narc_0616_00136" index="136">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har en flammesæk i kroppen.\nDens kropstemperatur topper 1.650\ngrader Fahrenheit før kamp.</language>
	</row>
	<row id="narc_0616_00137" index="137">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Verdens første kunstigt\nskabte Pokémon. Den kan rejse\ngennem elektronisk rum.</language>
	</row>
	<row id="narc_0616_00138" index="138">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon, der genopstod\nfra et fossil ved hjælp af moderne videnskab.\nDen svømmede i gamle have.</language>
	</row>
	<row id="narc_0616_00139" index="139">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det menes, at denne Pokémon\nuddøde, fordi dens spiral\nskallen blev for stor.</language>
	</row>
	<row id="narc_0616_00140" index="140">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det menes at have beboet\nstrande for 300 millioner år siden.\nDen er beskyttet af en stiv skal.</language>
	</row>
	<row id="narc_0616_00141" index="141">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det menes, at denne Pokémon\nkom ind på land, fordi dens\nbytte, der er tilpasset livet på land.</language>
	</row>
	<row id="narc_0616_00142" index="142">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon, der strejfede i himlen\ni dinosaurernes æra. Dens tænder er\nsom savklinger.</language>
	</row>
	<row id="narc_0616_00143" index="143">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den holder op med at spise kun for at sove.\nDet føles ikke fyldt, medmindre det\nspiser næsten 900 pund om dagen.</language>
	</row>
	<row id="narc_0616_00144" index="144">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En legendarisk fugl Pokémon.\nDet kan skabe snestorme ved\nfrysende fugt i luften.</language>
	</row>
	<row id="narc_0616_00145" index="145">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En legendarisk Pokémon, der siges\nat leve i tordenskyer. Det frit\nstyrer lyn.</language>
	</row>
	<row id="narc_0616_00146" index="146">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En af de legendariske fugle Pokémon.\nDet siges, at dens udseende\nindikerer forårets komme.</language>
	</row>
	<row id="narc_0616_00147" index="147">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det kaldes "Mirage Pokémon"\nfordi så få har set det.\nDens udgydte hud er fundet.</language>
	</row>
	<row id="narc_0616_00148" index="148">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis dens krop antager en aura, vil den\nvejret skifter øjeblikkeligt. Det er det\nsiges at leve i have og søer.</language>
	</row>
	<row id="narc_0616_00149" index="149">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges at gøre sit hjem\net sted i havet. Det vejleder\nbesætninger af skibsvrag til land.</language>
	</row>
	<row id="narc_0616_00150" index="150">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon skabt ved at rekombinere\nMEWs gener. Det siges at have\nmest vilde hjerte blandt Pokémon.</language>
	</row>
	<row id="narc_0616_00151" index="151">
		<attribute name="window_context_name">used</attribute>
		<language name="English">For den kan bruge alle slags\nbevæger sig, mener mange forskere MEW\nat være forfader til Pokémon.</language>
	</row>
	<row id="narc_0616_00152" index="152">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bruger bladet på hovedet til\nbestemme temperaturen og\nfugtighed. Den elsker at solbade.</language>
	</row>
	<row id="narc_0616_00153" index="153">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Knopperne, der ringer dens hals, giver\naf en krydret aroma, der forfriskende\nfolk op.</language>
	</row>
	<row id="narc_0616_00154" index="154">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens ånde har det fantastiske\nevne til at genoplive døde planter og\nblomster.</language>
	</row>
	<row id="narc_0616_00155" index="155">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har en frygtsom natur. Hvis det er\nforskrækket, flammerne på ryggen\nbrænde kraftigere.</language>
	</row>
	<row id="narc_0616_00156" index="156">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det skræmmer fjender med varmen\naf dens flammer. Ilden brænder mere\nstærkt, når den er klar til at kæmpe.</language>
	</row>
	<row id="narc_0616_00157" index="157">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den angriber ved hjælp af ildsprængninger.\nDet skaber varmeskimmer med\nintens ild for at skjule sig selv.</language>
	</row>
	<row id="narc_0616_00158" index="158">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har for vane at bide hvad som helst\nmed sine udviklede kæber. Selv dens\nTræner skal være forsigtig.</language>
	</row>
	<row id="narc_0616_00159" index="159">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når den først bider ned, giver den ikke slip\nindtil den mister hugtænderne. Nye hugtænder\nhurtigt vokse på plads.</language>
	</row>
	<row id="narc_0616_00160" index="160">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det bevæger sig normalt langsomt, men det\ngår i blændende fart, når den\nangriber og bider bytte.</language>
	</row>
	<row id="narc_0616_00161" index="161">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det har en meget nervøs karakter.\nDen står højt op på halen, så den\nkan scanne brede områder.</language>
	</row>
	<row id="narc_0616_00162" index="162">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Moderen sætter sit afkom til\nsove ved at krølle op omkring dem.\nDet sætter fjender i hjørner med fart.</language>
	</row>
	<row id="narc_0616_00163" index="163">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den skifter stående fod så\nhurtigt, det kan ikke ses. Det græder\npå samme tid hver dag.</language>
	</row>
	<row id="narc_0616_00164" index="164">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis den vender hovedet på hovedet,\ndet er et tegn på, at den er engageret i\nmeget kompleks tænkning.</language>
	</row>
	<row id="narc_0616_00165" index="165">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er så frygtsom, at den ikke kan bevæge sig, hvis den er\ner ikke sammen med en sværm af andre. Det\nformidler sine følelser med duft.</language>
	</row>
	<row id="narc_0616_00166" index="166">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bruger stjernelys som energi. Når\nflere stjerner vises om natten, den\nmønstre på ryggen vokser sig større.</language>
	</row>
	<row id="narc_0616_00167" index="167">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det sætter en fælde ved at spinde et spind\nmed tynd men stærk silke. Det venter\nubevægeligt for byttet at ankomme.</language>
	</row>
	<row id="narc_0616_00168" index="168">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den fæstner silke til sit bytte og\nsætter den fri. Senere sporer den\nsilke til byttet og dets venner.</language>
	</row>
	<row id="narc_0616_00169" index="169">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon, der vandt meget\nforbedret flyvepræstation ved\nat dens ben bliver til vinger.</language>
	</row>
	<row id="narc_0616_00170" index="170">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det udleder positive og\nnegativ elektricitet fra dens\nantennespidser for at chokere sine fjender.</language>
	</row>
	<row id="narc_0616_00171" index="171">
		<attribute name="window_context_name">used</attribute>
		<language name="English">LANTURNs lys kan lyse op fra\nstore dybder. Den får tilnavnet\n"Dybhavsstjernen."</language>
	</row>
	<row id="narc_0616_00172" index="172">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den leger med andre ved berøring\nhaler og gnister. Denne\nsynes at være en prøve på modet.</language>
	</row>
	<row id="narc_0616_00173" index="173">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mange dukker op, når nattehimlen\ner fyldt med stjerneskud.\nDe forsvinder med solopgang.</language>
	</row>
	<row id="narc_0616_00174" index="174">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har en blød og hoppende krop.\nNår den først begynder at hoppe, er den\nbliver umuligt at stoppe.</language>
	</row>
	<row id="narc_0616_00175" index="175">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens skal siges at være fyldt\nmed glæde, som den deler med\ngodhjertede mennesker.</language>
	</row>
	<row id="narc_0616_00176" index="176">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges at dukke op foran\nvenlige mennesker til at sprede en glødende\nned kaldet "glædestøv".</language>
	</row>
	<row id="narc_0616_00177" index="177">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den plukker mad fra kaktusplanter,\nbehændigt undgå knopper og rygsøjler.\nDet ser ud til at springe over at flytte.</language>
	</row>
	<row id="narc_0616_00178" index="178">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Denne mærkelige Pokémon kan se begge dele\nfortiden og fremtiden. Det øjne\nsolens bevægelse hele dagen.</language>
	</row>
	<row id="narc_0616_00179" index="179">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens fluffy pels svulmer op til det dobbelte\nnår statisk elektricitet opbygges.\nAt røre ved det kan være chokerende.</language>
	</row>
	<row id="narc_0616_00180" index="180">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis dens pels bliver fuldt opladet\nmed elektricitet lyser dens hale.\nDet affyrer hår, der zapper ved stød.</language>
	</row>
	<row id="narc_0616_00181" index="181">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Spidsen af ​​dens hale skinner klart.\nI gamle dage sendte folk\nsignaler ved hjælp af halens lys.</language>
	</row>
	<row id="narc_0616_00182" index="182">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når den kraftige regnsæson\nender, trækkes den ud af varm\nsollys til at danse i det fri.</language>
	</row>
	<row id="narc_0616_00183" index="183">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Spidsen af ​​dens hale er fyldt med olie\ndet er lettere end vand, så det\nfungerer som en flyder.</language>
	</row>
	<row id="narc_0616_00184" index="184">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens lange ører er fremragende sensorer.\nDet kan skelne bevægelserne\naf levende ting på flodsenge.</language>
	</row>
	<row id="narc_0616_00185" index="185">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den står langs stier og lader som om\nat være et træ. Hvis det begynder at regne,\ndet ser ud til at forsvinde.</language>
	</row>
	<row id="narc_0616_00186" index="186">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det samler grupper af andre som\nderes leder. Dens råb gør\nPOLIWAG adlyder.</language>
	</row>
	<row id="narc_0616_00187" index="187">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den driver på vind. Det siges det\nnår HOPPIP samles i marker og\nbjerge, foråret er på vej.</language>
	</row>
	<row id="narc_0616_00188" index="188">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den blomstrer, når vejret varmer.\nDet svæver på himlen for at suge til sig som\nså meget sollys som muligt.</language>
	</row>
	<row id="narc_0616_00189" index="189">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Blæst af sæsonbestemte vinde, det\ncirkler rundt om kloden og spreder sig\nbomuldssporer som det går.</language>
	</row>
	<row id="narc_0616_00190" index="190">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever på toppen af ​​gigantiske træer.\nDen vikler halen omkring en gren\nså den ikke falder af, mens den sover.</language>
	</row>
	<row id="narc_0616_00191" index="191">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det falder pludselig ud af himlen\nmorgenen. Et år efter en forkølelse\nsommer, eksploderer deres befolkning.</language>
	</row>
	<row id="narc_0616_00192" index="192">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den får energi fra varmt sollys\nog er kendt for sin vane med\nbevæger sig i jagten på det.</language>
	</row>
	<row id="narc_0616_00193" index="193">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens øjne kan se 360 ​​grader\nuden at bevæge hovedet. Det vil det ikke\nsavner bytte - selv dem bag det.</language>
	</row>
	<row id="narc_0616_00194" index="194">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når temperaturen afkøles i\naften kommer de op af vandet\nat søge mad langs kysten.</language>
	</row>
	<row id="narc_0616_00195" index="195">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En tåbelig Pokémon. Det gør den ikke\npas på hvis den støder hovedet ind i\nbåde eller sten, mens du svømmer.</language>
	</row>
	<row id="narc_0616_00196" index="196">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens pels har udseendet og følelsen af\nfløjl. Kuglen på panden\nlyser, når den bruger psyko-kraft.</language>
	</row>
	<row id="narc_0616_00197" index="197">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Månens lys ændrede sig\nEEVEEs genetiske struktur. Det\nlurer i mørket efter bytte.</language>
	</row>
	<row id="narc_0616_00198" index="198">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det ser ud til at være tæt på rejsende at lokke\ndem ind i dybe skove. Det siges\nat bære ulykke.</language>
	</row>
	<row id="narc_0616_00199" index="199">
		<attribute name="window_context_name">used</attribute>
		<language name="English">At blive bidt af SHELLDER gav det\nintelligens sammenlignelig med\nprisvindende videnskabsmænd.</language>
	</row>
	<row id="narc_0616_00200" index="200">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den får næring fra frygt\nat den absorberer i sine røde kugler.\nOm dagen sover den i mørke.</language>
	</row>
	<row id="narc_0616_00201" index="201">
		<attribute name="window_context_name">used</attribute>
		<language name="English">De ser ud til at kommunikere imellem\nhinanden telepatisk. De\nfindes altid fast på vægge.</language>
	</row>
	<row id="narc_0616_00202" index="202">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den prøver desperat at beholde sin\nsort hale skjult. Det siges at være\nbevis på at halen gemmer på en hemmelighed.</language>
	</row>
	<row id="narc_0616_00203" index="203">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mens den sover, er hovedet på sit\nhalen holder øje. Halen gør ikke\nhar brug for at sove.</language>
	</row>
	<row id="narc_0616_00204" index="204">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det ligner bare en fyrrekogle.\nDens skal beskytter den mod fugle\nPokémon, der pikker den ved en fejl.</language>
	</row>
	<row id="narc_0616_00205" index="205">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er indkapslet i en stålskal. Dens\nkiggende øjne er alt, hvad der kan være\nset af dens mystiske indre.</language>
	</row>
	<row id="narc_0616_00206" index="206">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den graver sig ned i jorden med sin\nhale og laver en labyrintlignende rede.\nDen kan bare flyve lidt.</language>
	</row>
	<row id="narc_0616_00207" index="207">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den sejler på vinden med sin\nlemmer udvidet til at slå fra\nhimmel. Den sigter mod byttets ansigt.</language>
	</row>
	<row id="narc_0616_00208" index="208">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den tygger sig gennem kampesten\nmed sine robuste kæber. Dens øjne kan\nse i mørket under jorden.</language>
	</row>
	<row id="narc_0616_00209" index="209">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Små Pokémon flygter fra dets skræmmende\nansigt. Det overvejes dog\naf kvinder at være sød.</language>
	</row>
	<row id="narc_0616_00210" index="210">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er frygtsom på trods af sit udseende.\nHvis den bliver rasende,\nden vil slå med sine enorme hugtænder.</language>
	</row>
	<row id="narc_0616_00211" index="211">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den skyder de giftige rygsøjler på sin\nkrop i alle retninger. Den er rund\nform gør den til en dårlig svømmer.</language>
	</row>
	<row id="narc_0616_00212" index="212">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har en stålhård krop. Det\nintimiderer fjender ved at hæve dens\nøjenmønstrede tang.</language>
	</row>
	<row id="narc_0616_00213" index="213">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den opbevarer bær i sin skal.\nBærene gærer til sidst til\nblive lækre juicer.</language>
	</row>
	<row id="narc_0616_00214" index="214">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Med kraftige ben og kløer,\ndet genererer nok kraft til at kaste\nfjender over store afstande.</language>
	</row>
	<row id="narc_0616_00215" index="215">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er ekstremt ondskabsfuldt og vil ikke\nstop med at angribe, indtil dens fjende er\nude af stand til at bevæge sig.</language>
	</row>
	<row id="narc_0616_00216" index="216">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lader honning trænge ind i sine poter\nså den kan slikke dem hele tiden.\nHvert sæt poter smager unikt.</language>
	</row>
	<row id="narc_0616_00217" index="217">
		<attribute name="window_context_name">used</attribute>
		<language name="English">På sit territorium forlader den\nridser på træer, der bærer\nlækre bær eller frugter.</language>
	</row>
	<row id="narc_0616_00218" index="218">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens krop er lavet af magma.\nHvis den ikke bliver ved med at bevæge sig, er den\nkroppen vil afkøle og hærde.</language>
	</row>
	<row id="narc_0616_00219" index="219">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens kropstemperatur er nogenlunde\n18.000 grader F. Flammetud\nfra huller i dens hærdede skal.</language>
	</row>
	<row id="narc_0616_00220" index="220">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det elsker at spise svampe\nvokse under dødt græs. Det også\nfinder varme kilder, mens han fouragerer.</language>
	</row>
	<row id="narc_0616_00221" index="221">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens pjuskede pels gør den ude af stand\nat se. Det tjekker omgivelserne\nmed sin følsomme næse i stedet.</language>
	</row>
	<row id="narc_0616_00222" index="222">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mange bor i det rene hav\nsyd. De kan tilsyneladende ikke leve\ni forurenet vand.</language>
	</row>
	<row id="narc_0616_00223" index="223">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den klynger sig til MANTINE at fodre på\nde store Pokémons scraps. Dette er\nen tilpasning for at undgå fjender.</language>
	</row>
	<row id="narc_0616_00224" index="224">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det slører sin fjendes udsyn ved\nspytter en sky af grumset blæk.\nDen laver sin rede blandt kampesten.</language>
	</row>
	<row id="narc_0616_00225" index="225">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bærer mad sammenrullet i sin\nhale. Det har for vane at dele\nmad med mennesker tabt i bjergene.</language>
	</row>
	<row id="narc_0616_00226" index="226">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den svømmer elegant, åndssvag af\nREMORAID hænger på dens brede\nfinner. Det har en føjelig natur.</language>
	</row>
	<row id="narc_0616_00227" index="227">
		<attribute name="window_context_name">used</attribute>
		<language name="English">På trods af at den er klædt helt ind\njernhård panser, den flyver kl\nhastigheder over 180 mph.</language>
	</row>
	<row id="narc_0616_00228" index="228">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det formidler sine følelser ved hjælp af\nforskellige råb. Det virker i en pakke\nfor klogt at nedlægge bytte.</language>
	</row>
	<row id="narc_0616_00229" index="229">
		<attribute name="window_context_name">used</attribute>
		<language name="English">For længe siden forestillede folk sig\ndets uhyggelige hyl at være opkaldet\naf den grumme høster.</language>
	</row>
	<row id="narc_0616_00230" index="230">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever i huler på havbunden\nog skaber kæmpe hvirvler\nhver gang den bevæger sig.</language>
	</row>
	<row id="narc_0616_00231" index="231">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er stærk på trods af dens kompakte\nstørrelse. Den kan nemt samles op og\nbære et voksent menneske på ryggen.</language>
	</row>
	<row id="narc_0616_00232" index="232">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den angriber ved at krølle sig sammen\nrulle ind i dens fjende. Det kan blæse\nadskille et hus i ét slag.</language>
	</row>
	<row id="narc_0616_00233" index="233">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Med planetarisk udvikling\nsoftware installeret, blev det\ni stand til at arbejde i rummet.</language>
	</row>
	<row id="narc_0616_00234" index="234">
		<attribute name="window_context_name">used</attribute>
		<language name="English">At stirre på dens gevirer skaber\nen mærkelig fornemmelse, som om man var det\nbliver trukket ind i deres centre.</language>
	</row>
	<row id="narc_0616_00235" index="235">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den markerer sit territorium ved at bruge sin\nhale som en pensel. Der er\nmere end 5.000 forskellige mærker.</language>
	</row>
	<row id="narc_0616_00236" index="236">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er berømt for sin iver efter at\nkamp og plejer altid skader\nfra at udfordre større fjender.</language>
	</row>
	<row id="narc_0616_00237" index="237">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kæmper, mens den snurrer som en top.\nCentrifugalkraften forstærker dens\ndestruktiv kraft med ti.</language>
	</row>
	<row id="narc_0616_00238" index="238">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den tester alt ved berøring\nmed sine læber, som husker\nhvad den kan lide og ikke lide.</language>
	</row>
	<row id="narc_0616_00239" index="239">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den genererer elektricitet ved\nhvirvler med armene. Imidlertid er det\nkan ikke lagre den energi, den laver.</language>
	</row>
	<row id="narc_0616_00240" index="240">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens kropstemperatur er ca\n1.100 grader F. Det er sundt hvis\ndet ånder gule flammer.</language>
	</row>
	<row id="narc_0616_00241" index="241">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges, at børn, der drikker\nMILTANKs mælk vokser op til at blive\nhjertelige, sunde voksne.</language>
	</row>
	<row id="narc_0616_00242" index="242">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er en Pokémon, der leverer\nlykke. At spise sit æg siges\nat lave én slags til alle.</language>
	</row>
	<row id="narc_0616_00243" index="243">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges at være faldet med\nlyn. Den kan affyre torden\nfra regnskyerne på ryggen.</language>
	</row>
	<row id="narc_0616_00244" index="244">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges, at når det brøler, en\nvulkanen går i udbrud et sted omkring\nkloden.</language>
	</row>
	<row id="narc_0616_00245" index="245">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det ræser verden rundt til\nrense forurenet vand. Den streger\nvæk med nordenvinden.</language>
	</row>
	<row id="narc_0616_00246" index="246">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon der spiser jord. En gang det\nhar spist et stort bjerg, det\ngår i seng, så den kan vokse.</language>
	</row>
	<row id="narc_0616_00247" index="247">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens krop er så hård som grundfjeldet.\nVed at udlufte trykgas kan den\naffyre sig selv som en raket.</language>
	</row>
	<row id="narc_0616_00248" index="248">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis det hærger, vælter det\nbjerge og begraver floder. Kort\nskal tegnes om bagefter.</language>
	</row>
	<row id="narc_0616_00249" index="249">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den sover i en dybhavsgrav.\nHvis den slår med vingerne, siges den\nforårsage en 40-dages storm.</language>
	</row>
	<row id="narc_0616_00250" index="250">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens fjer er i syv farver.\nDet siges, at enhver, der ser det\nlovet evig lykke.</language>
	</row>
	<row id="narc_0616_00251" index="251">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har magten til at rejse på tværs\ntid, men det siges kun at dukke op\ni fredelige tider.</language>
	</row>
	<row id="narc_0616_00252" index="252">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens fodsåler er dækket\nved utallige bittesmå pigge, hvilket muliggør\ndet at gå på vægge og lofter.</language>
	</row>
	<row id="narc_0616_00253" index="253">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever i tætte jungler. Mens \nlukker sig om sit bytte og springer\nfra gren til gren.</language>
	</row>
	<row id="narc_0616_00254" index="254">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Bladene, der vokser på dens arme\nkan fælde tykke træer. Det er det\nuden jævnaldrende i junglekamp.</language>
	</row>
	<row id="narc_0616_00255" index="255">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ild brænder indeni, så det føles\nmeget varmt at kramme. Den starter\nildkugler på 1.800 grader F.</language>
	</row>
	<row id="narc_0616_00256" index="256">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens sparkende beherskelse slipper den løs\n10 spark i sekundet. Det udsender\nskarpe råb for at skræmme fjender.</language>
	</row>
	<row id="narc_0616_00257" index="257">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Flammer sprudler ud fra dens håndled,\nomslutter dens knoer. Dens\nslag svider dens fjender.</language>
	</row>
	<row id="narc_0616_00258" index="258">
		<attribute name="window_context_name">used</attribute>
		<language name="English">For at advare det, finnen på hovedet\nmærker vandstrømmen. Det har den\nstyrken til at løfte kampesten.</language>
	</row>
	<row id="narc_0616_00259" index="259">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens robuste ben giver den sikker\nfodfæste, selv i mudder. Det\ngraver sig ned i snavs for at sove.</language>
	</row>
	<row id="narc_0616_00260" index="260">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kan svømme, mens den trækker en stor\nskib. Det slår fjender ned med en\nsving med sine tykke arme.</language>
	</row>
	<row id="narc_0616_00261" index="261">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon med en vedvarende\nnaturen jager den sit udvalgte bytte\nindtil byttet bliver udmattet.</language>
	</row>
	<row id="narc_0616_00262" index="262">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den jager bytte i en flok.\nDen vil aldrig adlyde kommandoerne\naf en dygtig træner.</language>
	</row>
	<row id="narc_0616_00263" index="263">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den går i zigzag-form. Det er det\ngod til at finde varer i\ngræs og endda i jorden.</language>
	</row>
	<row id="narc_0616_00264" index="264">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den oplader bytte ved hastigheder over\n60 mph. Dog fordi det kan\nkun løb lige, det fejler ofte.</language>
	</row>
	<row id="narc_0616_00265" index="265">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den spytter en hvid silke, der vender sig\nklæbrig, når den kommer i kontakt med luft. Det er det\nbruges til at immobilisere fjender.</language>
	</row>
	<row id="narc_0616_00266" index="266">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den drikker dug, der samler sig på den\nsilke og venter på evolution. Dens\nhård kokon afviser angreb.</language>
	</row>
	<row id="narc_0616_00267" index="267">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når blomstermarker blomstrer, flagrer det\nrundt og samler pollen. Trods\ndens udseende, den er vild.</language>
	</row>
	<row id="narc_0616_00268" index="268">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Indkapslet i sin hårde kokon, det\ntåler angreb. Det glemmer aldrig\ndets fjenders udseende.</language>
	</row>
	<row id="narc_0616_00269" index="269">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den slår voldsomt med vingerne til\nsprede giftigt støv ved angreb.\nDen bliver aktiv efter solnedgang.</language>
	</row>
	<row id="narc_0616_00270" index="270">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det ligner en vandplante og\nfungerer som en færge til Pokémon\nder ikke kan svømme.</language>
	</row>
	<row id="narc_0616_00271" index="271">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har en drilsk ånd. Hvis det\nfår øje på en lystfisker, vil den trække på\nfiskesnøre til at forstyrre.</language>
	</row>
	<row id="narc_0616_00272" index="272">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis den hører festlig musik, er alt det\nmuskler fyldes med energi. Det kan den ikke\nhjælpe med at bryde ud i en dans.</language>
	</row>
	<row id="narc_0616_00273" index="273">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når det dingler fra et træ\ngren, det ligner bare et agern.\nDen nyder at skræmme andre Pokémon.</language>
	</row>
	<row id="narc_0616_00274" index="274">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lyden af ​​dens græsfløjte gør\ndens lyttere urolige. Den lever dybt\ni skove.</language>
	</row>
	<row id="narc_0616_00275" index="275">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ved at blafre med sin løvrige vifte kan den\npiske vindstød på 100 ft/sekund\nder kan jævne huse.</language>
	</row>
	<row id="narc_0616_00276" index="276">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har en modig ånd, der gør\ndet tager modigt imod hårde fjender. Det\nfluer på jagt efter varme klimaer.</language>
	</row>
	<row id="narc_0616_00277" index="277">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kredser om himlen på jagt efter\nbytte. Når den får øje på en, dykker den\nstejlt for at fange byttet.</language>
	</row>
	<row id="narc_0616_00278" index="278">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fanger havvinde med sin lange\nvinger, det svæver, som om det var en\nsvævefly. Den folder sine vinger for at hvile.</language>
	</row>
	<row id="narc_0616_00279" index="279">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det fungerer som en leveringsservice af\nbærer små Pokémon i sin regning.\nDet dupper på bølgerne for at hvile sig.</language>
	</row>
	<row id="narc_0616_00280" index="280">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bruger hornene på hovedet til\nfornemme menneskelige følelser. Det siges at\ndukke op foran glade mennesker.</language>
	</row>
	<row id="narc_0616_00281" index="281">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er meget sansende for sin\nTrænerens følelser. Den danser hvornår\ndet føles lykkeligt.</language>
	</row>
	<row id="narc_0616_00282" index="282">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den vil forsøge at beskytte sin betroede\nTræner med sit liv. Det har\nevne til at se fremtiden.</language>
	</row>
	<row id="narc_0616_00283" index="283">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det ser ud som om, den skøjter videre\nvand. Det trækker bytte med en sød\nduft fra spidsen af ​​hovedet.</language>
	</row>
	<row id="narc_0616_00284" index="284">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens antenner har øjenmønstre\npå dem. Dens fire vinger gør det muligt\nat svæve og flyve i alle retninger.</language>
	</row>
	<row id="narc_0616_00285" index="285">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det sprøjter giftsporer ud fra\ntoppen af ​​hovedet. Disse sporer\nforårsage smerte overalt, hvis det indåndes.</language>
	</row>
	<row id="narc_0616_00286" index="286">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens korte arme strækker sig, når den\nkaster slag. Dens teknik er\nlig med pro-boksere.</language>
	</row>
	<row id="narc_0616_00287" index="287">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bruger næsten al sin tid i en\ndagen spredte sig. Bare at se det\ngør en døsig.</language>
	</row>
	<row id="narc_0616_00288" index="288">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens hjerte slår tidoblet\ntempo, så den kan ikke sidde stille til\nendda et øjeblik.</language>
	</row>
	<row id="narc_0616_00289" index="289">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Verdens dovne Pokémon. Når\nden slapper af, den sparer faktisk\nenergi til at slå tilbage.</language>
	</row>
	<row id="narc_0616_00290" index="290">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den vokser under jorden og sanser\nsine omgivelser ved hjælp af antenner\ni stedet for dets næsten blinde øjne.</language>
	</row>
	<row id="narc_0616_00291" index="291">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fordi det bevæger sig så hurtigt, det\nnogle gange bliver usynlige. Det\nsamles omkring træsaft.</language>
	</row>
	<row id="narc_0616_00292" index="292">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En kasseret fejlskal, der kom til\nliv. Kigger ind i revnen på dens\ntilbage siges at stjæle ens ånd.</language>
	</row>
	<row id="narc_0616_00293" index="293">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Normalt er dens råb som stille\nmumler. Hvis den bliver bange, skriger den\nmed samme volumen som et jetfly.</language>
	</row>
	<row id="narc_0616_00294" index="294">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Chokbølgerne fra dens skrig kan\nvælte lastbiler. Den stempler sin\nfødder for at tænde.</language>
	</row>
	<row id="narc_0616_00295" index="295">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens hyl kan høres over seks\nmiles væk. Det udsender alt muligt\nlyde fra portene på dens krop.</language>
	</row>
	<row id="narc_0616_00296" index="296">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den hærder sin krop ved at smække\nind i tykke træer. Mange knækkede\ntræer kan findes nær dens rede.</language>
	</row>
	<row id="narc_0616_00297" index="297">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den elsker at matche power med\nstore Pokémon. Den kan banke en\nlastbil, der flyver med sine armstød.</language>
	</row>
	<row id="narc_0616_00298" index="298">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens hale er fyldt med næringsstoffer\nnødvendigt for vækst. Det spiller\nved at hoppe på halen.</language>
	</row>
	<row id="narc_0616_00299" index="299">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens næse er en magnet. Som følge heraf\ndenne Pokémon holder altid sit ansigt\npeger mod nord.</language>
	</row>
	<row id="narc_0616_00300" index="300">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kan ikke stoppe sig selv i at jagte\nflytte ting, og det kører i en\ncirkel, jagter sin egen hale.</language>
	</row>
	<row id="narc_0616_00301" index="301">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er meget populært blandt kvinder\nSneakers for sin sublime pels.\nDen holder ikke rede.</language>
	</row>
	<row id="narc_0616_00302" index="302">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den gemmer sig i hulernes mørke.\nDens kost af ædelstene har ændret sig\ndets øjne i ædelstene.</language>
	</row>
	<row id="narc_0616_00303" index="303">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fastgjort til dens hoved er en enorm\nsæt kæber dannet af horn.\nDen kan tygge gennem jernbjælker.</language>
	</row>
	<row id="narc_0616_00304" index="304">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever normalt dybt i bjergene.\nDog kan sult drive det til\nspise jernbaneskinner og biler.</language>
	</row>
	<row id="narc_0616_00305" index="305">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Til mad graver den jernmalm op. Det\nsmadrer sin stålsatte krop imod\nandre til at kæmpe om territorium.</language>
	</row>
	<row id="narc_0616_00306" index="306">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mens man søger jern til mad, er det\ngraver tunneler ved at bryde igennem\ngrundfjeldet med dets stålhorn.</language>
	</row>
	<row id="narc_0616_00307" index="307">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den går aldrig glip af sin daglige yoga\ntræning, og det øger sin\nåndelig kraft gennem meditation.</language>
	</row>
	<row id="narc_0616_00308" index="308">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gennem daglig meditation finpudses det\ndens åndelige kraft. Det kan fornemme\nhvad andre tænker.</language>
	</row>
	<row id="narc_0616_00309" index="309">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Bruger elektricitet lagret i sin pels,\ndet stimulerer sine muskler til\nøge dens reaktionshastighed.</language>
	</row>
	<row id="narc_0616_00310" index="310">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den afleder elektricitet fra sin\nmanke. Det skaber en tordensky\noverhead for at slippe lyn.</language>
	</row>
	<row id="narc_0616_00311" index="311">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den hepper på venner med pom-poms\nlavet af gnister. Det dræner strømmen\nfra telefonpæle.</language>
	</row>
	<row id="narc_0616_00312" index="312">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det hepper på vennerne. Hvis det\nvenner taber, dens krop lader det\naf flere og flere gnister.</language>
	</row>
	<row id="narc_0616_00313" index="313">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kommunikerer med andre ved\noplyser dens bagside om natten. Det\nelsker ILLUMISEs søde aroma.</language>
	</row>
	<row id="narc_0616_00314" index="314">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Med sin søde aroma vejleder den\nVOLBEAT til at tegne skilte med lys i\nnattehimlen.</language>
	</row>
	<row id="narc_0616_00315" index="315">
		<attribute name="window_context_name">used</attribute>
		<language name="English">De smukke blomster på armene\nhar giftige torne. ikke engang\ntænk på at plukke de blomster.</language>
	</row>
	<row id="narc_0616_00316" index="316">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Næsten hele dens krop er dens mave.\nDens hårde fordøjelsessaft hurtigt\nopløs alt, hvad det sluger.</language>
	</row>
	<row id="narc_0616_00317" index="317">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den sluger alt helt.\nDen sveder giftige væsker fra sin\nfollikler til at dæmpe fjender.</language>
	</row>
	<row id="narc_0616_00318" index="318">
		<attribute name="window_context_name">used</attribute>
		<language name="English">De sværmer enhver fjende, der invaderer\nderes territorium. Deres skarpe hugtænder\nkan rive bådskrog ud.</language>
	</row>
	<row id="narc_0616_00319" index="319">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens hugtænder river gennem pladejern.\nDen svømmer med 75 mph og er kendt som\n"Havets bølle."</language>
	</row>
	<row id="narc_0616_00320" index="320">
		<attribute name="window_context_name">used</attribute>
		<language name="English">På solrige dage lander den på strande\nat hoppe som en bold og spille.\nDen sprøjter vand ud af næsen.</language>
	</row>
	<row id="narc_0616_00321" index="321">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den største af alle Pokémon.\nDen kan dykke til en dybde på næsten\n10.000 fod på kun et åndedrag.</language>
	</row>
	<row id="narc_0616_00322" index="322">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens puklede ryg gemmer sig intenst\nvarm magma. I regn, magma\nafkøles og bremser dens bevægelse.</language>
	</row>
	<row id="narc_0616_00323" index="323">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den har vulkaner på ryggen. Hvis\nmagma opbygges i dens krop, den\ngyser og bryder derefter voldsomt ud.</language>
	</row>
	<row id="narc_0616_00324" index="324">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den brænder kul inde i sin skal for\nenergi. Det blæser sort sod ud, hvis\nden er truet.</language>
	</row>
	<row id="narc_0616_00325" index="325">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den hopper konstant og bruger sin\nhalen som en fjeder. Chokket af\nhoppende holder sit hjerte bankende.</language>
	</row>
	<row id="narc_0616_00326" index="326">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bruger sorte perler til at forstærke den\npsyko-kraft. Det gør noget mærkeligt\ndans for at få kontrol over fjender.</language>
	</row>
	<row id="narc_0616_00327" index="327">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ikke to SPINDA har ens\nmønster af pletter. Den vakler\ntrin forsømmer fjendernes mål.</language>
	</row>
	<row id="narc_0616_00328" index="328">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det laver en konisk hul i ørkenen\nsand og ligger på lur i bunden\nfor at byttet kommer væltende ned.</language>
	</row>
	<row id="narc_0616_00329" index="329">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den gyser voldsomt sine vinger,\ngenerere ultralydsbølger til\nfremkalde hovedpine hos mennesker.</language>
	</row>
	<row id="narc_0616_00330" index="330">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det pisker sandstorme op med\nkraftige klap af dens vinger. Det er det\nkendt som "Ørkenånden".</language>
	</row>
	<row id="narc_0616_00331" index="331">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ved at lagre vand i sin krop, dette\nørkenboer kan overleve i 30\ndage uden vand.</language>
	</row>
	<row id="narc_0616_00332" index="332">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bliver aktiv om natten,\nsøger bytte, der er udmattet\nfra dagens ørkenvarme.</language>
	</row>
	<row id="narc_0616_00333" index="333">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens vinger er som bomuldsduner.\nHvis det sætter sig på nogens hoved,\ndet ligner en bomuldshat.</language>
	</row>
	<row id="narc_0616_00334" index="334">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det ligner en fluffy sky når\nden er under flugt. Den nynner med sin\nsopran stemme.</language>
	</row>
	<row id="narc_0616_00335" index="335">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det har skændtes med SEVIPER for\nmange generationer. Dens skarpe kløer\ner dens største våben.</language>
	</row>
	<row id="narc_0616_00336" index="336">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I mange generationer har den gjort det\nfejdede med ZANGOOSE. Det skærper sin\nbladet hale på sten til kamp.</language>
	</row>
	<row id="narc_0616_00337" index="337">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fordi den bliver aktiv om natten\naf fuldmånen, siges den at have\nnogle links til månefaserne.</language>
	</row>
	<row id="narc_0616_00338" index="338">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Rygter om en ny Pokémon-art\nat være fra solen. Det giver sig\nlys, mens du spinder.</language>
	</row>
	<row id="narc_0616_00339" index="339">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens knurhår udgør en fremragende radar.\nDe bruges til at lokalisere bytte,\nselv i det mørkeste vand.</language>
	</row>
	<row id="narc_0616_00340" index="340">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Som følge af at forårsage rystelser ved\ntæske om, det udviklede den\nevnen til at forudsige rigtige jordskælv.</language>
	</row>
	<row id="narc_0616_00341" index="341">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens hårdføre vitalitet gør det muligt\ntilpasse sig ethvert miljø. Dens\ntang vil aldrig frigive bytte.</language>
	</row>
	<row id="narc_0616_00342" index="342">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er en bølle, der bruger sin\ntang til at tage op og smide ud\nandre Pokémon fra dens dam.</language>
	</row>
	<row id="narc_0616_00343" index="343">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bevæger sig ved at snurre på foden.\nDet er en sjælden Pokémon, der var\nopdaget i gamle ruiner.</language>
	</row>
	<row id="narc_0616_00344" index="344">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En gammel lerfigur, der kom\ntil livet som Pokémon fra eksponering\ntil en mystisk lysstråle.</language>
	</row>
	<row id="narc_0616_00345" index="345">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den boede på havbunden 100\nmillioner år siden og var\ngenoplivet videnskabeligt.</language>
	</row>
	<row id="narc_0616_00346" index="346">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever i det lave vand\nhavene. Når tidevandet går ud, det\ngraver bytte op fra strande.</language>
	</row>
	<row id="narc_0616_00347" index="347">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det var en Pokémon-forfader\ngenoplivet fra et fossil. Den levede\ni havet og jaget med kløer.</language>
	</row>
	<row id="narc_0616_00348" index="348">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den gik i land efter at have udviklet sig.\nHele dens krop er beklædt med en robust\nrustning.</language>
	</row>
	<row id="narc_0616_00349" index="349">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den spiser hvad som helst, så den kan endda\nlever i forurenede vandløb og søer.\nIngen lægger mærke til det.</language>
	</row>
	<row id="narc_0616_00350" index="350">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er verdens smukkeste\nPokémon. Der er mange værker af\nkunst med MILOTIC.</language>
	</row>
	<row id="narc_0616_00351" index="351">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens udseende ændres med\nvejr. For nylig dens molekyler\nviste sig at være ligesom vand.</language>
	</row>
	<row id="narc_0616_00352" index="352">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kan frit ændre sin krops\nfarve. Det zigzag mønster på dens\nmaven ændrer sig dog ikke.</language>
	</row>
	<row id="narc_0616_00353" index="353">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den elsker hævngerrige følelser og\nhænger i rækker under udhænget af\nhuse, hvor der bor hævngerrige mennesker.</language>
	</row>
	<row id="narc_0616_00354" index="354">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En dukke, der blev en Pokémon over\ndets nag fra at blive smidt. Det\nsøger barnet, der fornægtede det.</language>
	</row>
	<row id="narc_0616_00355" index="355">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den forfølger stædigt sit bytte\nhvor end det går. Imidlertid\njagten er opgivet ved solopgang.</language>
	</row>
	<row id="narc_0616_00356" index="356">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens krop er hul. Det siges det\ndem, der ser ind i dens krop er\nsuget ind i tomrummet.</language>
	</row>
	<row id="narc_0616_00357" index="357">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fordi det hele tiden kun spiste\ndens yndlingsfrugt, frugten\nbegyndte at vokse om halsen.</language>
	</row>
	<row id="narc_0616_00358" index="358">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Udsender ultralydsråb, det\nflyder på vinden for at rejse fantastisk\nafstande.</language>
	</row>
	<row id="narc_0616_00359" index="359">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den fornemmer kommende katastrofer og\nvises kun for folk til\nadvare dem om forestående fare.</language>
	</row>
	<row id="narc_0616_00360" index="360">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den vokser sig stærk ved at skubbe op\nmod andre i massevis.\nDen elsker at spise sød frugt.</language>
	</row>
	<row id="narc_0616_00361" index="361">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I snelandet, bestemt\nfolklore siger, at et hus vil\ntrives, hvis der bor en SNORUNT.</language>
	</row>
	<row id="narc_0616_00362" index="362">
		<attribute name="window_context_name">used</attribute>
		<language name="English">For at beskytte sig selv beklæder den sin\nkrop i en rustning af is, lavet\nved at fryse fugt i luften.</language>
	</row>
	<row id="narc_0616_00363" index="363">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den ruller hen over isflager for at nå\nkysten, fordi dens krop er dårlig\nformet til svømning.</language>
	</row>
	<row id="narc_0616_00364" index="364">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det plejer at dreje tingene på sig\nnæse. Ved at gøre det lærer den\nteksturer og lugte.</language>
	</row>
	<row id="narc_0616_00365" index="365">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den knuser is med sine store stødtænder.\nDens tykke spæk afviser ikke kun\nkulden, men også fjendtlige angreb.</language>
	</row>
	<row id="narc_0616_00366" index="366">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det laver en enkelt perle under\ndens levetid. Perlen siges\nat forstærke psykisk kraft.</language>
	</row>
	<row id="narc_0616_00367" index="367">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever dybt i havet. med en\nhale formet som en lille fisk, det\ntiltrækker intetanende bytte.</language>
	</row>
	<row id="narc_0616_00368" index="368">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever på bunden af ​​havet.\nOm foråret, dens lyserøde krop\nbliver mere levende af en eller anden grund.</language>
	</row>
	<row id="narc_0616_00369" index="369">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En sjælden Pokémon opdaget under\nen dybhavsudforskning. Det har den ikke\nændret på over 100 millioner år.</language>
	</row>
	<row id="narc_0616_00370" index="370">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever i varme hav. Det siges\nat et par finder denne Pokémon\nvil blive velsignet med evig kærlighed.</language>
	</row>
	<row id="narc_0616_00371" index="371">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Drømmer om en dag at flyve, det\nøver sig ved at springe ud fra klipper\nhver dag.</language>
	</row>
	<row id="narc_0616_00372" index="372">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Inden for dens robuste skal, dens celler\ner begyndt at ændre sig. Skallen\nskræller af i det øjeblik det udvikler sig.</language>
	</row>
	<row id="narc_0616_00373" index="373">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Som et resultat af sin langvarige drøm\nflyvning, dens cellulære struktur\nændret sig, og vinger voksede ud.</language>
	</row>
	<row id="narc_0616_00374" index="374">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den taler med andre ved at bruge\nmagnetiske impulser. I en sværm, de\nbevæge sig i perfekt harmoni.</language>
	</row>
	<row id="narc_0616_00375" index="375">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er dannet ved, at to BELDUM går sammen\nsammen. Dens stålkrop bliver det ikke\nridset, hvis den støder sammen med en stråle.</language>
	</row>
	<row id="narc_0616_00376" index="376">
		<attribute name="window_context_name">used</attribute>
		<language name="English">METANG kombineret for at danne det.\nMed fire hjerner har den\nintelligens af en supercomputer.</language>
	</row>
	<row id="narc_0616_00377" index="377">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hele dens krop er lavet af sten.\nHvis nogen del afbrydes i kamp, ​​er det\nfastgør sten for at reparere sig selv.</language>
	</row>
	<row id="narc_0616_00378" index="378">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens krop er lavet af is fra\nistid. Det styrer den kolde luft af\n-328 grader Fahrenheit.</language>
	</row>
	<row id="narc_0616_00379" index="379">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Tempereret af tryk under jorden\nover titusinder af år,\ndens krop kan ikke ridses.</language>
	</row>
	<row id="narc_0616_00380" index="380">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens krop er dækket af en dun\nder kan bryde lys i sådan en\nmåde at det bliver usynligt.</language>
	</row>
	<row id="narc_0616_00381" index="381">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En yderst intelligent Pokémon.\nVed at folde sine vinger tilbage under flugten,\nden kan overhale jetfly.</language>
	</row>
	<row id="narc_0616_00382" index="382">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges at have udvidet\nhave ved at forårsage regnskyl. Det havde den\nligget i søvn i en skyttegrav.</language>
	</row>
	<row id="narc_0616_00383" index="383">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den havde sovet i undergrunden\nmagma lige siden det voldsomt\nkæmpede KYOGRE for længe siden.</language>
	</row>
	<row id="narc_0616_00384" index="384">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever langt i ozonlaget\nover skyerne og kan ikke være\nset fra jorden.</language>
	</row>
	<row id="narc_0616_00385" index="385">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges at have evnen til\nimødekomme ethvert ønske for kun en uge\nhvert tusinde år.</language>
	</row>
	<row id="narc_0616_00386" index="386">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En fremmed virus, der faldt til jorden\npå en meteor gennemgik et DNA\nmutation til at blive denne Pokémon.</language>
	</row>
	<row id="narc_0616_00387" index="387">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den foretager fotosyntese med\nsin krop, der laver ilt. Bladet\npå hovedet visner, hvis den er tørstig.</language>
	</row>
	<row id="narc_0616_00388" index="388">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Skallen er hærdet jord. Nogle\nPokémon kommer for at hakke bærrene\nvokser på træerne på ryggen.</language>
	</row>
	<row id="narc_0616_00389" index="389">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Grupper af denne Pokémon migrerer\npå jagt efter vand har været\nforveksles med "flytte skove".</language>
	</row>
	<row id="narc_0616_00390" index="390">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens brændende bagende er drevet af\ngas lavet i maven. Selv regn\nkan ikke slukke ilden.</language>
	</row>
	<row id="narc_0616_00391" index="391">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det bruger lofter og vægge til\niværksætte luftangreb. Den er brændende\nhalen er kun ét våben.</language>
	</row>
	<row id="narc_0616_00392" index="392">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens ildkrone er tegn på\ndens brændende natur. Den er slået af\ningen med hensyn til hurtighed.</language>
	</row>
	<row id="narc_0616_00393" index="393">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever langs kyster i det nordlige\nlande. En dygtig svømmer, det\ndykker i over 10 minutter for at jage.</language>
	</row>
	<row id="narc_0616_00394" index="394">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens vinger leverer onde slag\nsnap selv de tykkeste træer.\nDen leder efter bytte i iskolde hav.</language>
	</row>
	<row id="narc_0616_00395" index="395">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den svømmer lige så hurtigt som en jetbåd.\nKanterne på dens vinger er skarpe\nog kan skære drivis fra hinanden.</language>
	</row>
	<row id="narc_0616_00396" index="396">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Normalt med en stor flok, er det\nknap mærkbar, når den er alene.\nDens råb er meget voldsomme.</language>
	</row>
	<row id="narc_0616_00397" index="397">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever i skove og marker.\nDer opstår skænderier om territorium\nnår flokke støder sammen.</language>
	</row>
	<row id="narc_0616_00398" index="398">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Musklerne i dens vinger og ben\ner stærke. Den kan sagtens flyve mens\ngriber en lille Pokémon.</language>
	</row>
	<row id="narc_0616_00399" index="399">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den gnaver hele tiden i kævler og\nsten for at skære ned på dens forside\ntænder. Den lægger rede ved siden af ​​vand.</language>
	</row>
	<row id="narc_0616_00400" index="400">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mens dens bevægelser ud af vandet\ner træge, kan den svømme lige så hurtigt\nsom enhver FEEBAS.</language>
	</row>
	<row id="narc_0616_00401" index="401">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den chatter med andre ved hjælp af\nlyde fra dens kolliderende antenner.\nDisse lyde er efterårets kendetegn.</language>
	</row>
	<row id="narc_0616_00402" index="402">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det signalerer sine følelser med sine\nmelodier. Forskere studerer\ndisse melodiske mønstre.</language>
	</row>
	<row id="narc_0616_00403" index="403">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens forben har en muskel-baseret\nsystem til at generere elektricitet.\nDens krop skinner, hvis den er truet.</language>
	</row>
	<row id="narc_0616_00404" index="404">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den hviler forbenene på andre til\nkommunikere med rytmisk elektrisk\npulser fra dens kløer.</language>
	</row>
	<row id="narc_0616_00405" index="405">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når dens øjne skinner guld, kan den\nplet skjuler bytte - selv dem\nsøge ly bag en mur.</language>
	</row>
	<row id="narc_0616_00406" index="406">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever ved siden af ​​klare damme.\nDet spreder pollen, der fremkalder\nhårde nysen og løbende næser.</language>
	</row>
	<row id="narc_0616_00407" index="407">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Med en danseres bevægelser,\ndet slår med piske, der er\ntæt beklædt med gifttorne.</language>
	</row>
	<row id="narc_0616_00408" index="408">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den blev genopstået fra et jern\nkuglelignende fossil. Det nedsætter bytte med\ndens hovedrumper.</language>
	</row>
	<row id="narc_0616_00409" index="409">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens kranium er hård som jern. Det er det\nen dyr, der river junglen ned\ntræer, mens de fanger bytte.</language>
	</row>
	<row id="narc_0616_00410" index="410">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det plejer at polere sit ansigt ved\ngnider den mod træstammer. Det\ner svag for angreb bagfra.</language>
	</row>
	<row id="narc_0616_00411" index="411">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når de bliver angrebet, danner de en mur\nmed deres skjoldagtige ansigter til\nbeskytte deres unge.</language>
	</row>
	<row id="narc_0616_00412" index="412">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis dens kappe er brudt i kamp,\ndet laver hurtigt kappen om med\nmaterialer i nærheden.</language>
	</row>
	<row id="narc_0616_00413" index="413">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens udseende ændrer sig afhængigt af\nhvor det udviklede sig. Materialerne\npå hånden blive en del af dens krop.</language>
	</row>
	<row id="narc_0616_00414" index="414">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den holder ikke rede. Den flyver\nover marker og bjerge i\nkonstant søgen efter blomsterhonning.</language>
	</row>
	<row id="narc_0616_00415" index="415">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den samler og leverer honning til\ndens koloni. Om natten klumper de sig\nat danne en bikube og sove.</language>
	</row>
	<row id="narc_0616_00416" index="416">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når truet, larver fra sin\nseks-cellet honeycomb slår tilbage.\nDer er kun én i en koloni. </language>
	</row>
	<row id="narc_0616_00417" index="417">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den laver strøm med poser\ni kinderne og skyder ladninger\nfra dens hale. Den lever på toppen af ​​træer.</language>
	</row>
	<row id="narc_0616_00418" index="418">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den svømmer ved at dreje sine to haler\nsom en skrue. Når den dykker, er den\nflydepose kollapser.</language>
	</row>
	<row id="narc_0616_00419" index="419">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens flydepose udviklede sig som en\nresultat af at forfølge akvatiske byttedyr.\nDen kan fungere som en gummiflåde.</language>
	</row>
	<row id="narc_0616_00420" index="420">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sollys farver det rødt. Når\nlille kugle er drænet for næringsstoffer,\ndet svinder ind for at varsle evolution.</language>
	</row>
	<row id="narc_0616_00421" index="421">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er føjelig som en knop, men vender sig\nmunter, når den blomstrer. Den folder\ntilbage i en knop, hvis sollys aftager.</language>
	</row>
	<row id="narc_0616_00422" index="422">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever langs vandområder.\nDens kropsform er ændret til\npasser til dens levested.</language>
	</row>
	<row id="narc_0616_00423" index="423">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den havde åbenbart en kæmpe skal til\nbeskyttelse i oldtiden.\nDen lever i lavvandede tidevandsbassiner.</language>
	</row>
	<row id="narc_0616_00424" index="424">
		<attribute name="window_context_name">used</attribute>
		<language name="English">De arbejder i store kolonier og\nlave ringe ved at sammenkæde deres\nhaler, tilsyneladende i venskab.</language>
	</row>
	<row id="narc_0616_00425" index="425">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det trækker i hænderne på børn\nat stjæle dem væk. Imidlertid er det\nbliver trukket rundt i stedet.</language>
	</row>
	<row id="narc_0616_00426" index="426">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bærer mennesker og Pokémon\nnår den flyver. Men da det kun\ndriver, kan det ende hvor som helst.</language>
	</row>
	<row id="narc_0616_00427" index="427">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når den mærker fare, bliver den frisk\ndens ører. På kolde nætter sover den\nmed hovedet stukket ind i pelsen.</language>
	</row>
	<row id="narc_0616_00428" index="428">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den er meget bevidst om sit udseende\nog undlader aldrig at pleje sine ører.\nDen kører med sprælske spring.</language>
	</row>
	<row id="narc_0616_00429" index="429">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den råber besværgelser. Mens de\nnormalt plage mål, nogle\nsang bringer lykke.</language>
	</row>
	<row id="narc_0616_00430" index="430">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det gør sine MURKROW kammerater\nbringe den mad. Den går sin tid i tomgang\nvæk og soignerer sig selv i sin rede.</language>
	</row>
	<row id="narc_0616_00431" index="431">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Med sit skarpe genskin sætter den\nfjender i en mild hypnotisk tilstand.\nDet er en meget omskiftelig Pokémon.</language>
	</row>
	<row id="narc_0616_00432" index="432">
		<attribute name="window_context_name">used</attribute>
		<language name="English">At få sig selv til at fremstå skræmmende\nkødfuld, den spænder tæt om taljen\nmed sine tvillingehaler.</language>
	</row>
	<row id="narc_0616_00433" index="433">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hver gang den hopper, laver den en\nringende lyd. Det overdøver fjender\nudsender højfrekvente skrig.</language>
	</row>
	<row id="narc_0616_00434" index="434">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det sprøjter en næse-krøller,\nstinkende væske fra dens bagside til\nafvise angribere.</language>
	</row>
	<row id="narc_0616_00435" index="435">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den sprøjter en stinkende væske fra dens\nhale. Væsken lugter værre\nlængere får den lov til at feste.</language>
	</row>
	<row id="narc_0616_00436" index="436">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der blev taget røntgenbilleder for at kontrollere\ndens kropsstruktur. Intet\ndukkede dog op.</language>
	</row>
	<row id="narc_0616_00437" index="437">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det kan fremkalde regnskyer.\nFolk for længe siden ærede det som\nbringer rigelig høst.</language>
	</row>
	<row id="narc_0616_00438" index="438">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den foretrækker tørre omgivelser. Det\nlækker vand fra øjnene til\njustere kroppens væskeniveauer.</language>
	</row>
	<row id="narc_0616_00439" index="439">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det kan lide steder, hvor mennesker\nsamle. Det efterligner fjender til at forvirre\ndem, og derefter tager sin flugt.</language>
	</row>
	<row id="narc_0616_00440" index="440">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bærer en rund, ægformet\nrock i sin mavepose og giver\nklippen til sine venner.</language>
	</row>
	<row id="narc_0616_00441" index="441">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den holder rytmen ved at svirpe med den\nhalefjer som en metronom.\nDet efterligner menneskelig tale.</language>
	</row>
	<row id="narc_0616_00442" index="442">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det var bundet til en sprække i en\nulige slutsten som straf for\nugerninger for 500 år siden.</language>
	</row>
	<row id="narc_0616_00443" index="443">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den levede engang i troperne. Til\nundgå kulden, den lever i huler\nopvarmet af jordvarme.</language>
	</row>
	<row id="narc_0616_00444" index="444">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det plejer at grave op og hamstre\nædelstene i sin rede. Dens bytte er\nkonstant målrettet af tyve.</language>
	</row>
	<row id="narc_0616_00445" index="445">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den flyver med hastigheder svarende til et jetfly\nkampfly. Det tillader det aldrig\nbytte for at undslippe.</language>
	</row>
	<row id="narc_0616_00446" index="446">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den gemmer mad under sin lange krop\nhår. Den glemmer dog, at den har\ngemte maden.</language>
	</row>
	<row id="narc_0616_00447" index="447">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens krop er smidig, men alligevel kraftfuld.\nDen kan toppe tre bjerge og\nkrydse to kløfter på en nat.</language>
	</row>
	<row id="narc_0616_00448" index="448">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ved at fange auraen, der udstråler\nfra andre, kan den læse deres\ntanker og bevægelser.    </language>
	</row>
	<row id="narc_0616_00449" index="449">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den indhyller sig med sand til\nbeskytte sig mod bakterier.\nDen nyder ikke at blive våd.</language>
	</row>
	<row id="narc_0616_00450" index="450">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens enorme mund er næsten syv\nfødder på tværs. Den har kraft nok\nat knuse en bil fuldstændigt.</language>
	</row>
	<row id="narc_0616_00451" index="451">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den lever i tørre lande. Den begraver\nsig i sand og ligger og venter på\nintetanende bytte.</language>
	</row>
	<row id="narc_0616_00452" index="452">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens krop er indkapslet i en robust\nskal. Dens hoved drejer 180\ngrader, hvilket eliminerer blinde pletter.</language>
	</row>
	<row id="narc_0616_00453" index="453">
		<attribute name="window_context_name">used</attribute>
		<language name="English">At puste sine giftsække op, det\nlaver en uhyggelig buldrende lyd\nfor intimidering.</language>
	</row>
	<row id="narc_0616_00454" index="454">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Toksinen lavet i dets giftsække\npumpes til knoklørne\ngennem rør ned ad dens arme.</language>
	</row>
	<row id="narc_0616_00455" index="455">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hængende fra grene ved hjælp af sin\ntentakler, det ligner en plante.\nDen venter på bytte med åben mund.</language>
	</row>
	<row id="narc_0616_00456" index="456">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Måden dens to halefinner flagrer på\nmens den svømmer har fortjent det\nkaldenavnet "HAVETS SMUKKE".</language>
	</row>
	<row id="narc_0616_00457" index="457">
		<attribute name="window_context_name">used</attribute>
		<language name="English">For at undgå opdagelse af rovdyr,\nden kravler langs havbunden vha\nde to finner på brystet.</language>
	</row>
	<row id="narc_0616_00458" index="458">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Forskere opdagede, at\nmarkante mønstre på ryggen\nafvige fra region til region.</language>
	</row>
	<row id="narc_0616_00459" index="459">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Om foråret vokser den bær\nmed konsistensen af ​​frosne godbidder\nomkring dens mave.</language>
	</row>
	<row id="narc_0616_00460" index="460">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det dækker brede områder i sne ved\npiske snestorme op. Det er det også\nkendt som "Ismonsteret".</language>
	</row>
	<row id="narc_0616_00461" index="461">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det sender signaler til andre ved\nudskæring af ulige mønstre i frost-\ndækkede træer og is.</language>
	</row>
	<row id="narc_0616_00462" index="462">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det udviklede sig fra eksponering til en\nsærligt magnetfelt.\nTre enheder genererer magnetisme.</language>
	</row>
	<row id="narc_0616_00463" index="463">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den omslutter ting med sin strækbar\ntunge. At komme for tæt på det\nvil efterlade dig gennemblødt af savlen.</language>
	</row>
	<row id="narc_0616_00464" index="464">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den sætter sten i huller i sine håndflader\nog bruger sine muskler til at skyde dem.\nGEODUDE bliver skudt på sjældne tidspunkter.</language>
	</row>
	<row id="narc_0616_00465" index="465">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den fanger bytte ved at strække sig ud\narme lavet af vinstokke. At miste armene til\nrovdyr generer det ikke.</language>
	</row>
	<row id="narc_0616_00466" index="466">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den skubber spidserne af sine to haler\nmod fjenden, så slipper han løs\nmed over 20.000 volt strøm.</language>
	</row>
	<row id="narc_0616_00467" index="467">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den sprænger ildkugler på over 3.600\ngrader F fra enderne af dens\nvåben. Den lever i vulkanske kratere.</language>
	</row>
	<row id="narc_0616_00468" index="468">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det vil aldrig dukke op, hvor der\ner stridigheder. Dens observationer har\nblevet sjælden for nylig.</language>
	</row>
	<row id="narc_0616_00469" index="469">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ved at kværne sine vinger skaber den\nchokbølger, der påfører kritiske\nindre skader på fjender.</language>
	</row>
	<row id="narc_0616_00470" index="470">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ligesom en plante bruger den\nfotosyntese. Som et resultat er det\naltid indhyllet i klar luft.</language>
	</row>
	<row id="narc_0616_00471" index="471">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Som en beskyttelsesteknik kan den\nhelt fryse sin pels til at lave\ndens hår står som nåle.</language>
	</row>
	<row id="narc_0616_00472" index="472">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den observerer bytte, mens den hænger\nomvendt fra grene. Når\nchancen byder sig, den suser!</language>
	</row>
	<row id="narc_0616_00473" index="473">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens imponerende stødtænder er lavet af\nis. Befolkningen tyndede ud, da den\nblev varm efter istiden.</language>
	</row>
	<row id="narc_0616_00474" index="474">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Yderligere software blev installeret\nfor at gøre det til en bedre Pokémon.\nDet begyndte dog at opføre sig mærkeligt.</language>
	</row>
	<row id="narc_0616_00475" index="475">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En mester i høflighed og\nsværdkæmpelse, det kæmper ved hjælp af\nstrækker sværd på albuerne.</language>
	</row>
	<row id="narc_0616_00476" index="476">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det udstråler stærk magnetisme fra\nover det hele. Den styrer tre små\nenheder kaldet Mini-Noses.</language>
	</row>
	<row id="narc_0616_00477" index="477">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Antennen på hovedet fanger\nradiobølger fra åndernes verden\nder befaler det at tage folk derhen.</language>
	</row>
	<row id="narc_0616_00478" index="478">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det fryser fjender med en iskold ånde\nnæsten -60 grader F. Hvad synes\nat være dens krop er faktisk hul.</language>
	</row>
	<row id="narc_0616_00479" index="479">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dens krop består af plasma. Det\ner kendt for at infiltrere elektronisk\nenheder og skabe kaos.</language>
	</row>
	<row id="narc_0616_00480" index="480">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges, at dens fremkomst\ngav mennesker intelligensen til\nforbedre deres livskvalitet.</language>
	</row>
	<row id="narc_0616_00481" index="481">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den sover på bunden af ​​en sø.\nDens ånd siges at forlade sin krop\nat flyve på søens overflade.</language>
	</row>
	<row id="narc_0616_00482" index="482">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det menes, at UXIE, MESPRIT\nog AZELF kom alle fra det samme\næg.</language>
	</row>
	<row id="narc_0616_00483" index="483">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon, der omtales i legenden.\nDet siges, at tiden begyndte at bevæge sig\nda DIALGA blev født.</language>
	</row>
	<row id="narc_0616_00484" index="484">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det siges at leve i et hul i\nrumlig dimension parallel med vores.\nDet optræder i mytologien.</language>
	</row>
	<row id="narc_0616_00485" index="485">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bor i vulkanske huler. Det\ngraver sig ind med sine korsformede fødder\nat kravle på lofter og vægge.</language>
	</row>
	<row id="narc_0616_00486" index="486">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er der en varig legende\noplyser denne slæbte Pokémon\nkontinenter med reb.</language>
	</row>
	<row id="narc_0616_00487" index="487">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon, der siges at leve i en\nverden på bagsiden af ​​vores.\nDet optræder på en gammel kirkegård.</language>
	</row>
	<row id="narc_0616_00488" index="488">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Skinnende partikler frigives fra\ndens vinger som et slør. Det siges\nat repræsentere halvmånen.</language>
	</row>
	<row id="narc_0616_00489" index="489">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En Pokémon, der lever i varme hav.\nDet puster flydeposen op på sin\nhovedet til at drive og søge efter mad.</language>
	</row>
	<row id="narc_0616_00490" index="490">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vand udgør 80% af dens krop.\nDenne Pokémon er let påvirket af\ndets miljø.</language>
	</row>
	<row id="narc_0616_00491" index="491">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Folklore siger, at på måneløs\nnætter, vil denne Pokémon lave\nfolk ser forfærdelige mareridt.</language>
	</row>
	<row id="narc_0616_00492" index="492">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det kan opløse toksiner i luften\nfor øjeblikkeligt at omdanne ødelagt land\nind i en frodig mark af blomster.</language>
	</row>
	<row id="narc_0616_00493" index="493">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det fortælles i mytologien, at dette\nPokémon blev født før\nuniverset eksisterede endda.</language>
	</row>
</body>