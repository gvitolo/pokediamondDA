	<row id="narc_0191_00030" index="30">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 1, 0} skilte sig ikke ret meget ud...\r</language>
	</row>
	<row id="narc_0191_00031" index="31">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 1, 0} fangede lidt opmærksomhed.\r</language>
	</row>
	<row id="narc_0191_00032" index="32">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 1, 0} tiltrak\n ordentlig opmærksomhed.\r</language>
	</row>
	<row id="narc_0191_00033" index="33">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 1, 0} vakte stor opmærksomhed!\r</language>
	</row>
	<row id="narc_0191_00034" index="34">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 1, 0} tiltrak\ntotal opmærksomhed!\r</language>
	</row>
	<row id="narc_0191_00035" index="35">
		<attribute name="window_context_name">used</attribute>
		<language name="English">OK! Det er tid til\nskuespilkonkurrencen!\rVis de moves, der\neksemplerer nuttet!\rFire forestillinger hver!\nLad os se lidt entusiasme!\r</language>
	</row>
	<row id="narc_0191_00036" index="36">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English"></language>
		<language name="日本語">XXXX</language>
	</row>
	<row id="narc_0191_00037" index="37">
		<attribute name="window_context_name">used</attribute>
		<language name="English">OK! Det er tid til\nskuespilkonkurrencen!\rVis de træk, der\neksemplerer smarthed!\rFire præstationer hver!\nLad os se lidt entusiasme!\r</language>
	</row>
	<row id="narc_0191_00038" index="38">
		<attribute name="window_context_name">used</attribute>
		<language name="English">OK! Det er tid til\nskuespilkonkurrencen!\rVis de træk, der\neksempler på hårdhed!\rFire præstationer hver!\nLad os se lidt entusiasme!\r</language>
	</row>
	<row id="narc_0191_00039" index="39">
		<attribute name="window_context_name">used</attribute>
		<language name="English">OK! Det er tid til\nskuespilkonkurrencen!\rVis de moves, der\neksemplerer skønhed!\rFire forestillinger hver!\nLad os se lidt entusiasme!\r</language>
	</row>
	<row id="narc_0191_00040" index="40">
		<attribute name="window_context_name">used</attribute>
		<language name="English">OK! Det er tid til\nskuespilkonkurrencen!\rVis de moves, der\neksemplerer coolness!\rFire præstationer hver!\nLad os se lidt entusiasme!\r</language>
	</row>
