<?xml version="1.0"?>
<body language="English">
	<row id="narc_0191_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vælg den dommer, du vil bedømme træk.</language>
	</row>
	<row id="narc_0191_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ydelse {COLOR 1}nr. {STRVAR_1 50, 0}{COLOR 0}!\nHvilket træk er dit valg?</language>
	</row>
	<row id="narc_0191_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er den {COLOR 1}sidste {COLOR 0}forestilling!\nVælg dit træk!</language>
	</row>
	<row id="narc_0191_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Til {STRVAR_1 3, 1}, {STRVAR_1 1, 0}\nudført {STRVAR_1 6, 2}!\r</language>
	</row>
	<row id="narc_0191_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh nej! Nogen har allerede optrådt for den dommer!\r</language>
	</row>
	<row id="narc_0191_00005" index="5">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English"></language>
		<language name="日本語">XXXX</language>
	</row>
	<row id="narc_0191_00006" index="6">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} var stærkt\nimponeret over skuespillet af\r{STRVAR_1 1, 1} og\n{STRVAR_1 1, 2}! {COLOR 1}+2{COLOR 0}!\r</language>
	</row>
	<row id="narc_0191_00007" index="7">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} var imponeret\n over præstationerne af\r{STRVAR_1 1, 1}, {STRVAR_1 1, 2},\nog {STRVAR_1 1, 3}! {COLOR 1}+1{COLOR 0}!\r</language>
	</row>
	<row id="narc_0191_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Alle optrådte for\n{STRVAR_1 3, 0}...\rOg udvandede\ndommerens indtryk.\r</language>
	</row>
	<row id="narc_0191_00009" index="9">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} var meget\n imponeret over {STRVAR_1 1, 1}s præstation! {COLOR 1}+3{COLOR 0}!\r</language>
	</row>
	<row id="narc_0191_00010" index="10">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English"></language>
		<language name="日本語">XXXX</language>
	</row>
	<row id="narc_0191_00011" index="11">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Efter at have set Cool-bevægelsen\nudført, steg {STRVAR_1 3, 0}s\fspænding!\r</language>
	</row>
	<row id="narc_0191_00012" index="12">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Efter at have set Beauty-bevægelsen\n udført, steg {STRVAR_1 3, 0}s\fspænding!\r</language>
	</row>
	<row id="narc_0191_00013" index="13">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Da {STRVAR_1 3, 0}s\fspændingen så den søde bevægelse udføres, steg\r!</language>
	</row>
	<row id="narc_0191_00014" index="14">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Da {STRVAR_1 3, 0}s\fspændingen så den smarte bevægelse udføres, steg\r!</language>
	</row>
	<row id="narc_0191_00015" index="15">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Efter at have set det hårde træk\nudført, steg {STRVAR_1 3, 0}s\fspænding!\r</language>
	</row>
