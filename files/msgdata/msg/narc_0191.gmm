	<row id="narc_0191_00068" index="68">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I næste sving optræder de\nmest scorende deltagere først.\r</language>
	</row>
	<row id="narc_0191_00069" index="69">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er det! Præstationsbedømmelsen er nu slut!\r</language>
	</row>
	<row id="narc_0191_00070" index="70">
		<attribute name="window_context_name">garbage</attribute>
