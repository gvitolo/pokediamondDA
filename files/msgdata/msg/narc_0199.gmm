	<row id="narc_0199_00120" index="120">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Godmorgen!\nVelkommen til Pokémon Center.\rVi genopretter din trætte Pokémon\ntil fuld sundhed.\rVil du hvile din Pokémon?</language>
	</row>
	<row id="narc_0199_00121" index="121">
