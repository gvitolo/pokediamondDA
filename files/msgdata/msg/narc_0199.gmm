	</row>
	<row id="narc_0199_00082" index="82">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg er meget ked af det.\rVi arbejder under jorden lige nu.\nDet er forbudt for offentligheden.\rPrøv venligst senere.</language>
	</row>
	<row id="narc_0199_00083" index="83">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Digital Watch{COLOR 0}-appen viser\ndet aktuelle klokkeslæt.\r</language>
	</row>
	<row id="narc_0199_00084" index="84">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Lommeregner{COLOR 0}-appen kan håndtere\nberegninger op til ti cifre.\r</language>
	</row>
	<row id="narc_0199_00085" index="85">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Memo Pad{COLOR 0}-appen kan bruges til\n at skrive hurtige noter ned.\r</language>
	</row>
	<row id="narc_0199_00086" index="86">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Pedometer{COLOR 0}-appen tæller antallet\naf skridt, du har gået.\r</language>
	</row>
	<row id="narc_0199_00087" index="87">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Pokémon List{COLOR 0}-appen lader dig\ntjekke status for dit hold.\r</language>
	</row>
	<row id="narc_0199_00088" index="88">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Friendship Checker{COLOR 0}-appen identificerer\nden Pokémon, der kan lide dig.</language>
	</row>
	<row id="narc_0199_00089" index="89">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Dowsing Machine{COLOR 0}-appen lokaliserer\nusynlige elementer.\r</language>
	</row>
	<row id="narc_0199_00090" index="90">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Berry Searcher{COLOR 0}-appen angiver\nplaceringerne af modne bær.</language>
	</row>
	<row id="narc_0199_00091" index="91">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Day-Care Checker{COLOR 0}-appen viser\nden Pokémon, der er tilbage med dagplejen.</language>
	</row>
	<row id="narc_0199_00092" index="92">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Pokémon History{COLOR 0}-appen viser\nden senest opnåede Pokémon.</language>
	</row>
	<row id="narc_0199_00093" index="93">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Counter{COLOR 0}-appen kan bruges\ntil at tælle op til 9.999.</language>
	</row>
	<row id="narc_0199_00094" index="94">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Analog Watch{COLOR 0}-appen viser\nden aktuelle tid.</language>
	</row>
	<row id="narc_0199_00095" index="95">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Appen {COLOR 2}Marking Map{COLOR 0} tillader\nplacering af markører.\r</language>
	</row>
	<row id="narc_0199_00096" index="96">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Link Searcher{COLOR 0}-appen bestemmer\ntilgængeligheden af ​​trådløse hotspots.\r</language>
	</row>
	<row id="narc_0199_00097" index="97">
		<attribute name="window_context_name">used</attribute>
