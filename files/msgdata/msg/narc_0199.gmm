	<row id="narc_0199_00110" index="110">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er tekst indgraveret på bagsiden\naf den opnåede plade...\r"Da universet blev skabt, blev dens skår til denne plade."\r</language>
	</row>
	<row id="narc_0199_00111" index="111">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er tekst indgraveret på bagsiden\naf den opnåede plade...\r"Kraften fra besejrede giganter\ninfuserer denne plade."\r</language>
	</row>
	<row id="narc_0199_00112" index="112">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er tekst indgraveret på bagsiden\naf den opnåede plade...\r"To væsener af tid og rum er frigjort fra den oprindelige."\r</language>
	</row>
	<row id="narc_0199_00113" index="113">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er tekst indgraveret på bagsiden\naf den opnåede plade...\r"Tre væsener blev født til at binde\ntid og rum."\r</language>
	</row>
	<row id="narc_0199_00114" index="114">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er tekst indgraveret på bagsiden\naf den opnåede plade...\r"To skaber materie og tre skaber\nsånd, der former verden."\r</language>
	</row>
	<row id="narc_0199_00115" index="115">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er tekst indgraveret på bagsiden\naf den opnåede plade...\r"Den originale åndede alene\nfør universet kom."\r</language>
	</row>
	<row id="narc_0199_00116" index="116">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er tekst indgraveret på bagsiden\naf den opnåede plade...\r"Pladernes kræfter er delt\namong Pokémon."\r</language>
	</row>
	<row id="narc_0199_00117" index="117">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er tekst indgraveret på bagsiden\naf den opnåede plade...\r"Den retmæssige bærer af en plade\ntegner fra den plade, den holder."\r</language>
	</row>
	<row id="narc_0199_00118" index="118">
