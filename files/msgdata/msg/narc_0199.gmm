<?xml version="1.0"?>
<body language="English">
	<row id="narc_0199_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hej og velkommen til\nPokémon Center.\rVi genopretter din trætte Pokémon\ntil fuld sundhed.\rVil du hvile din Pokémon?</language>
	</row>
	<row id="narc_0199_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">OK, jeg tager din Pokémon i et par\nsekunder.</language>
	</row>
	<row id="narc_0199_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Tak fordi du ventede.\rVi har genoprettet din Pokémon til fuld\nsundhed.\r</language>
	</row>
	<row id="narc_0199_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi håber at se dig igen!</language>
	</row>
	<row id="narc_0199_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hej og velkommen til\nPokémon Center.\rVi genopretter din trætte Pokémon\ntil fuld sundhed.\rVil du...\r</language>
	</row>
	<row id="narc_0199_00005" index="5">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det der trænerkort!\rDen funklende farve!\nOg alle de stjerner!\rJeg har set adskillige trænere med sølv\nTrænerkort indtil nu...\rMen du er den første, der topper dem\nmed det trænerkort.\rVenligst, {STRVAR_1 3, 0}, må jeg få\næren af ​​at helbrede din Pokémon?</language>
	</row>
	<row id="narc_0199_00006" index="6">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er dejligt at se dig, {STRVAR_1 3, 0}!\nDu vil have det sædvanlige, ikke sandt?</language>
	</row>
	<row id="narc_0199_00007" index="7">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg vil med glæde tage din\nPokémon i et par sekunder.</language>
	</row>
	<row id="narc_0199_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Tak fordi du ventede.</language>
	</row>
	<row id="narc_0199_00009" index="9">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi håber at se dig igen!</language>
	</row>
	<row id="narc_0199_00010" index="10">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Din Pokémon kan være inficeret med\nPokémon.\rLidt er kendt om Pokérus\nbortset fra, at de er mikroskopiske\flife-former, der knytter sig til Pokémon.\rMens de er inficerede, siges Pokémon at\vokse usædvanligt godt.</language>
	</row>
	<row id="narc_0199_00011" index="11">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} er ude af kampklar\nPokémon!\r{STRVAR_1 3, 0}s syn er dæmpet!</language>
	</row>
	<row id="narc_0199_00012" index="12">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English"></language>
		<language name="日本語">XXXXXXXXXXXX</language>
	</row>
	<row id="narc_0199_00013" index="13">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vil du gemme spillet?</language>
	</row>
	<row id="narc_0199_00014" index="14">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er allerede en gemt fil.\nEr det OK at overskrive den?</language>
	</row>
	<row id="narc_0199_00015" index="15">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gemmer...\nSluk ikke for strømmen.</language>
	</row>
	<row id="narc_0199_00016" index="16">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0}reddede spillet.</language>
	</row>
	<row id="narc_0199_00017" index="17">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Advarsel!\nDer er allerede en gemt spilfil.\rHvis du gemmer nu, vil den anden fils\eventyr, inklusive elementer og\fPokémon, gå helt tabt.\rEr du sikker på, at du vil gemme nu\nog overskrive den anden gemte fil?</language>
	</row>
	<row id="narc_0199_00018" index="18">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gem fejl.</language>
	</row>
	<row id="narc_0199_00019" index="19">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gemmer...\nSluk ikke for strømmen.</language>
	</row>
	<row id="narc_0199_00020" index="20">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er allerede en gemt spilfil.\nDet er umuligt at gemme.\rSe venligst vejledningen\nhæftet for detaljer.\rTryk på Op + VÆLG + B-knappen på\ntitelskærmen, hvis du vil slette\fden nuværende gemte spilfil.</language>
	</row>
	<row id="narc_0199_00021" index="21">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gemmer en masse data...\nSluk ikke for strømmen.</language>
	</row>
	<row id="narc_0199_00022" index="22">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vil du give et kaldenavn til\n{STRVAR_1 0, 0}?</language>
	</row>
	<row id="narc_0199_00023" index="23">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English"></language>
		<language name="日本語">XXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0199_00024" index="24">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} fik Pokétch\nappen {STRVAR_1 24, 1}.</language>
	</row>
	<row id="narc_0199_00025" index="25">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Opnåede {STRVAR_1 8, 0}!</language>
	</row>
	<row id="narc_0199_00026" index="26">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} installerede appen på\nPokétch.\r</language>
	</row>
	<row id="narc_0199_00027" index="27">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ærgerligt!\nSagen er fuld...</language>
	</row>
	<row id="narc_0199_00028" index="28">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} opnået\n{COLOR 2}{STRVAR_1 8, 1}{COLOR 0}!</language>
	</row>
	<row id="narc_0199_00029" index="29">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} opnået\n{COLOR 1}{STRVAR_1 8, 1}{COLOR 0}!</language>
	</row>
	<row id="narc_0199_00030" index="30">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} læg {STRVAR_1 8, 1}\ni {STRVAR_1 31, 2}-lommen.</language>
	</row>
	<row id="narc_0199_00031" index="31">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} læg\n{STRVAR_1 31, 1} væk i Fashion Case.</language>
	</row>
	<row id="narc_0199_00032" index="32">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} startede pc'en op.\r</language>
	</row>
	<row id="narc_0199_00033" index="33">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvilken pc skal tilgås?</language>
	</row>
	<row id="narc_0199_00034" index="34">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pokémon Storage System\nblev tilgået.\r</language>
	</row>
	<row id="narc_0199_00035" index="35">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Adgang til {STRVAR_1 3, 0}s pc.\r</language>
	</row>
	<row id="narc_0199_00036" index="36">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Rowans ord genlød...\n{STRVAR_1 3, 0}! Der er tid og sted for alt! Men ikke nu.</language>
	</row>
	<row id="narc_0199_00037" index="37">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Velkommen!\nHvad har du brug for?</language>
	</row>
	<row id="narc_0199_00038" index="38">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English"></language>
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0199_00039" index="39">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der! Alle glade og sunde!\nHeld og lykke og pas på!</language>
	</row>
	<row id="narc_0199_00040" index="40">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mor: {STRVAR_1 3, 0}!\nVelkommen hjem.\rDet lyder som om, du havde en rigtig\noplevelse derude.\rMåske skulle du tage et hurtigt\nhvil, så du kan slappe af.\r...\n...</language>
	</row>
	<row id="narc_0199_00041" index="41">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mor: Åh, godt! Du og din\nPokémon ser godt ud.\rÅh, ja, jeg hørte fra professor\nRowan.\rHan sagde, at en Pokémons energi\nmåles i HP (Hit Points).\rHvis din Pokémon mister deres HP,\nkan du gendanne den på ethvert\fPokémon Center.\nHvis du vil rejse langt væk,\nhvis du rejser langt væk,\n på Pokémon Mart.\rGør mig stolt, skat!\nPas på!</language>
	</row>
	<row id="narc_0199_00042" index="42">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mor: Åh, godt! Du og din\nPokémon ser godt ud.\rÅh ja, {STRVAR_1 3, 0}, din Pokémon\nvil besvime, hvis den løber tør for HP.\rHvis din Pokémon mister sin HP, så kom\nhjem, før den besvimer.\rDen vil blive helbredt til fuld sundhed ved\nat tage en pause, skat!\nHvil dig godt!</language>
	</row>
	<row id="narc_0199_00043" index="43">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lad os først genoprette din Pokémon til fuld sundhed.</language>
	</row>
	<row id="narc_0199_00044" index="44">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dine Pokémon er blevet helbredt\ntil perfekt helbred.</language>
	</row>
	<row id="narc_0199_00045" index="45">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Besøg venligst et Pokémon-center, når\n din Pokémons HP går ned.\rHvis du planlægger at rejse til en hvilken som helst afstand, bør du fylde op\fPotions på en Pokémon Mart.\rHeld og lykke, træner!</language>
	</row>
	<row id="narc_0199_00046" index="46">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er en sød duft i luften...</language>
	</row>
	<row id="narc_0199_00047" index="47">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er en sød duft i luften...\r</language>
	</row>
	<row id="narc_0199_00048" index="48">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Barken er strøet med honning...</language>
	</row>
	<row id="narc_0199_00049" index="49">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Barken er slathered med honning...\r</language>
	</row>
	<row id="narc_0199_00050" index="50">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Smør barken med honning?</language>
	</row>
	<row id="narc_0199_00051" index="51">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Barken blev strøet med honning.</language>
	</row>
	<row id="narc_0199_00052" index="52">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er ingen mail i postkassen.\r</language>
	</row>
	<row id="narc_0199_00053" index="53">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mailens indhold vil gå tabt.\nVil du tage det tilbage alligevel?</language>
	</row>
	<row id="narc_0199_00054" index="54">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ikke engang en bid...</language>
	</row>
	<row id="narc_0199_00055" index="55">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pokémon'en slap væk...</language>
	</row>
	<row id="narc_0199_00056" index="56">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vippede den ind for hurtigt...</language>
	</row>
	<row id="narc_0199_00057" index="57">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Landede en Pokémon!</language>
	</row>
