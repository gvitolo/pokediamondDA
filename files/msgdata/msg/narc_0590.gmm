	<row id="narc_0590_00010" index="10">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Nintendo Wi-Fi-forbindelse</language>
	</row>
	<row id="narc_0590_00011" index="11">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wi-Fi Battle Tower er pt\nunder vedligeholdelse.\rPrøv venligst igen senere.\r</language>
