		<attribute name="window_context_name">used</attribute>
		<language name="English">Wi-Fi Battle Tower er meget\noverfyldt.\rPrøv venligst igen senere.\r</language>
	</row>
	<row id="narc_0590_00013" index="13">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Kan ikke oprette forbindelse til Wi-Fi\nKamptårnet.\rVender tilbage til receptionsskranken.\r</language>
