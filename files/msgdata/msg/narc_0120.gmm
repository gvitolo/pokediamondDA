	</row>
	<row id="narc_0120_00025" index="25">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English"></language>
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0120_00026" index="26">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er en ramme at vise et billede i.</language>
	</row>
</body>
