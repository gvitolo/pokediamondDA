	<row id="narc_0343_00215" index="215">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Det er\n stiv og tung bøjle, der fremmer\nstærk vækst, men sænker hastigheden.</language>
	</row>
	<row id="narc_0343_00216" index="216">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nIndehaveren får en del af en kamps\nExp. Point uden at kæmpe.</language>
	</row>
	<row id="narc_0343_00217" index="217">
		<attribute name="window_context_name">used</attribute>
