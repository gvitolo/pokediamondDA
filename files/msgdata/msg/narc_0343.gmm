	<row id="narc_0343_00244" index="244">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er et langt, skarpt næb, der booster\nkraften i Flying-type bevægelser.</language>
