	<row id="narc_0343_00245" index="245">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en lille, giftig modhage, der øger\nkraften i bevægelser af typen Poison.</language>
