	<row id="narc_0343_00265" index="265">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en forstørrelseslinse, der en smule\nforøger nøjagtigheden af ​​bevægelser.</language>
	</row>
	<row id="narc_0343_00266" index="266">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er et pandebånd, der en smule forstærker\nkraften i fysiske bevægelser.</language>
	</row>
	<row id="narc_0343_00267" index="267">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Det er\n et par tykke briller, der en smule\nforstærker kraften ved specielle bevægelser.</language>
	</row>
	<row id="narc_0343_00268" index="268">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Det er\n et godt slidt bælte, der en smule booster\nkraften i supereffektive bevægelser.</language>
	</row>
	<row id="narc_0343_00269" index="269">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-element, der forlænger varigheden af ​​barrierebevægelser som Light\nSkærm og Reflect, der bruges af indehaveren.</language>
	</row>
	<row id="narc_0343_00270" index="270">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet øger kraften i træk, men til\nbekostning af nogle HP ved hvert hit.</language>
	</row>
	<row id="narc_0343_00271" index="271">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand til engangsbrug, der skal opbevares af en\nPokémon. Det tillader den øjeblikkelige brug af\na træk, der oplades ved den første tur.</language>
	</row>
	<row id="narc_0343_00272" index="272">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en bizar kugle, der forgifter\nholderen i kamp.</language>
	</row>
	<row id="narc_0343_00273" index="273">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en bizar kugle, der påfører holderen en\nbrænding i kamp.</language>
	</row>
	<row id="narc_0343_00274" index="274">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af DITTO.\nEkstremt fint, men hårdt, dette mærkelige\npudder booster hastighedsstatistikken.</language>
	</row>
	<row id="narc_0343_00275" index="275">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Hvis den\nhar fuld HP, vil indehaveren udholde et\npotentielt KO-angreb, hvilket efterlader 1 HP.</language>
	</row>
	<row id="narc_0343_00276" index="276">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et emne, der skal holdes af en Pokémon.\nHvis indehaveren bevæger sig efter fjenden, vil dens\nkritiske hit-forhold blive forstærket.</language>
	</row>
	<row id="narc_0343_00277" index="277">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-emne, der booster et træk\nus efter hinanden. Dens effekt er\nnulstillet, hvis et andet træk bruges.</language>
	</row>
	<row id="narc_0343_00278" index="278">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-element, der reducerer hastigheden.\nDet gør flyvende og svævende\nholdere modtagelige for Ground-bevægelser.</language>
	</row>
	<row id="narc_0343_00279" index="279">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er enormt tungt og får\nholderen til at bevæge sig langsommere end normalt.</language>
	</row>
	<row id="narc_0343_00280" index="280">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En lang, tynd, lysende rød snor, der skal holdes af en Pokémon. Hvis indehaveren\nbliver forelsket, gør fjenden det også.</language>
	</row>
	<row id="narc_0343_00281" index="281">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et hold-element, der gradvist genopretter\nHP af Pokémon-type Pokémon.\nDet påfører alle andre typer skade.</language>
	</row>
	<row id="narc_0343_00282" index="282">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-emne, der forlænger\nvarigheden af ​​bevægelsen. Hagl brugt af\nindehaveren.</language>
	</row>
	<row id="narc_0343_00283" index="283">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-emne, der forlænger\nvarigheden af ​​bevægelsen Sandstorm brugt\naf indehaveren.</language>
	</row>
	<row id="narc_0343_00284" index="284">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-element, der forlænger\nvarigheden af ​​bevægelsen Sunny Day brugt\naf indehaveren.</language>
	</row>
	<row id="narc_0343_00285" index="285">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-emne, der forlænger\nvarigheden af ​​bevægelsen Rain Dance brugt\naf indehaveren.</language>
	</row>
	<row id="narc_0343_00286" index="286">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-element, der forlænger\nvarigheden af ​​multiturn-angreb som\nBind og Wrap.</language>
	</row>
	<row id="narc_0343_00287" index="287">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDette tørklæde øger hastigheden, men tillader\nbrugen af ​​kun én form for bevægelse.</language>
	</row>
	<row id="narc_0343_00288" index="288">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En hold-genstand, der beskadiger holderen hver gang. Det kan låse hurtigt på fjender\n, der rører holderen.</language>
	</row>
	<row id="narc_0343_00289" index="289">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-element, der fremmer\nAngrebsgevinst ved udjævning, men reducerer\nhastighedsstatistikken.</language>
	</row>
	<row id="narc_0343_00290" index="290">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold element, der fremmer\nForsvarsgevinst ved udjævning, men reducerer\nhastighedsstatistikken.</language>
	</row>
	<row id="narc_0343_00291" index="291">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-element, der promoverer\nSp. Atk-forøgelse ved nivellering, men reducerer\nhastighedsstatistikken.</language>
	</row>
	<row id="narc_0343_00292" index="292">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-element, der promoverer\nSp. Def. forstærkning ved nivellering, men reducerer\nhastighedsstatistikken.</language>
	</row>
	<row id="narc_0343_00293" index="293">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-element, der fremmer\nHastighedsforøgelse ved nivellering, men reducerer\nhastighedsstatistikken.</language>
	</row>
	<row id="narc_0343_00294" index="294">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-element, der fremmer\nHP-gevinst ved udjævning, men reducerer\nHastighedsstatistiken.</language>
	</row>
	<row id="narc_0343_00295" index="295">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et hårdt, kasseret skjold, der skal holdes\n af en Pokémon. Det gør det muligt for indehaveren at\nskifte med en ventende Pokémon i kamp.</language>
	</row>
	<row id="narc_0343_00296" index="296">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon hold-emne, der øger\nkraften ved HP-stjælebevægelser for at lade\nindehaveren genvinde mere HP.</language>
	</row>
	<row id="narc_0343_00297" index="297">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Disse\distinktive briller booster Sp. Atk, men\ntillad kun én slags træk at blive brugt.</language>
	</row>
	<row id="narc_0343_00298" index="298">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der forstærker\nkraften af ​​bevægelser af typen Fire.</language>
	</row>
	<row id="narc_0343_00299" index="299">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der forstærker\nkraften af ​​vand-lignende bevægelser.</language>
	</row>
	<row id="narc_0343_00300" index="300">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der øger\nkraften af ​​bevægelser af elektrisk type.</language>
	</row>
	<row id="narc_0343_00301" index="301">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der øger\nkraften af ​​​​græs-lignende bevægelser.</language>
	</row>
	<row id="narc_0343_00302" index="302">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der forstærker\nkraften af ​​​​is-lignende bevægelser.</language>
	</row>
	<row id="narc_0343_00303" index="303">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der forstærker\nkraften i bevægelser af slagmål.</language>
	</row>
	<row id="narc_0343_00304" index="304">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der forstærker\nkraften i bevægelser af typen Poison.</language>
	</row>
	<row id="narc_0343_00305" index="305">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der forstærker\nkraften af ​​Ground-type bevægelser.</language>
	</row>
	<row id="narc_0343_00306" index="306">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der øger\nkraften af ​​Flying-type bevægelser.</language>
	</row>
	<row id="narc_0343_00307" index="307">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der øger\nkraften i bevægelser af psykisk type.</language>
	</row>
	<row id="narc_0343_00308" index="308">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentablet, der øger\nkraften af ​​​​bug-lignende bevægelser.</language>
	</row>
	<row id="narc_0343_00309" index="309">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der forstærker\nkraften af ​​rock-lignende bevægelser.</language>
	</row>
	<row id="narc_0343_00310" index="310">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der øger\nkraften i bevægelser af spøgelsestypen.</language>
	</row>
	<row id="narc_0343_00311" index="311">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentablet, der øger\nkraften i drage-lignende bevægelser.</language>
	</row>
	<row id="narc_0343_00312" index="312">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der forstærker\nkraften af ​​bevægelser af Dark-type.</language>
	</row>
	<row id="narc_0343_00313" index="313">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en stentavle, der øger\nkraften i bevægelser af ståltypen.</language>
	</row>
	<row id="narc_0343_00314" index="314">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Det er\neksotisk-duftende røgelse, der booster\nkraften i bevægelser af psykisk type.</language>
	</row>
	<row id="narc_0343_00315" index="315">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Det er\neksotisk-duftende røgelse, der booster\nkraften i rock-agtige bevægelser.</language>
	</row>
	<row id="narc_0343_00316" index="316">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Det er\neksotisk-duftende røgelse, der gør\nholderen opustet og langsomt bevægende.</language>
	</row>
	<row id="narc_0343_00317" index="317">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Det er\neksotisk-duftende røgelse, der booster\nkraften i vand-lignende bevægelser.</language>
	</row>
	<row id="narc_0343_00318" index="318">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Det er\neksotisk-duftende røgelse, der booster\nkraften i græs-lignende bevægelser.</language>
	</row>
	<row id="narc_0343_00319" index="319">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet fordobler en kamps præmiepenge, hvis\nden holdende Pokémon slutter sig til.</language>
	</row>
	<row id="narc_0343_00320" index="320">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet hjælper med at holde vilde Pokémon væk, hvis\nindehaveren er den første i partiet.</language>
	</row>
	<row id="narc_0343_00321" index="321">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En slags beskyttende genstand.\nDen er ekstremt stiv og tung.\nDen er elsket af en bestemt Pokémon.</language>
	</row>
	<row id="narc_0343_00322" index="322">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En æske spækket med en enorm mængde elektrisk energi.\nDen er elsket af en bestemt Pokémon.</language>
	</row>
	<row id="narc_0343_00323" index="323">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En kasse fyldt med en enorm\nmængde magmaenergi.\nDen er elsket af en bestemt Pokémon.</language>
	</row>
	<row id="narc_0343_00324" index="324">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En gennemsigtig enhed, der flyder over med\ntvivlsom data.\nDens producent er ukendt.</language>
	</row>
	<row id="narc_0343_00325" index="325">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En klud gennemsyret af rædselsvækkende stærk\nåndelig energi.\nDen er elsket af en bestemt Pokémon.</language>
	</row>
	<row id="narc_0343_00326" index="326">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en skarp kroget klo, der øger\nholderens forhold mellem kritiske hits.</language>
	</row>
	<row id="narc_0343_00327" index="327">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet kan få fjenden til at vige, når\nholderen påfører skade.</language>
	</row>
	<row id="narc_0343_00328" index="328">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren fokuserer sit sind før\nstarter dette angreb. Det vil mislykkes, hvis\nbrugeren bliver ramt, før den bruges.</language>
	</row>
	<row id="narc_0343_00329" index="329">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Skarpe, enorme kløer krog og hug\nfjenden hurtigt og med stor\nkraft.</language>
	</row>
	<row id="narc_0343_00330" index="330">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver ramt med en pulserende eksplosion\nvand. Det kan også forvirre\nmålet.</language>
	</row>
	<row id="narc_0343_00331" index="331">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren fokuserer stille sit sind og\n beroliger sin ånd for at hæve sin Sp. Atk\nand Sp. Def statistik.</language>
	</row>
	<row id="narc_0343_00332" index="332">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden er bange for at blive erstattet\naf en anden Pokémon i sit parti.\nI naturen slutter kampen.</language>
	</row>
	<row id="narc_0343_00333" index="333">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et træk, der efterlader fjenden slemt\nforgiftet. Denne gaveskade\nforværres hver gang.</language>
	</row>
	<row id="narc_0343_00334" index="334">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Tilkalder en haglstorm, der varer i\nfem omgange. Haglstormen skader\nalle typer undtagen Is.</language>
	</row>
	<row id="narc_0343_00335" index="335">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren spænder sine muskler for at fylde\nens krop, hvilket øger både dens angrebs- og\nforsvarsstatistikker.</language>
	</row>
	<row id="narc_0343_00336" index="336">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren skyder med magt frø mod\nfjenden. To til fem frø skydes i\nhurtigt rækkefølge.</language>
	</row>
	<row id="narc_0343_00337" index="337">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et variabelt træk, der ændrer type\nog kraft afhængigt af den skjulte\nevne af Pokémon'en, der bruger den.</language>
	</row>
	<row id="narc_0343_00338" index="338">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren intensiverer solen i\nfem drejninger og tænder for Fire-type\nbevægelser.</language>
	</row>
	<row id="narc_0343_00339" index="339">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden hånes til et raseri, der\nlader den kun bruge angrebstræk i\nto til fire omgange.</language>
	</row>
	<row id="narc_0343_00340" index="340">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver ramt af en iskold\nstråle af energi. Det kan også fryse\nmålfaststoffet.</language>
	</row>
	<row id="narc_0343_00341" index="341">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En hylende snestorm bliver tilkaldt for at\nslå fjenden. Det kan også fryse\nmålfaststoffet.</language>
	</row>
	<row id="narc_0343_00342" index="342">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden angribes med en kraftig\nstråle. Brugeren skal hvile på næste\ndrejning for at genvinde sin energi.</language>
	</row>
	<row id="narc_0343_00343" index="343">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En vidunderlig væg af lys sættes op for at\nundertrykke skader fra specielle angreb\ni fem omgange.</language>
	</row>
	<row id="narc_0343_00344" index="344">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det gør det muligt for brugeren at undgå alle\angreb. Dens chance for at fejle stiger\nhvis den bruges i rækkefølge.</language>
	</row>
	<row id="narc_0343_00345" index="345">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren tilkalder en kraftig regn, der\nfalder i fem omgange, og opstarter\nVand-lignende bevægelser.</language>
	</row>
	<row id="narc_0343_00346" index="346">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et næringsstof-drænende angreb. Brugerens\nHP gendannes med halvdelen af ​​​​skaden\noptaget af målet.</language>
	</row>
	<row id="narc_0343_00347" index="347">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren opretter et beskyttende felt\nder forhindrer statusproblemer som\ngift, lammelser, forbrændinger og søvn.</language>
	</row>
	<row id="narc_0343_00348" index="348">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fuld kraftangreb, der bliver mere\nkraftigt, jo mindre brugere kan lide dens\nTræner.</language>
	</row>
	<row id="narc_0343_00349" index="349">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et angreb i to omgange. Brugeren samler\nlys og sprænger derefter en bundtet stråle på\nden anden omgang.</language>
	</row>
	<row id="narc_0343_00350" index="350">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver smækket med en robust\nhale af stål. Det kan også sænke \nmålets forsvarsstat, hvis det rammer.</language>
	</row>
	<row id="narc_0343_00351" index="351">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En stærk elektrisk eksplosion løsnes ved\nfjenden. Det kan også efterlade fjenden\nlammet.</language>
	</row>
	<row id="narc_0343_00352" index="352">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ond torden bliver tabt på fjenden for at påføre skade. Det kan også\nefterlade målet lammet.</language>
	</row>
	<row id="narc_0343_00353" index="353">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren sætter et jordskælv i gang\nder rammer alle Pokémonerne i\nkampen.</language>
	</row>
	<row id="narc_0343_00354" index="354">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fuldkraftsangreb, der bliver mere\nkraftigt, jo mere brugeren kan lide dens\nTræner.</language>
	</row>
	<row id="narc_0343_00355" index="355">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren graver sig ned og angriber derefter på den\nanden tur. Den kan også bruges til at\nå forlade fangehuller.</language>
	</row>
	<row id="narc_0343_00356" index="356">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden rammes af en stærk telekinetisk\nkraft. Det kan også reducere fjendens\nSp. Def stat.</language>
	</row>
	<row id="narc_0343_00357" index="357">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren kaster en skyggefuld klat mod fjenden. Det kan også sænke fjendens\nSp. Def stat.</language>
	</row>
	<row id="narc_0343_00358" index="358">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren angriber med hårde næver,\netc. Den kan også bryde enhver barriere\nsåsom Light Screen og Reflect.</language>
	</row>
	<row id="narc_0343_00359" index="359">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren begynder at bevæge sig så hurtigt\nat den skaber illusoriske kopier for at\nhæve sin undvigelse.</language>
	</row>
	<row id="narc_0343_00360" index="360">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En vidunderlig væg af lys er sat op for at\nundertrykke skader fra fysiske angreb\ni fem omgange.</language>
	</row>
	<row id="narc_0343_00361" index="361">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren slår fjenden med et hurtigt\nstød af elektricitet. Dette angreb kan ikke\nundgås.</language>
	</row>
	<row id="narc_0343_00362" index="362">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden er brændt med et intenst\nudbrud af ild. Målet kan også være\n efterladt med en forbrænding.</language>
	</row>
	<row id="narc_0343_00363" index="363">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Uhygiejnisk slam slynges mod fjenden. Det kan også forgifte\nmålet.</language>
	</row>
	<row id="narc_0343_00364" index="364">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En fem-svings sandstorm tilkaldes\nfor at skade alle kombattanter undtagen\nRock-, Ground- og Steel-typerne.</language>
	</row>
	<row id="narc_0343_00365" index="365">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver angrebet med en intens\nblæsning af altopslugende ild. Det kan også efterlade målet med en forbrænding.</language>
	</row>
	<row id="narc_0343_00366" index="366">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Store kampesten kastes mod fjenden\nfor at påføre skade. Det kan også få \nmålet til at vige.</language>
	</row>
	<row id="narc_0343_00367" index="367">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren forvirrer fjenden med fart,\nså slår til. Angrebet lander uden\nfejl.</language>
	</row>
	<row id="narc_0343_00368" index="368">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren plager og gør fjenden rasende, hvilket gør den ude af stand til at bruge det\nsamme træk to gange i træk.</language>
	</row>
	<row id="narc_0343_00369" index="369">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et angrebstræk, der fordobler sin kraft\nhvis brugeren er forgiftet, lammet eller\nhar en forbrænding.</language>
	</row>
	<row id="narc_0343_00370" index="370">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et angrebstræk med effekter, der\nvarierer afhængigt af brugerens\miljø.</language>
	</row>
	<row id="narc_0343_00371" index="371">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren går i dvale i to\ndrejninger. Det genopretter fuldstændigt brugerens HP\nog afhjælper ethvert statusproblem.</language>
	</row>
	<row id="narc_0343_00372" index="372">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis det er det modsatte køn af\brugeren, bliver fjenden forelsket\nog mindre tilbøjelig til at angribe.</language>
	</row>
	<row id="narc_0343_00373" index="373">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren angriber og stjæler fjendens\nholdte genstand samtidigt. Det kan ikke\nstjæle, hvis brugeren har et element.</language>
	</row>
	<row id="narc_0343_00374" index="374">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver ramt med vinger af stål.\nDet kan også hæve brugerens forsvar\nstat.</language>
	</row>
	<row id="narc_0343_00375" index="375">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren bruger sin psykiske kraft til at\nudveksle evner med fjenden.\n</language>
	</row>
	<row id="narc_0343_00376" index="376">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren stjæler effekterne af enhver\nhelbredende eller statusændrende bevægelse, som fjenden forsøger at bruge.</language>
	</row>
	<row id="narc_0343_00377" index="377">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren angriber fjenden med fuld\nkraft ved hjælp af brændende energi. Det reducerer også\nskarpt brugerens Sp. Atk.</language>
	</row>
	<row id="narc_0343_00378" index="378">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren lander og hviler sin krop.\nDen gendanner brugerens HP med op til\nhalvdelen af ​​den øverste HP.</language>
	</row>
	<row id="narc_0343_00379" index="379">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren angriber med fuld kraft.\nDet kan også sænke fjendens Sp. Def\nstat hvis den rammer.</language>
	</row>
	<row id="narc_0343_00380" index="380">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren henter kraft fra naturen og\nskyder den mod fjenden. Det kan også sænke\nmålets Sp. Def.</language>
	</row>
	<row id="narc_0343_00381" index="381">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et tilbageholdende angreb, der forhindrer fjenden i at besvime. Målet er tilbage\nmed mindst 1 HP.</language>
	</row>
	<row id="narc_0343_00382" index="382">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis fjendens HP er nede på under det halve,\nvil dette angreb ramme med dobbelt kraft.</language>
	</row>
	<row id="narc_0343_00383" index="383">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren kaster sin tilbageholdte genstand mod fjenden for at angribe. Dens kraft og effekter\nafhænger af emnet.</language>
	</row>
	<row id="narc_0343_00384" index="384">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren angriber med en elektrisk\nladning. Brugeren kan bruge enhver resterende\elektricitet til at hæve sin Sp. Atk stat.</language>
	</row>
	<row id="narc_0343_00385" index="385">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren udholder ethvert angreb og efterlader\n1 HP. Dens chance for at fejle stiger, hvis den bruges i rækkefølge.</language>
	</row>
	<row id="narc_0343_00386" index="386">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver angrebet med en chok\nbølge genereret af brugerens gabende\nmund.</language>
	</row>
	<row id="narc_0343_00387" index="387">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En energi-drænende punch. Brugerens\nHP gendannes med halvdelen af ​​​​skaden\noptaget af målet.</language>
	</row>
	<row id="narc_0343_00388" index="388">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren skyder en uhyggelig, blålig\nhvid flamme mod fjenden for at påføre en\nforbrænding.</language>
	</row>
	<row id="narc_0343_00389" index="389">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver angrebet med pulveragtige\nskæl blæst af vinden. Det kan også\nhæve alle brugerens statistik.</language>
	</row>
	<row id="narc_0343_00390" index="390">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det forhindrer fjenden i at bruge dens\nholdte genstand. Dens træner er også\nforhindret i at bruge genstande på den.</language>
	</row>
	<row id="narc_0343_00391" index="391">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren eksploderer for at påføre skade på\nalle Pokémon i kamp. Brugeren besvimer\nuved at bruge dette træk.</language>
	</row>
	<row id="narc_0343_00392" index="392">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren hugger med en skarp klo\nlavet af skygger. Den har et højt\nkritisk hit-forhold.</language>
	</row>
	<row id="narc_0343_00393" index="393">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren gemmer magt og angriber derefter.\nHvis brugeren kan bruge dette angreb efter\nfjenden, fordobles dens magt.</language>
	</row>
	<row id="narc_0343_00394" index="394">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren genbruger en engangsgenstand\nder er blevet brugt i kamp, ​​så den kan\nbruges igen.</language>
	</row>
	<row id="narc_0343_00395" index="395">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren oplader fjenden ved at bruge hver\nbit af dens magt. Den skal hvile på den\nnæste tur for at komme sig.</language>
	</row>
	<row id="narc_0343_00396" index="396">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren polerer sin krop for at reducere\ntræk. Det hæver hastigheden\nstaten markant.</language>
	</row>
	<row id="narc_0343_00397" index="397">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren blinker med et lys, der reducerer fjendens nøjagtighed. Den kan også bruges til at\nbelyse huler.</language>
	</row>
	<row id="narc_0343_00398" index="398">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren stikker fjenden med en\nslebet sten nedefra. Den har\na høj kritiske hit-forhold.</language>
	</row>
	<row id="narc_0343_00399" index="399">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et angrebstræk, der påfører dobbelt\nskaden, hvis brugeren er blevet såret\naf fjenden i samme tur.</language>
	</row>
	<row id="narc_0343_00400" index="400">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En svag elektrisk ladning lanceres\nat fjenden. Det forårsager lammelse, hvis det\nhitter.</language>
	</row>
	<row id="narc_0343_00401" index="401">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren tackler fjenden fra et\nhøjhastighedsspin. Jo langsommere brugeren er,\njo større er skaden.</language>
	</row>
	<row id="narc_0343_00402" index="402">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En hektisk dans for at løfte kampånden. Det hæver brugerens\nangrebsstat kraftigt.</language>
	</row>
	<row id="narc_0343_00403" index="403">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren lægger en fælde af svævende\nsten omkring fjenden. Fælden gør ondt\nfjender, der skifter til kamp.</language>
	</row>
	<row id="narc_0343_00404" index="404">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren hypnotiserer sig selv til at\nkopiere enhver statændring foretaget\naf fjenden.</language>
	</row>
	<row id="narc_0343_00405" index="405">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis det er det modsatte køn af\brugeren, charmeres fjenden til kraftigt\n at sænke sin Sp. Atk stat.</language>
	</row>
	<row id="narc_0343_00406" index="406">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren frigiver en forfærdelig aura\n gennemsyret af mørke tanker. Det kan også\nfå målet til at vige.</language>
	</row>
	<row id="narc_0343_00407" index="407">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Store kampesten kastes mod fjenden\nfor at påføre skade. Det kan også få \nmålet til at vige.</language>
	</row>
	<row id="narc_0343_00408" index="408">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren hugger mod fjenden ved at\nkrydse dens le eller kløer, som om\nde var en saks.</language>
	</row>
	<row id="narc_0343_00409" index="409">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mens den sover, bruger brugeren\ntilfældigt et af bevægelserne\nikke kender.</language>
	</row>
	<row id="narc_0343_00410" index="410">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren trækker strøm fra den Berry\nit holder for at angribe. The Berry\nbestemmer dens type og kraft.</language>
	</row>
	<row id="narc_0343_00411" index="411">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden bliver stukket med en fangarm eller\narm sivet med gift. Det kan også\nforgifte fjenden.</language>
	</row>
	<row id="narc_0343_00412" index="412">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et angreb, der kun virker på en sovende fjende. Det absorberer halvdelen af ​​den skade, der er forårsaget for at helbrede brugerens HP.</language>
	</row>
	<row id="narc_0343_00413" index="413">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren fanger fjenden med græs\nog snubler den. Jo tungere fjenden er, jo større er skaden.</language>
	</row>
	<row id="narc_0343_00414" index="414">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren raser fjenden til\nforvirring. Det hæver dog også fjendens angrebsstatistik kraftigt.</language>
	</row>
	<row id="narc_0343_00415" index="415">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren hakker fjenden. Hvis fjenden\nholder en bær, plukker brugeren den og\nvinder dens effekt.</language>
	</row>
	<row id="narc_0343_00416" index="416">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Efter at have foretaget sit angreb, skynder brugeren tilbage for at skifte plads med en\nparts-Pokémon i vente.</language>
	</row>
	<row id="narc_0343_00417" index="417">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren laver en kopi af sig selv ved hjælp af\nnoget af sin HP. Kopier fungerer som\nbrugerens lokkemiddel.</language>
	</row>
	<row id="narc_0343_00418" index="418">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren samler al sin lysenergi\nog frigiver den i ét skud. Det kan også sænke fjendens Sp. Def stat.</language>
	</row>
	<row id="narc_0343_00419" index="419">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren skaber et bizart rum i\nhvor langsommere Pokémon kan bevæge sig\nførst i fem omgange.</language>
	</row>
	<row id="narc_0343_00420" index="420">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden klippes med en le eller en klo.\nDen kan også bruges til at fælde tynde\ntræer.</language>
	</row>
	<row id="narc_0343_00421" index="421">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren svæver og slår derefter på den\nanden tur. Den kan også bruges til at\nflyve til enhver kendt by.</language>
	</row>
	<row id="narc_0343_00422" index="422">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den oversvømmer hele slagmarken med\en kæmpe bølge. Den kan også bruges\ntil at krydse vand.</language>
	</row>
	<row id="narc_0343_00423" index="423">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fjenden slynges med et slag\nat med maksimal kraft. Den kan også bruges\ntil at flytte kampesten.</language>
	</row>
	<row id="narc_0343_00424" index="424">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Forhindringer flyttes, hvilket reducerer fjendens undvigelsesstatistik. Den kan også bruges til at fjerne dyb tåge.</language>
	</row>
	<row id="narc_0343_00425" index="425">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren slynger fjenden med et\nslående slag. Den kan også smadre\nrevne kampesten.</language>
	</row>
	<row id="narc_0343_00426" index="426">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brugeren oplader fjenden med en\nawesome hastighed. Den kan også bruges\ntil at bestige et vandfald.</language>
	</row>
	<row id="narc_0343_00427" index="427">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et opladningsangreb, der også kan efterlade\nfjenden forvirret. Den kan også bruges\ntil at skalere klippevægge.</language>
	</row>
	<row id="narc_0343_00428" index="428">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En taske fyldt med praktiske værktøjer\ntil at udforske. Det giver adgang til\nundergrunden.</language>
	</row>
	<row id="narc_0343_00429" index="429">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En robust, rummelig opgave, der bruges\ntil at bære bytte fra kulminen.</language>
	</row>
	<row id="narc_0343_00430" index="430">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den viser reglerne for at holde kampe.\nFor forbundne kampe kan du vælge\nhvilket sæt regler du vil bruge.</language>
	</row>
	<row id="narc_0343_00431" index="431">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et værktøj, der kan søge efter Pokémon\n, der gemmer sig i græsset. Dens batteri\noplades, mens du går.</language>
	</row>
	<row id="narc_0343_00432" index="432">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et kort, der viser de Battle Points\du har optjent.\n</language>
	</row>
	<row id="narc_0343_00433" index="433">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En notesbog, der holder en dag-til-dag\noptegnelse over dit eventyr indtil videre.\n</language>
	</row>
	<row id="narc_0343_00434" index="434">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et etui til opbevaring af sæler, der kan\npåføres kapselhylstrene til Poké\nbolde.</language>
	</row>
	<row id="narc_0343_00435" index="435">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fancy etui til ryddelig og\norganiseret opbevaring af farverige Pokémon\nTilbehør.</language>
	</row>
	<row id="narc_0343_00436" index="436">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En lillebitte taske, der kan rumme ti segl til\ndekorering af Poké-bolde.</language>
	</row>
	<row id="narc_0343_00437" index="437">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En praktisk notesblok, der bruges til\n at registrere dine venner og føre en\noptegnelse over spillet.</language>
	</row>
	<row id="narc_0343_00438" index="438">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En stor nøgle til at betjene dørene til\nThe Valley Windworks i canyonen.\nDen blev holdt af et Team Galactic Grunt.</language>
	</row>
	<row id="narc_0343_00439" index="439">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et ældgammelt holdt og lykke lavet af\nPokémon-knogler, der skal tages til den ældste\naf Celestic Town.</language>
	</row>
	<row id="narc_0343_00440" index="440">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En kortnøgle til at frakoble sikkerhed\nsystemer i Galactic HQ. At miste det\n kan tilsyneladende resultere i straf.</language>
	</row>
	<row id="narc_0343_00441" index="441">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En mytisk kæde, der siges at forbinde\nden legendariske Pokémon, der skabte\nSinnoh-regionen.</language>
	</row>
	<row id="narc_0343_00442" index="442">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et meget praktisk kort, der kan ses til enhver tid. Den viser endda din \nnuværende placering.</language>
	</row>
	<row id="narc_0343_00443" index="443">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En enhed, der angiver trænere, der\nønsker at kæmpe. Dens batteri oplades\nmens du går.</language>
	</row>
	<row id="narc_0343_00444" index="444">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et etui til at holde mønter opnået i\nSpillhjørnet.\nDen kan rumme op til 50.000 mønter.</language>
	</row>
	<row id="narc_0343_00445" index="445">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En gammel og slået fiskestang.\nBrug den ved et hvilket som helst vandområde til at fiske efter\nvilde akvatiske Pokémon.</language>
	</row>
	<row id="narc_0343_00446" index="446">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ny fiskestang af god kvalitet.\nBrug den ved et hvilket som helst vandområde til at fiske efter\nvilde akvatiske Pokémon.</language>
	</row>
	<row id="narc_0343_00447" index="447">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En fantastisk, højteknologisk fiskestang.\nBrug den ved et hvilket som helst vandområde til at fiske efter\nvilde akvatiske Pokémon.</language>
	</row>
	<row id="narc_0343_00448" index="448">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En vandkande formet som en PSYDUCK.\nDet hjælper med at fremme sund vækst af\nBær plantet i blød jord.</language>
	</row>
	<row id="narc_0343_00449" index="449">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et etui til opbevaring af Poffin kogt af\nbær.\n</language>
	</row>
	<row id="narc_0343_00450" index="450">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En foldecykel, der muliggør meget\nhurtigere bevægelse end løbeskoene.</language>
	</row>
	<row id="narc_0343_00451" index="451">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En nøgle til en af ​​suiterne på\nluksushotellet ved en sø. Af en eller anden mærkelig\ngrund forsvinder den ofte.</language>
	</row>
	<row id="narc_0343_00452" index="452">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et brev fra Prof. Oak.\nSkrevet i det er en anmodning til dig om at\ngå til Rt. 224.</language>
	</row>
	<row id="narc_0343_00453" index="453">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En fjer, der gløder som månen.\nDet siges, at den besidder kraften til at\nberette mareridt.</language>
	</row>
	<row id="narc_0343_00454" index="454">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et kort nødvendigt for at komme ind i kroen i\nCanalave City. Mærkeligt nok var den sidste dato\nmarkeret for 50 år siden.</language>
	</row>
	<row id="narc_0343_00455" index="455">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En fløjte, der udsender ekkolyde\nsom ikke ser ud til at være af denne verden.\nDet er uvist, hvem der har lavet den.</language>
	</row>
	<row id="narc_0343_00456" index="456">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den billet, der kræves for at sejle på\nfærgen S.S. Anne. Den har en tegning af et\nskib.</language>
	</row>
	<row id="narc_0343_00457" index="457">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Passet, der kræves for at deltage i Pokémon\nkonkurrencer. Den har en tegning af en pris\nbånd på.</language>
	</row>
	<row id="narc_0343_00458" index="458">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En sten dannet, da kampesten smeltede i\nintensivt varm magma og derefter hærdet.\nMagma forbliver forseglet inde.</language>
	</row>
	<row id="narc_0343_00459" index="459">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En pakke betroet i din varetægt.\nDu skal levere den til din\nbarndomsven, der forlod Twinleaf Town.</language>
	</row>
	<row id="narc_0343_00460" index="460">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En kupon, der skal byttes til et\nPokémon Watch (forkortet Pokétch).\nDer er nødvendige køb.</language>
	</row>
	<row id="narc_0343_00461" index="461">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En kupon, der skal byttes til et\nPokémon Watch (forkortet Pokétch).\nDer er nødvendige køb.</language>
	</row>
	<row id="narc_0343_00462" index="462">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En kupon, der skal byttes til et\nPokémon Watch (forkortet Pokétch).\nDer er nødvendige køb.</language>
	</row>
	<row id="narc_0343_00463" index="463">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Nøglen til Team Galactics skumle\nvarehus placeret i udkanten af\nVeilstone City.</language>
	</row>
	<row id="narc_0343_00464" index="464">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En fantastisk medicin udleveret af\napoteket i Cianwood City. Det helbreder fuldstændigt en Pokémon for enhver lidelse.</language>
	</row>
