	<row id="narc_0343_00223" index="223">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet fordobler en kamps præmiepenge, hvis\nden holdende Pokémon slutter sig til.</language>
	</row>
	<row id="narc_0343_00224" index="224">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet hjælper med at holde vilde Pokémon væk, hvis\nindehaveren er den første i partiet.</language>
	</row>
