	<row id="narc_0343_00249" index="249">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er et brændbart brændstof, der booster\nkraften i bevægelser af typen Fire.</language>
	</row>
	<row id="narc_0343_00250" index="250">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en hård og skarp hugtænd, der øger\nkraften i træk af dragetypen.</language>
	</row>
	<row id="narc_0343_00251" index="251">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er et overdådigt tørklæde, der booster\nkraften i bevægelser af Normal-typen.</language>
	</row>
	<row id="narc_0343_00252" index="252">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En gennemsigtig enhed fyldt med alle\n slags data.\nDen er produceret af Silph Co.</language>
	</row>
	<row id="narc_0343_00253" index="253">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nIndehaverens HP gendannes lidt\hver gang den påfører skade.</language>
	</row>
	<row id="narc_0343_00254" index="254">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Det er\nrøgelse med en mærkelig aroma, der\nforstærker kraften ved bevægelser af vandtypen.</language>
	</row>
	<row id="narc_0343_00255" index="255">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon. Den\nvanskelige aroma af denne røgelse sænker fjendens nøjagtighed.</language>
	</row>
	<row id="narc_0343_00256" index="256">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal opbevares af CHANSEY. Det er et\npar håndsker, der booster CHANSEYs\nkritiske hit-forhold.</language>
	</row>
	<row id="narc_0343_00257" index="257">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af DITTO.\nEkstremt fint, men hårdt, dette mærkelige\npudder booster forsvarsstatistikken.</language>
	</row>
	<row id="narc_0343_00258" index="258">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal opbevares af CUBONE eller\nMAROWAK. Det er en eller anden hård knogle, der booster angrebsstatistikken.</language>
	</row>
	<row id="narc_0343_00259" index="259">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal opbevares af FARFETCH'D. Det er\n meget lang og stiv porrestilk\nder øger forholdet mellem kritiske hits.</language>
	</row>
	<row id="narc_0343_00260" index="260">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et element, der skal holdes af en Pokémon.\nDet booster det "seje" aspekt af\nindehaveren i en konkurrence.</language>
	</row>
	<row id="narc_0343_00261" index="261">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet booster "Skønhed"-aspektet for\nindehaveren i en konkurrence.</language>
	</row>
	<row id="narc_0343_00262" index="262">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet booster det "søde" aspekt af\nindehaveren i en konkurrence.</language>
	</row>
	<row id="narc_0343_00263" index="263">
		<attribute name="window_context_name">used</attribute>
