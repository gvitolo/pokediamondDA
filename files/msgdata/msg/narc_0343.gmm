	<row id="narc_0343_00214" index="214">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et element, der skal holdes af en Pokémon.\nDet gendanner enhver sænket stat i\nkamp. Den kan kun bruges én gang.</language>
