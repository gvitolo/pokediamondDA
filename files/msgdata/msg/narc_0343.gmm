	<row id="narc_0343_00238" index="238">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der skal holdes af en Pokémon.\nDet er en ubrydelig sten, der øger\nkraften i rock-agtige bevægelser.</language>
