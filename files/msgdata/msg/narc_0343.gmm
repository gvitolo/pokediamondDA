<?xml version="1.0"?>
<body language="English">
	<row id="narc_0343_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">???</language>
	</row>
	<row id="narc_0343_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den bedste bold med det ultimative niveau af\npræstation. Det vil fange enhver vild\nPokémon uden fejl.</language>
	</row>
	<row id="narc_0343_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ultra-performance bold, der\ngiver en højere Pokémon-fangstrate\nend en stor bold.</language>
	</row>
	<row id="narc_0343_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En god, højtydende bold, der\ngiver en højere Pokémon-fangsthastighed\nend en standard Poké-bold.</language>
	</row>
	<row id="narc_0343_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En enhed til at fange vilde Pokémon.\nDen kaster som en fed mod målet.\nDen er designet som et kapselsystem.</language>
	</row>
	<row id="narc_0343_00005" index="5">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En speciel Poké Ball, der kun bruges i\nThe Great Marsh. Den er dekoreret i et\ncamouflagemønster.</language>
	</row>
	<row id="narc_0343_00006" index="6">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En noget anderledes Poké Ball, der\nfungerer særligt godt på vand- og\nBug-type Pokémon.</language>
	</row>
	<row id="narc_0343_00007" index="7">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En noget anderledes Poké Ball, der\nfungerer særligt godt på Pokémon, der\nlever i havet.</language>
	</row>
	<row id="narc_0343_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En noget anderledes Poké Ball, der\nfungerer særligt godt på svagere\nPokémon i naturen.</language>
	</row>
	<row id="narc_0343_00009" index="9">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En noget anderledes Poké Ball, der\nfungerer særligt godt på Pokémon\narter, der tidligere blev fanget.</language>
	</row>
	<row id="narc_0343_00010" index="10">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En noget anderledes bold, der\nbliver gradvist bedre, jo flere omgange der er i en kamp.</language>
	</row>
	<row id="narc_0343_00011" index="11">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En behagelig Poké-bold, der får en\nfanget vild Pokémon til hurtigt at vokse\nvenlig.</language>
	</row>
	<row id="narc_0343_00012" index="12">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En noget sjælden Poké Ball, der er\nlavet specielt til minde om\n begivenhed af en slags.</language>
	</row>
	<row id="narc_0343_00013" index="13">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En noget anderledes Poké Ball, der\ngør det nemmere at fange vilde Pokémon\n om natten eller på mørke steder som grotter.</language>
	</row>
	<row id="narc_0343_00014" index="14">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En afhjælpende Poké Ball, der genopretter den\nfangede Pokémons HP og eliminerer\nalle statusproblemer.</language>
	</row>
	<row id="narc_0343_00015" index="15">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En noget anderledes Poké Ball, der\ngiver en bedre fangstrate, hvis den\nbruges i starten af ​​​​et vildt møde.</language>
	</row>
	<row id="narc_0343_00016" index="16">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ret sjælden Poké-bold, der er\nspecielt udformet for at fejre\n en slags begivenhed.</language>
	</row>
	<row id="narc_0343_00017" index="17">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-lignende medicin mod sår.\nDet genopretter HP'en af ​​en Pokémon med\nkun 20 point.</language>
	</row>
	<row id="narc_0343_00018" index="18">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-type medicin.\nDet løfter virkningen af ​​gave fra én\nPokémon.</language>
	</row>
	<row id="narc_0343_00019" index="19">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-lignende medicin.\nDet helbreder en enkelt Pokémon, der\nlider af en forbrænding.</language>
	</row>
	<row id="narc_0343_00020" index="20">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-lignende medicin.\nDen afrimer en Pokémon, der er blevet\nfrosset fast.</language>
	</row>
	<row id="narc_0343_00021" index="21">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-lignende medicin.\nDet vækker en Pokémon fra søvnens\nklør.</language>
	</row>
	<row id="narc_0343_00022" index="22">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-type medicin.\nDet eliminerer lammelser fra en enkelt\nPokémon.</language>
	</row>
	<row id="narc_0343_00023" index="23">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En medicin, der fuldt ud genopretter HP\nog helbreder eventuelle statusproblemer for en\nenkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00024" index="24">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-lignende medicin mod sår.\nDet genopretter fuldstændigt HP'en af ​​en\nenkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00025" index="25">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-lignende medicin til sår.\nDet genopretter HP'en for én Pokémon med\n200 point.</language>
	</row>
	<row id="narc_0343_00026" index="26">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-lignende medicin mod sår.\nDet genopretter HP'en af ​​en Pokémon med\n50 point.</language>
	</row>
	<row id="narc_0343_00027" index="27">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En spray-type medicin.\nDet helbreder alle statusproblemer for en\nenkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00028" index="28">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En medicin, der genopliver en besvimet\nPokémon. Det gendanner halvdelen af\nPokémons maksimale HP.</language>
	</row>
	<row id="narc_0343_00029" index="29">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En medicin, der genopliver en besvimet\nPokémon. Det genopretter fuldstændigt\nPokémons HP.</language>
	</row>
	<row id="narc_0343_00030" index="30">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vand med et højt mineralindhold.\nDet genopretter HP'en for én Pokémon med\n50 point.</language>
	</row>
	<row id="narc_0343_00031" index="31">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En sodavandsdrik.\nDen genopretter HP'en for én Pokémon med\n60 point.</language>
	</row>
	<row id="narc_0343_00032" index="32">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En meget sød drink.\nDen genopretter HP'en for én Pokémon med\n80 point.</language>
	</row>
	<row id="narc_0343_00033" index="33">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mælk med et meget højt næringsindhold.\nDet genopretter HP'en for én Pokémon med\n100 point.</language>
	</row>
	<row id="narc_0343_00034" index="34">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et meget bittert medicinpulver.\nDet genopretter HP'en for én Pokémon med\n50 point.</language>
	</row>
	<row id="narc_0343_00035" index="35">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En meget bitter rod.\nDen genopretter HP'en for én Pokémon med\n200 point.</language>
	</row>
	<row id="narc_0343_00036" index="36">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et meget bittert medicinpulver.\nDet helbreder alle statusproblemer for en\nenkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00037" index="37">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En meget bitter lægeurt.\nDen genopliver en besvimet Pokémon og genskaber fuldstændigt dens HP.</language>
	</row>
	<row id="narc_0343_00038" index="38">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det gendanner PP'en for en Pokémons\nvalgte træk med maksimalt\n10 point.</language>
	</row>
	<row id="narc_0343_00039" index="39">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det gendanner fuldt ud PP'en for et enkelt\nvalgt træk, som er blevet lært\naf mål-Pokémonen.</language>
	</row>
	<row id="narc_0343_00040" index="40">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det gendanner PP'en for alle\nbevægelserne lært af den målrettede Pokémon\nmed 10 point hver.</language>
	</row>
	<row id="narc_0343_00041" index="41">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det gendanner fuldt ud PP'en for alle\nbevægelser lært af den målrettede\nPokémon.</language>
	</row>
	<row id="narc_0343_00042" index="42">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lavaridge Towns lokale specialitet.\nDet helbreder alle statusproblemer for\nogen Pokémon.</language>
	</row>
	<row id="narc_0343_00043" index="43">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En 100 % ren juice lavet af bær.\nDet genopretter HP'en af ​​en Pokémon med\nkun 20 point.</language>
	</row>
	<row id="narc_0343_00044" index="44">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den genopliver alle besvimede Pokémons.\nHvis den gør det, genopretter den også deres HP fuldstændigt.</language>
	</row>
	<row id="narc_0343_00045" index="45">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En nærende drik til Pokémon.\nDet øger basis-HP'en for en enkelt\nPokémon.</language>
	</row>
	<row id="narc_0343_00046" index="46">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En nærende drink til Pokémon.\nDet hæver basisangrebsstatistiken for en\nenkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00047" index="47">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En nærende drink til Pokémon.\nDet hæver basisforsvarsstatistiken for en\nenkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00048" index="48">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En nærende drink til Pokémon.\nDet hæver basishastighedsstatistikken for en\nenkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00049" index="49">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En nærende drink til Pokémon.\nDen hæver basen Sp. Atk (Special\nAngreb)-statistik for en enkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00050" index="50">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En sådan, der er fyldt med energi.\nDet hæver niveauet for en enkelt Pokémon\nmed en.</language>
	</row>
	<row id="narc_0343_00051" index="51">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det hæver en smule den maksimale PP for\na valgt træk, som er blevet lært\naf mål-Pokémonen.</language>
	</row>
	<row id="narc_0343_00052" index="52">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En nærende drink til Pokémon.\nDen hæver basen Sp. Def (Special\nDefense)-statistik for en enkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00053" index="53">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det hæver maksimalt den øverste PP i et\nvalgt træk, som er blevet lært\naf mål-Pokémonen.</language>
	</row>
	<row id="narc_0343_00054" index="54">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Old Chateaus skjulte specialitet.\nDet helbreder alle statusproblemer for en\nkelt Pokémon.</language>
	</row>
	<row id="narc_0343_00055" index="55">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der forhindrer statistisk reduktion\nem Træners fest Pokémon\ni fem omgange efter brug.</language>
	</row>
	<row id="narc_0343_00056" index="56">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et element, der øger det kritiske hit\nforhold for en Pokémon i kamp. Den slides\naf, hvis Pokémon'en trækkes tilbage.</language>
	</row>
	<row id="narc_0343_00057" index="57">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et element, der hæver angrebsstaten\n for en Pokémon i kamp. Det forsvinder, hvis\nPokémon'en trækkes tilbage.</language>
	</row>
	<row id="narc_0343_00058" index="58">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et element, der hæver forsvarsstaten\n for en Pokémon i kamp. Det forsvinder, hvis\nPokémon'en trækkes tilbage.</language>
	</row>
	<row id="narc_0343_00059" index="59">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et element, der hæver hastighedsstaten\n for en Pokémon i kamp. Det forsvinder, hvis\nPokémon'en trækkes tilbage.</language>
	</row>
	<row id="narc_0343_00060" index="60">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der øger nøjagtigheden\naf en Pokémon i kamp. Det forsvinder, hvis\nPokémon'en trækkes tilbage.</language>
	</row>
	<row id="narc_0343_00061" index="61">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der hæver Sp. Atk stat\nof en Pokémon i kamp. Det forsvinder, hvis\nPokémon'en trækkes tilbage.</language>
	</row>
	<row id="narc_0343_00062" index="62">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der hæver Sp. Def status\n for en Pokémon i kamp. Det forsvinder, hvis\nPokémon'en trækkes tilbage.</language>
	</row>
	<row id="narc_0343_00063" index="63">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En dukke, der tiltrækker Pokémon.\nBrug den til at flygte fra enhver kamp med en\nvild Pokémon.</language>
	</row>
	<row id="narc_0343_00064" index="64">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En genstand, der tiltrækker Pokémon.\nBrug den til at flygte fra enhver kamp med en\nvild Pokémon.</language>
	</row>
	<row id="narc_0343_00065" index="65">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En blå fløjte lavet af blæst glas.\nDens melodi vækker en enkelt Pokémon\naf søvn.</language>
	</row>
	<row id="narc_0343_00066" index="66">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En gul fløjte lavet af blæst glas.\nDens melodi slår en enkelt Pokémon ud\naf forvirring.</language>
	</row>
	<row id="narc_0343_00067" index="67">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En rød fløjte lavet af blæst glas.\nDens melodi slår en enkelt Pokémon ud\naf forelskelse.</language>
	</row>
	<row id="narc_0343_00068" index="68">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En sort fløjte lavet af blæst glas.\nDens melodi gør vilde Pokémon mindre\nsandsynlige, at de dukker op.</language>
	</row>
	<row id="narc_0343_00069" index="69">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En hvid fløjte lavet af blæst glas.\nDens melodi gør, at vilde Pokémon mere\nsandsynligt dukker op.</language>
	</row>
	<row id="narc_0343_00070" index="70">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Rent salt, der blev opdaget dybt\ninde i Shoal Cave.\nDet er ekstremt salt.</language>
	</row>
	<row id="narc_0343_00071" index="71">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En smuk muslingeskal, der blev fundet dybt\ninde i Shoal Cave.\nDen er stribet i blåt og hvidt.</language>
	</row>
	<row id="narc_0343_00072" index="72">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et lille rødt skår.\nDet ser ud til at være fra en slags\nimplement lavet for længe siden.</language>
	</row>
	<row id="narc_0343_00073" index="73">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et lille blåt skår.\nDet ser ud til at være fra et slags\nimplement lavet for længe siden.</language>
	</row>
	<row id="narc_0343_00074" index="74">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et lille gult skår.\nDet ser ud til at være fra en slags\nudførelse lavet for længe siden.</language>
	</row>
	<row id="narc_0343_00075" index="75">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et lille grønt skår.\nDet ser ud til at være fra en slags\nimplement lavet for længe siden.</language>
	</row>
	<row id="narc_0343_00076" index="76">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et element, der forhindrer svage vilde\nPokémon i at dukke op i 200 trin\nefter dets brug.</language>
	</row>
	<row id="narc_0343_00077" index="77">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et element, der forhindrer svage vilde\nPokémon i at dukke op i 250 trin\nefter dets brug.</language>
	</row>
	<row id="narc_0343_00078" index="78">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et langt, holdbart reb.\nBrug det til at flygte med det samme fra en hule\eller et fangehul.</language>
	</row>
	<row id="narc_0343_00079" index="79">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et element, der forhindrer svage vilde\nPokémon i at dukke op i 100 trin\nefter dets brug.</language>
	</row>
	<row id="narc_0343_00080" index="80">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDen er lige så rød som solen.</language>
	</row>
	<row id="narc_0343_00081" index="81">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDen er lige så sort som nattehimlen.</language>
	</row>
	<row id="narc_0343_00082" index="82">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDen er farvet orange.</language>
	</row>
	<row id="narc_0343_00083" index="83">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDen har et lynmønster.</language>
	</row>
	<row id="narc_0343_00084" index="84">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDet er en klar, lyseblå.</language>
	</row>
	<row id="narc_0343_00085" index="85">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDen har et bladmønster.</language>
	</row>
	<row id="narc_0343_00086" index="86">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En lille og sjælden svamp.\nDen er ret populær blandt visse\nmaniske fansegmenter.</language>
	</row>
	<row id="narc_0343_00087" index="87">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En stor og sjælden svamp.\nDen er meget populær blandt visse\nmaniske fansegmenter.</language>
	</row>
	<row id="narc_0343_00088" index="88">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En lidt lille perle, der funkler\ni en smuk sølvfarve.\nDen kan sælges billigt til butikker.</language>
	</row>
	<row id="narc_0343_00089" index="89">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ganske stor perle, der funkler i en\n smuk sølvfarve. Det kan sælges til en høj pris til butikker.</language>
	</row>
	<row id="narc_0343_00090" index="90">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dejligt, rødfarvet sand med en løs,\nsilkeagtig følelse. Det kan sælges til en høj\npris til butikker.</language>
	</row>
	<row id="narc_0343_00091" index="91">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et skår af en smuk perle, der funkler\ni en rød farve. Det kan sælges til en\nhøj pris til butikker.</language>
	</row>
	<row id="narc_0343_00092" index="92">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En guldklump, der afgiver et\nstrålende skær. Det kan sælges til en\nhøj pris til butikker.</language>
	</row>
	<row id="narc_0343_00093" index="93">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En smuk, hjerteformet skala, der er\nært sjælden. Det lyser svagt i regnbuens\nfarver.</language>
	</row>
	<row id="narc_0343_00094" index="94">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En sød honning med en frodig aroma, der\n vilde Pokémon, når den bruges\ni græs, huler eller på specielle træer.</language>
	</row>
	<row id="narc_0343_00095" index="95">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En plantegødning spredt på blød jord.\nDet fremskynder væksten af ​​​​bær.\nMen det tørrer også jorden hurtigere.</language>
	</row>
	<row id="narc_0343_00096" index="96">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En plantegødning spredt på blød jord.\nDet bremser væksten af ​​​​bær og\nfår jorden til at tørre langsommere.</language>
	</row>
	<row id="narc_0343_00097" index="97">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En plantegødning spredt på blød jord.\nDet forlænger den tid, hvor modne bær\nforbliver på deres planter, før de falder.</language>
	</row>
	<row id="narc_0343_00098" index="98">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En plantegødning spredt på blød jord.\nDet øger antallet af gange, der vokser nye planter, hvor modne planter visnede.</language>
	</row>
	<row id="narc_0343_00099" index="99">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fossil af en gammel Pokémon, der\nlevede i havet. Det ser ud til at være\ndel af en planterod.</language>
	</row>
	<row id="narc_0343_00100" index="100">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fossil af en gammel Pokémon, der\nlevede i havet. Det ser ud til at være\ndel af en klo.</language>
	</row>
	<row id="narc_0343_00101" index="101">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fossil af en gammel Pokémon, der\nlevede i havet. Det ser ud til at være\ndel af en muslingeskal.</language>
	</row>
	<row id="narc_0343_00102" index="102">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fossil af en gammel Pokémon, der\nlevede i havet. Det ser ud til at være\ndel af en skal.</language>
	</row>
	<row id="narc_0343_00103" index="103">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et stykke rav, der indeholder\ngenetisk materiale fra en gammel Pokémon.\nDet er klart med en rødlig farvetone.</language>
	</row>
	<row id="narc_0343_00104" index="104">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fossil fra en forhistorisk Pokémon\n, der levede på jorden. Det ser ud til at\nvære en del af et halsbånd.</language>
	</row>
	<row id="narc_0343_00105" index="105">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et fossil fra en forhistorisk Pokémon\n, der levede på jorden. Det ser ud til at\nvære en del af et hoved.</language>
	</row>
	<row id="narc_0343_00106" index="106">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En knogle, der er ekstremt værdifuld for\nPokémon-arkæologi. Det kan sælges\ntil en høj pris til butikker.</language>
	</row>
	<row id="narc_0343_00107" index="107">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDen skinner med et blændende lys.</language>
	</row>
	<row id="narc_0343_00108" index="108">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDet er så mørkt, som mørkt kan være.</language>
	</row>
	<row id="narc_0343_00109" index="109">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDen funkler som øjne.</language>
	</row>
	<row id="narc_0343_00110" index="110">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En ejendommelig sten, der får visse\narter af Pokémon til at udvikle sig.\nDen er formet som et æg.</language>
	</row>
	<row id="narc_0343_00111" index="111">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En vigtig genstand, der er nødvendig for at forhindre et stentårn i at kollapse. Stemmer\nkan høres fra den af ​​​​og til.</language>
	</row>
