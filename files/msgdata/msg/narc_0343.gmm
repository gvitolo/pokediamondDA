	<row id="narc_0343_00135" index="135">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En lysende kugle, der skal holdes af\nDIALGA. Det øger kraften i træk af Drage-\n- og Stål-typen.</language>
	</row>
	<row id="narc_0343_00136" index="136">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En smukt glødende kugle, som skal holdes af\nPALKIA. Det øger kraften i træk af drage-\n- og vand-typen.</language>
	</row>
	<row id="narc_0343_00137" index="137">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brevpapir med et print af et\nforfriskende grønt felt.\nLad en Pokémon holde det til levering.</language>
	</row>
	<row id="narc_0343_00138" index="138">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brevpapir med et print af flammer\ni flammende rødt.\nLad en Pokémon holde det til levering.</language>
	</row>
	<row id="narc_0343_00139" index="139">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Brevpapir med et tryk af en blå\nverden under vandet.\nLad en Pokémon holde den til levering.</language>
	</row>
