	<row id="narc_0593_00023" index="23">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ved at udveksle vennekoder\nmed andre spillere, kan du evt\nhandle og kæmpe med dem\nover Nintendo WFC.</language>
	</row>
	<row id="narc_0593_00024" index="24">
		<attribute name="window_context_name">used</attribute>
		<language name="English">For at få din vennekode,\nlog venligst på\nNintendo WFC.</language>
	</row>
	<row id="narc_0593_00025" index="25">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 53, 1} {STRVAR_1 53, 2} {STRVAR_1 53, 3}\n{STRVAR_1 3, 0} vil blive registreret.</language>
	</row>
	<row id="narc_0593_00026" index="26">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vennekoden er forkert.\n{STRVAR_1 53, 1} {STRVAR_1 53, 2} {STRVAR_1 53, 3}</language>
	</row>
	<row id="narc_0593_00027" index="27">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 53, 1} {STRVAR_1 53, 2} {STRVAR_1 53, 3}</language>
	</row>
	<row id="narc_0593_00028" index="28">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0} vil blive slettet.\nEr du sikker på dette?</language>
	</row>
	<row id="narc_0593_00029" index="29">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Din venneliste er fuld!</language>
	</row>
	<row id="narc_0593_00030" index="30">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den vennekode har allerede været\nregistreret før.</language>
	</row>
	<row id="narc_0593_00031" index="31">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{STRVAR_1 3, 0}s vennekode:\n{STRVAR_1 53, 1} {STRVAR_1 53, 2} {STRVAR_1 53, 3}</language>
	</row>
	<row id="narc_0593_00032" index="32">
