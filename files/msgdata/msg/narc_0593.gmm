	</row>
	<row id="narc_0593_00033" index="33">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Register {STRVAR_1 3, 0} i din\nPal Pad?</language>
	</row>
	<row id="narc_0593_00034" index="34">
		<attribute name="window_context_name">used</attribute>
