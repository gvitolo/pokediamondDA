	<row id="narc_0193_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dansekonkurrencen er klar til at\ngå i gang!\rKan backupdanserne fejlfrit\nfølge hoveddanserens trin?!\rOK! Alle sammen, lad os danse!\nStart musikken!\r</language>
	</row>
	<row id="narc_0193_00009" index="9">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 2}Udfør {STRVAR_1 50, 0} trin som hoveddanser!{COLOR 0}</language>
	</row>
	<row id="narc_0193_00010" index="10">
		<attribute name="window_context_name">used</attribute>
		<language name="English">{COLOR 1}Kopiér Pokémon’en før dig!{COLOR 0}</language>
