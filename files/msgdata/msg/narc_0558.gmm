	<row id="narc_0558_02213" index="2213">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ll battle against people who’ve\nbeaten me again and again.\rBy doing that, we both grow a little\nas Trainers.\r</language>
	</row>
	<row id="narc_0558_02214" index="2214">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du vandt og jeg tabte, men begge dele\ndet har vi fået noget ud af.\n</language>
	</row>
	<row id="narc_0558_02215" index="2215">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ll battle against people who’ve\nbeaten me again and again.\rBy doing that, we both grow a little\nas Trainers.\r</language>
	</row>
	<row id="narc_0558_02216" index="2216">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du vandt og jeg tabte, men begge dele\ndet har vi fået noget ud af.\n</language>
	</row>
	<row id="narc_0558_02217" index="2217">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, det er dig igen!\rJeg har fået min selvtillid tilbage.\nLad os tage endnu en kamp!\r</language>
	</row>
	<row id="narc_0558_02218" index="2218">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You made me lose my confidence...\n</language>
	</row>
	<row id="narc_0558_02219" index="2219">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, det er dig igen!\rJeg har fået min selvtillid tilbage.\nLad os tage endnu en kamp!\r</language>
	</row>
	<row id="narc_0558_02220" index="2220">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You made me lose my confidence...\n</language>
	</row>
	<row id="narc_0558_02221" index="2221">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Knowing you to be an expert,\nI challenge you to a rematch!\r</language>
	</row>
	<row id="narc_0558_02222" index="2222">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I can see why you’re an expert...\n</language>
	</row>
	<row id="narc_0558_02223" index="2223">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Knowing you to be an expert,\nI challenge you to a rematch!\r</language>
	</row>
	<row id="narc_0558_02224" index="2224">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I can see why you’re an expert...\n</language>
	</row>
	<row id="narc_0558_02225" index="2225">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Why would you wander around here?\nYou must really like it here.\r</language>
	</row>
	<row id="narc_0558_02226" index="2226">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The winds of victory shifted...\n</language>
	</row>
	<row id="narc_0558_02227" index="2227">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Why would you wander around here?\nYou must really like it here.\r</language>
	</row>
	<row id="narc_0558_02228" index="2228">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The winds of victory shifted...\n</language>
	</row>
	<row id="narc_0558_02229" index="2229">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh? I’ve seen your face before.\nWhat say we battle?\r</language>
	</row>
	<row id="narc_0558_02230" index="2230">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvad? Det er slut, siger du?\n</language>
	</row>
	<row id="narc_0558_02231" index="2231">
		<attribute name="window_context_name">used</attribute>
		<language name="English">We’ll come at you with our hearts\nablaze!\r</language>
	</row>
	<row id="narc_0558_02232" index="2232">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Your heart burns as hot as mine!\n</language>
	</row>
	<row id="narc_0558_02233" index="2233">
		<attribute name="window_context_name">used</attribute>
		<language name="English">This isn’t like last time. See how\nmuch I’ve trained since then!\r</language>
	</row>
	<row id="narc_0558_02234" index="2234">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Whew...\nYou’re overtrained for me.\n</language>
	</row>
	<row id="narc_0558_02235" index="2235">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg vidste, du var på vej tilbage hertil.\nJeg mærkede det med mine fodsåler!\r</language>
	</row>
	<row id="narc_0558_02236" index="2236">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I got a good taste of your power!\n</language>
	</row>
	<row id="narc_0558_02237" index="2237">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg vidste, du var på vej tilbage hertil.\nJeg mærkede det med mine fodsåler!\r</language>
	</row>
	<row id="narc_0558_02238" index="2238">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I got a good taste of your power!\n</language>
	</row>
	<row id="narc_0558_02239" index="2239">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You really must like snow.\rAfter all, if you didn’t, I doubt that\nyou’d come here so often!\r</language>
	</row>
	<row id="narc_0558_02240" index="2240">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The conditions weren’t very good.\n</language>
	</row>
	<row id="narc_0558_02241" index="2241">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You really must like snow.\rAfter all, if you didn’t, I doubt that\nyou’d come here so often!\r</language>
	</row>
	<row id="narc_0558_02242" index="2242">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The conditions weren’t very good.\n</language>
	</row>
	<row id="narc_0558_02243" index="2243">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Super outdoor fishing!\nShouting still doesn’t help!\r</language>
	</row>
	<row id="narc_0558_02244" index="2244">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gwaaah!\nThis is hurting!\n</language>
	</row>
	<row id="narc_0558_02245" index="2245">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Rock ’n’ roll!\nWe’ll beat it out again!\fOur rhythm of battle!\r</language>
	</row>
	<row id="narc_0558_02246" index="2246">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Can you hear it?\nThat’s my guitar weeping...\n</language>
	</row>
	<row id="narc_0558_02247" index="2247">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Last time, you beat me before I had\na chance to show you my skill.\rThis time, I’ll shows you why they\nconsider me an ace!\r</language>
	</row>
	<row id="narc_0558_02248" index="2248">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m burning with jealousy over your\ntalent!\n</language>
	</row>
	<row id="narc_0558_02249" index="2249">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ace Trainers always work to improve\ntheir natural-born talents.\r</language>
	</row>
	<row id="narc_0558_02250" index="2250">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I see...\nI have to concede defeat.\n</language>
	</row>
	<row id="narc_0558_02251" index="2251">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pal Park, huh? I wonder what kinds\nof Pokémon you can see there?\r</language>
	</row>
	<row id="narc_0558_02252" index="2252">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re one enthusiastic Trainer.\n</language>
	</row>
	<row id="narc_0558_02253" index="2253">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hi, traveler!\rI’ve forgotten your name, but we’ve\nbattled before, haven’t we?\r</language>
	</row>
	<row id="narc_0558_02254" index="2254">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You sure showed me up.\n</language>
	</row>
	<row id="narc_0558_02255" index="2255">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, vi rider på havet,\ni en båd, kun dig og mig!\rSådan er sømandens måde!\nSømandens vej. Du synger også!\r</language>
	</row>
	<row id="narc_0558_02256" index="2256">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Din Pokémon...\nDe ser gode ud!\n</language>
	</row>
	<row id="narc_0558_02257" index="2257">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, vi rider på havet,\ni en båd, kun dig og mig!\rSådan er sømandens måde!\nSømandens vej. Du synger også!\r</language>
	</row>
	<row id="narc_0558_02258" index="2258">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Din Pokémon...\nDe ser gode ud!\n</language>
	</row>
	<row id="narc_0558_02259" index="2259">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ah, det er dig. Jeg keder mig igen.\nVil du bryde monotonien?\r</language>
	</row>
	<row id="narc_0558_02260" index="2260">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The monotony was broken, but...\n</language>
	</row>
	<row id="narc_0558_02261" index="2261">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ah, det er dig. Jeg keder mig igen.\nVil du bryde monotonien?\r</language>
	</row>
	<row id="narc_0558_02262" index="2262">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The monotony was broken, but...\n</language>
	</row>
	<row id="narc_0558_02263" index="2263">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg har trænet her i håb om\ngår til Pokémon League.\r</language>
	</row>
	<row id="narc_0558_02264" index="2264">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m shocked...\nNo, really.\n</language>
	</row>
	<row id="narc_0558_02265" index="2265">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg har bestemt mig! Hvis jeg endelig slår dig,\nJeg udfordrer Pokémon League!\r</language>
	</row>
	<row id="narc_0558_02266" index="2266">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Bblblblugh...\n</language>
	</row>
	<row id="narc_0558_02267" index="2267">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er mig igen! Det barske hav her\nskulle have skærpet mig op!\r</language>
	</row>
	<row id="narc_0558_02268" index="2268">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The world remains as harsh as\never...\n</language>
	</row>
	<row id="narc_0558_02269" index="2269">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er lige meget hvor lang tid det tager,\nJeg skal til Pokémon League!\r</language>
	</row>
	<row id="narc_0558_02270" index="2270">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det her er så svært...\n</language>
	</row>
	<row id="narc_0558_02271" index="2271">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvor meget stærkere gjorde din Pokémon\nblive?\rLad mig tjekke for dig, okay?\r</language>
	</row>
	<row id="narc_0558_02272" index="2272">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ve had my fill...\n</language>
	</row>
	<row id="narc_0558_02273" index="2273">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My dragon Pokémon chose to remain\nhere to become powerful.\r</language>
	</row>
	<row id="narc_0558_02274" index="2274">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Your battle style...\n</language>
	</row>
	<row id="narc_0558_02275" index="2275">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Why have you come back to this spot?\nI want to know what all this means!\r</language>
	</row>
	<row id="narc_0558_02276" index="2276">
		<attribute name="window_context_name">used</attribute>
		<language name="English">jeg ser...\rSå det var hvad det var...\n</language>
	</row>
	<row id="narc_0558_02277" index="2277">
		<attribute name="window_context_name">used</attribute>
		<language name="English">See?\nYou’ve come back again.\rThere must be something that draws\nyou here...\r</language>
	</row>
	<row id="narc_0558_02278" index="2278">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kraft, der slumrer i dig...\nDet er ret fantastisk...\n</language>
	</row>
	<row id="narc_0558_02279" index="2279">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I am indeed a Veteran, but I don’t\nuse that as an excuse to slack off.\rI take pride in challenging those\nwho have bested me before!\r</language>
	</row>
	<row id="narc_0558_02280" index="2280">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I see...\nSimply outstanding.</language>
	</row>
	<row id="narc_0558_02281" index="2281">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I let my bird Pokémon do as they\nwish. And so, we train here daily!\r</language>
	</row>
	<row id="narc_0558_02282" index="2282">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sheesh... Jeg ankommer et nyt sted og\ndet viser sig at være Battle Zone...\n</language>
	</row>
	<row id="narc_0558_02283" index="2283">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ve cranked up my dragon Pokémon’s\nabilities!\rI’ve been looking forward to seeing\nyou again!\r</language>
	</row>
	<row id="narc_0558_02284" index="2284">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Raising abilities alone doesn’t mean\nI can win either...\n</language>
	</row>
	<row id="narc_0558_02285" index="2285">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What’s missing from my game...\nHave you discovered yours yet?\r</language>
	</row>
	<row id="narc_0558_02286" index="2286">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg ser det nu...\n</language>
	</row>
	<row id="narc_0558_02287" index="2287">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The urge to battle you again has\nstruck me. Humor me!\r</language>
	</row>
	<row id="narc_0558_02288" index="2288">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I shouldn’t have paid attention\nto my urge...\n</language>
	</row>
	<row id="narc_0558_02289" index="2289">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi har stået over for mange udfordrere siden\nvi mødtes, men de var alle svage...\rJeg nyder den hårde modstand\nkun du kan yde!\r</language>
	</row>
	<row id="narc_0558_02290" index="2290">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ve found a tough adversary in\nyou...\n</language>
	</row>
	<row id="narc_0558_02291" index="2291">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hello again! Please don’t hold\nanything back, just like before.\r</language>
	</row>
	<row id="narc_0558_02292" index="2292">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hmm...\n</language>
	</row>
	<row id="narc_0558_02293" index="2293">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du kommer til at vinde igen!\nDet er den fremtid, jeg så!\r</language>
	</row>
	<row id="narc_0558_02294" index="2294">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det, jeg så i fremtiden, viste sig\nat være sandt...\n</language>
	</row>
	<row id="narc_0558_02295" index="2295">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Right after this, you will hurl a Poké\nBall in an astonishingly cool manner!\r</language>
	</row>
	<row id="narc_0558_02296" index="2296">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Right after this, I have to pay\nout your prize money...\n</language>
	</row>
	<row id="narc_0558_02297" index="2297">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Denne gang! Denne gang vinder jeg!\nMin ånd er fornyet og stærk!\r</language>
	</row>
	<row id="narc_0558_02298" index="2298">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My spirit is broken...\n</language>
	</row>
	<row id="narc_0558_02299" index="2299">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Kan du huske mit slogan?\nMennesker! Natur! Pokémon!\rDet er rigtigt. Harmoni er afgørende!\r</language>
	</row>
	<row id="narc_0558_02300" index="2300">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re A-OK!\n</language>
	</row>
	<row id="narc_0558_02301" index="2301">
		<attribute name="window_context_name">used</attribute>
		<language name="English">By battling tough opponents, both\npeople and Pokémon grow tough!\r</language>
	</row>
	<row id="narc_0558_02302" index="2302">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Min, du er hård.\n</language>
	</row>
	<row id="narc_0558_02303" index="2303">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Yo, Pokémon-riding Trainer!\nHow about a rematch?\r</language>
	</row>
	<row id="narc_0558_02304" index="2304">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Awesome!\nYou’re a real wild child!\n</language>
	</row>
	<row id="narc_0558_02305" index="2305">
		<attribute name="window_context_name">used</attribute>
		<language name="English">People still keep coming to us for\nbattles! Why?!\r</language>
	</row>
	<row id="narc_0558_02306" index="2306">
		<attribute name="window_context_name">used</attribute>
		<language name="English">OK, vi tabte.\n</language>
	</row>
	<row id="narc_0558_02307" index="2307">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_02308" index="2308">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_02309" index="2309">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Does this mean I’m only talented as\nan Artist?\n</language>
	</row>
	<row id="narc_0558_02310" index="2310">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re a lucky one...\n</language>
	</row>
	<row id="narc_0558_02311" index="2311">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I never thought I’d lose at\nPapa’s restaurant...\n</language>
	</row>
	<row id="narc_0558_02312" index="2312">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ohh... How could I lose at dear\nPapa’s restaurant?\n</language>
	</row>
	<row id="narc_0558_02313" index="2313">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ack! I lost...\nCheck, please!\n\n</language>
	</row>
	<row id="narc_0558_02314" index="2314">
		<attribute name="window_context_name">used</attribute>
		<language name="English">So young, and yet so strong!\nHow very remarkable!</language>
	</row>
	<row id="narc_0558_02315" index="2315">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I don’t care if I lose.\nI’m still a happy guy.\n</language>
	</row>
	<row id="narc_0558_02316" index="2316">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Waaah! You’re too much!\n</language>
	</row>
	<row id="narc_0558_02317" index="2317">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wow... You’re out there.\n</language>
	</row>
	<row id="narc_0558_02318" index="2318">
		<attribute name="window_context_name">used</attribute>
		<language name="English">ingen er kommet til skade?\n</language>
	</row>
	<row id="narc_0558_02319" index="2319">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Tough, aren’t you...?\n</language>
	</row>
	<row id="narc_0558_02320" index="2320">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg var også sammen med min far...\n</language>
	</row>
	<row id="narc_0558_02321" index="2321">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er noget af demonstrationen.\n</language>
	</row>
	<row id="narc_0558_02322" index="2322">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hmm...\nI should have expected this.</language>
	</row>
	<row id="narc_0558_02323" index="2323">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My luck’s run out...\n</language>
	</row>
	<row id="narc_0558_02324" index="2324">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I think I have what it takes to\nbecome a successful model!\n</language>
	</row>
	<row id="narc_0558_02325" index="2325">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hmm... I failed to foresee this\noutcome...\n</language>
	</row>
	<row id="narc_0558_02326" index="2326">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You know, I had confidence before\nheading into this.\n</language>
	</row>
	<row id="narc_0558_02327" index="2327">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Yeah, like I’m really supposed to\nwin with a Pokémon like this...</language>
	</row>
	<row id="narc_0558_02328" index="2328">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi bruger al vores tid på at kæmpe i\nsnestorme i Snowpoint City.\rVi viser dig, hvordan det er hærdet\nos op!\r</language>
	</row>
	<row id="narc_0558_02329" index="2329">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What’s with your toughness?!\n</language>
	</row>
	<row id="narc_0558_02330" index="2330">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’ve battled all over, you say?\nThat makes you tough, perhaps.\n</language>
	</row>
	<row id="narc_0558_02331" index="2331">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ve only been involved with Pokémon\nfor a short time.\rI managed to get this far because\nskilled friends toughened me up!\r</language>
	</row>
	<row id="narc_0558_02332" index="2332">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg kan ikke tro, hvor hård du er!\n</language>
	</row>
	<row id="narc_0558_02333" index="2333">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis du har fantastiske venner, der\ner ingen grænse for, hvor langt du kan gå.\n</language>
	</row>
	<row id="narc_0558_02334" index="2334">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vores mission er at implementere vores\noperationer uden spørgsmål.\rDet hele er for den nye verdensorden\nat vores chef vil lede!\r</language>
	</row>
	<row id="narc_0558_02335" index="2335">
		<attribute name="window_context_name">used</attribute>
		<language name="English">This won’t go unpunished...\n</language>
	</row>
	<row id="narc_0558_02336" index="2336">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m quite prepared to do anything\nto be promoted.\rOne day, and soon, you will learn\nthe true might of Team Galactic!\n</language>
	</row>
	<row id="narc_0558_02337" index="2337">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg vil ikke lade dig forstyrre vores forskning!\nDette er for Team Galactic!\r</language>
	</row>
	<row id="narc_0558_02338" index="2338">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I got whipped...\nI look pathetic...\n</language>
	</row>
	<row id="narc_0558_02339" index="2339">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vores chef er et videnskabeligt geni!\rHan vil gøre magten til mytisk\nhans egen Pokémon!\n</language>
	</row>
	<row id="narc_0558_02340" index="2340">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hej nu! Vores hovedkvarter er en state-of-the-\nkunst facilitet!\rEn snotnæse knægt som du burde\nhold dine beskidte hænder for dig selv!\r</language>
	</row>
	<row id="narc_0558_02341" index="2341">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du og din Pokémon var ikke en del\naf mine beregninger...\n</language>
	</row>
	<row id="narc_0558_02342" index="2342">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Our boss is trying to create an\nentirely new world.\rA world only for us!\nFor Team Galactic!\n</language>
	</row>
	<row id="narc_0558_02343" index="2343">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Bika bikabika!\nPigachu!\r</language>
	</row>
	<row id="narc_0558_02344" index="2344">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pikachu...\n</language>
	</row>
	<row id="narc_0558_02345" index="2345">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pika...\rI’ll need a lot more practice to\nbecome a real PIKACHU...\n</language>
	</row>
	<row id="narc_0558_02346" index="2346">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I work at a red-hot foundry.\nWatch out, I’m on fire!\r</language>
	</row>
	<row id="narc_0558_02347" index="2347">
		<attribute name="window_context_name">used</attribute>
		<language name="English">jeg brændte ud...\n</language>
	</row>
	<row id="narc_0558_02348" index="2348">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I toughened up my muscles from\nhonest work.\rPokémon have nothing on me!\n</language>
	</row>
	<row id="narc_0558_02349" index="2349">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Godt! Det er ikke tit, vi får besøg\nsom dig til jernværket!\rLad os markere lejligheden med\nen kamp!\r</language>
	</row>
	<row id="narc_0558_02350" index="2350">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fire!\n</language>
	</row>
	<row id="narc_0558_02351" index="2351">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The floor panels move automatically.\nWe’re pretty proud of them here!\n</language>
	</row>
	<row id="narc_0558_02352" index="2352">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Bliver du måske irriteret over\nhvor fører gulvpanelerne dig hen?\r</language>
	</row>
	<row id="narc_0558_02353" index="2353">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m going down in flames!\n</language>
	</row>
	<row id="narc_0558_02354" index="2354">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En arbejdende mands sved er\nsmukt at se...\rDer er også skønhed i tårerne\ngræd af nederlag...\n</language>
	</row>
	<row id="narc_0558_02355" index="2355">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den hårdeste af alle gryntene!\nDet var mig...\n</language>
	</row>
	<row id="narc_0558_02356" index="2356">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Arrgh!\nI let some little kid beat me!\n</language>
	</row>
	<row id="narc_0558_02357" index="2357">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sheesh... I should have done the\nfighting myself.\n</language>
	</row>
	<row id="narc_0558_02358" index="2358">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Humph! You’ve toughened up.\nBut you’re no match for our boss.\n</language>
	</row>
	<row id="narc_0558_02359" index="2359">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Done in by two kids?!\nThis isn’t right!\n</language>
	</row>
	<row id="narc_0558_02360" index="2360">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I should have kept my head down and\njust watched our warehouse...\n</language>
	</row>
	<row id="narc_0558_02361" index="2361">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fweh... If I didn’t run...\nI could’ve...battled harder...\n</language>
	</row>
	<row id="narc_0558_02362" index="2362">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My last Pokémon.\n</language>
	</row>
	<row id="narc_0558_02363" index="2363">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I see... I may lose if this pace\ncontinues...\n</language>
	</row>
	<row id="narc_0558_02364" index="2364">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Interesting.\nAnd quite curious.\n</language>
	</row>
	<row id="narc_0558_02365" index="2365">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg indrømmer, at du har presset mig\ntil dette yderste.\n</language>
	</row>
	<row id="narc_0558_02366" index="2366">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dette... Det kan ikke være!\nDet er ikke muligt, at jeg taber!\n</language>
	</row>
	<row id="narc_0558_02367" index="2367">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I won’t accept this!\nThe power spoken of in mythology...\rI didn’t just make it obey me,\nI made it my own!\n</language>
	</row>
	<row id="narc_0558_02368" index="2368">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I feel like crying...\nThis is so sad...\n</language>
	</row>
	<row id="narc_0558_02369" index="2369">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What a tough combination!\nI can’t believe it!\n</language>
	</row>
	<row id="narc_0558_02370" index="2370">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, ja? Når det bliver hårdt,\nmine Pokémon bliver hårdere!\n</language>
	</row>
	<row id="narc_0558_02371" index="2371">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What just went down?!\nYou’re telling me I lost again?!\n</language>
	</row>
	<row id="narc_0558_02372" index="2372">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, ja? Når det bliver hårdt,\nmine Pokémon bliver hårdere!\n</language>
	</row>
	<row id="narc_0558_02373" index="2373">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What just went down?!\nYou’re telling me I lost again?!\n</language>
	</row>
	<row id="narc_0558_02374" index="2374">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, ja? Når det bliver hårdt,\nmine Pokémon bliver hårdere!\n</language>
	</row>
	<row id="narc_0558_02375" index="2375">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What just went down?!\nYou’re telling me I lost again?!\n</language>
	</row>
	<row id="narc_0558_02376" index="2376">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg giver ikke op før slutningen!\nJeg kan ikke give op!\n</language>
	</row>
	<row id="narc_0558_02377" index="2377">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What just went down?!\nYou wait! I’ll get tougher!\n</language>
	</row>
	<row id="narc_0558_02378" index="2378">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg giver ikke op før slutningen!\nJeg kan ikke give op!\n</language>
	</row>
	<row id="narc_0558_02379" index="2379">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What just went down?!\nYou wait! I’ll get tougher!\n</language>
	</row>
	<row id="narc_0558_02380" index="2380">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg giver ikke op før slutningen!\nJeg kan ikke give op!\n</language>
	</row>
	<row id="narc_0558_02381" index="2381">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What just went down?!\nYou wait! I’ll get tougher!\n</language>
	</row>
	<row id="narc_0558_02382" index="2382">
		<attribute name="window_context_name">used</attribute>
		<language name="English">If I battle now, won’t it mess up my\nusual pace?\r</language>
	</row>
	<row id="narc_0558_02383" index="2383">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My pace is completely off...\n</language>
	</row>
