	<row id="narc_0558_01083" index="1083">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01084" index="1084">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01085" index="1085">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01086" index="1086">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01087" index="1087">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01088" index="1088">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01089" index="1089">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01090" index="1090">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01091" index="1091">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You... One look at you tells me\nyou’re a real contender!\r</language>
	</row>
	<row id="narc_0558_01092" index="1092">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re as tough as you look.</language>
	</row>
	<row id="narc_0558_01093" index="1093">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den ene dag vil folk løbe hen til den anden\nside af vejen, når jeg går forbi dem.\rDet er mit mål, jeg arbejder på.</language>
	</row>
	<row id="narc_0558_01094" index="1094">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Victory Road... På en eller anden måde føles det som\nhvis min rejse nu er ved at være slut.\rMen før det sidste kapitel er\nskrevet, jeg må skrive dit nederlag!\r</language>
	</row>
	<row id="narc_0558_01095" index="1095">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det var ikke sådan, jeg planlagde finalen\nkapitel at gå i min skrivetime...</language>
	</row>
	<row id="narc_0558_01096" index="1096">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis du ikke giver op, kan du nå\ndit mål.\rDen vedholdenhed er det, der er vigtigt\ntil trænere. Det står også i min bog.</language>
	</row>
	<row id="narc_0558_01097" index="1097">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vis mig, hvordan du har kæmpet for at komme\nher! Lad os gøre dette!\r</language>
	</row>
	<row id="narc_0558_01098" index="1098">
		<attribute name="window_context_name">used</attribute>
		<language name="English">So, that’s how you battled...?\n</language>
	</row>
	<row id="narc_0558_01099" index="1099">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Once you emerge from Victory Road,\nthe Pokémon League lies directly\fahead...\rBut many Trainers fail to ever find\ntheir way on Victory Road...\n</language>
	</row>
	<row id="narc_0558_01100" index="1100">
		<attribute name="window_context_name">used</attribute>
		<language name="English">This total stranger’ll be a good way\nto see if I have what it takes to own\fthe Pokémon League’s Elite Four!\r</language>
	</row>
	<row id="narc_0558_01101" index="1101">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kamp lige nu må gøre dig\nhårdere end alle andre i verden.\n</language>
	</row>
	<row id="narc_0558_01102" index="1102">
		<attribute name="window_context_name">used</attribute>
		<language name="English">It doesn’t appear as if anyone could\neven try to stand against your might.\rThe Elite Four should just surrender.</language>
	</row>
	<row id="narc_0558_01103" index="1103">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg kan fornemme, at din Pokémon har\nstor tillid til dig.\rDig og din Pokémon...\nDu ser ud til at være glødende.\r</language>
	</row>
	<row id="narc_0558_01104" index="1104">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ah, I understand it now!\n</language>
	</row>
	<row id="narc_0558_01105" index="1105">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You blaze with so much vitality!\n</language>
	</row>
	<row id="narc_0558_01106" index="1106">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lad mig tage et mål for hvor meget\ndu har rejst din Pokémon!\r</language>
	</row>
	<row id="narc_0558_01107" index="1107">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Strålende!\n</language>
	</row>
	<row id="narc_0558_01108" index="1108">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I stedet for at navigere Victory Road,\nJeg har meget bedre tid til at lægge\funge trænere kan lide dig på prøve.\n</language>
	</row>
	<row id="narc_0558_01109" index="1109">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m making an already-strong Pokémon\ngrow even stronger.\rI’ll need your help with this!\r</language>
	</row>
	<row id="narc_0558_01110" index="1110">
		<attribute name="window_context_name">used</attribute>
		<language name="English">There’s no way I could have won!\n</language>
	</row>
	<row id="narc_0558_01111" index="1111">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvordan skal jeg nu lære det mest\nkraftfulde dragebevægelser...? Godt?\n</language>
	</row>
	<row id="narc_0558_01112" index="1112">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Trænere på topniveau samles om dette\nsted naturligt.\rJeg vil gå så langt som at kalde det idealet\nsted at træne med de bedste!\r</language>
	</row>
	<row id="narc_0558_01113" index="1113">
		<attribute name="window_context_name">used</attribute>
		<language name="English">That’s why I like it here; I get to\nbattle tough characters like you.\n</language>
	</row>
	<row id="narc_0558_01114" index="1114">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Når to veje adskiller sig, skal du\nvælg den mindre tilbagelagte vej...\n</language>
	</row>
	<row id="narc_0558_01115" index="1115">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Min Pokémon kan karate!\nJeg advarer dig, det er en hård en!\r</language>
	</row>
	<row id="narc_0558_01116" index="1116">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ve met my match in strength!\n</language>
	</row>
	<row id="narc_0558_01117" index="1117">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg er nået så langt i livet ved at bruge\nkarate jeg lærte på internettet!\n</language>
	</row>
	<row id="narc_0558_01118" index="1118">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg bliver ved med at kæmpe, så jeg kan svæve\nstadig højere op i himlen!\r</language>
	</row>
	<row id="narc_0558_01119" index="1119">
		<attribute name="window_context_name">used</attribute>
		<language name="English">It seems I’ve been grounded...\n</language>
	</row>
	<row id="narc_0558_01120" index="1120">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Frihedens vinger...\rJeg ved, at jeg finder dem, hvis jeg kan vinde\nmin vej gennem Pokémon League...\n</language>
	</row>
	<row id="narc_0558_01121" index="1121">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vær advaret, dødelige!\nJeg kan se fremtiden!\r</language>
	</row>
	<row id="narc_0558_01122" index="1122">
		<attribute name="window_context_name">used</attribute>
		<language name="English">So be it! I will now divulge what\nI know of your future... Hmm!\n</language>
	</row>
	<row id="narc_0558_01123" index="1123">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I Pokémon League forude er\nElite Four venter på dig!\rMen det vidste du allerede.\n</language>
	</row>
	<row id="narc_0558_01124" index="1124">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg kan se fortiden!\r</language>
	</row>
	<row id="narc_0558_01125" index="1125">
		<attribute name="window_context_name">used</attribute>
		<language name="English">There’s just so much in your past...\n</language>
	</row>
	<row id="narc_0558_01126" index="1126">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Har du...\nMødte du en legendarisk Pokémon?\rNej. Det kan ikke være rigtigt...\n</language>
	</row>
	<row id="narc_0558_01127" index="1127">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pat: Det er et doublehold af esser!\nVi vil overvælde dig!\r</language>
	</row>
	<row id="narc_0558_01128" index="1128">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pat: Du og din Pokémon vil vinde\nmagt ved at hjælpe hinanden.\n</language>
	</row>
	<row id="narc_0558_01129" index="1129">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pat: Kombinationen af ​​dig og\ndin fantastiske Pokémon...\rDet er det ultimative tag-team!\n</language>
	</row>
	<row id="narc_0558_01130" index="1130">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pat: If you don’t mind, we’re hoping\nfor some two-on-two battle action.\n</language>
	</row>
	<row id="narc_0558_01131" index="1131">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jo: We form a combination that’s\nin perfect sync!\rHow do you expect to counter that?\r</language>
	</row>
	<row id="narc_0558_01132" index="1132">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jo: Du og din Pokémon laver\nen smuk kombination!\n</language>
	</row>
	<row id="narc_0558_01133" index="1133">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jo: Ja, den måde du kæmper på er\nfantastisk!\rDu bør prøve at tage Elite Four\nlige nu - ikke senere!\n</language>
	</row>
	<row id="narc_0558_01134" index="1134">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jo: Vi vil have en kamp\nuden fordel.\rVenligst vend tilbage, når du har\nmindst to Pokémon!\n</language>
	</row>
	<row id="narc_0558_01135" index="1135">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Al: I intend to perfect my Double\nBattle technique.\rThat will make me better all around.\r</language>
	</row>
	<row id="narc_0558_01136" index="1136">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Al: You! You’re an expert\ndouble battler, too!\n</language>
	</row>
	<row id="narc_0558_01137" index="1137">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Al: Your mastery over several\nPokémon at once...\rYou’re a remarkable Trainer!\n</language>
	</row>
	<row id="narc_0558_01138" index="1138">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Al: Har du kun én Pokémon?\rJeg vil sige, at du tager\nVictory Road for let, knægt.\n</language>
	</row>
	<row id="narc_0558_01139" index="1139">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Kay: I want to improve my doubles\ntechnique as much as I can.\rThat will improve me as a Trainer.\r</language>
	</row>
	<row id="narc_0558_01140" index="1140">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Kay: My goodness!\nYou’re great at doubles, too!</language>
	</row>
	<row id="narc_0558_01141" index="1141">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Kay: Afhængigt af kombinationerne,\nenhver slags Pokémon kan udmærke sig.\rDet er i hvert fald, hvad jeg synes.\n</language>
	</row>
	<row id="narc_0558_01142" index="1142">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Kay: You’re really going through\nVictory Road with only one Pokémon?\n</language>
	</row>
	<row id="narc_0558_01143" index="1143">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi undervisere vil tage imod udfordringer\nhvor som helst! Det er, hvad vi gør.\r</language>
	</row>
	<row id="narc_0558_01144" index="1144">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hmm...\nInsufficiently raised?\n</language>
	</row>
	<row id="narc_0558_01145" index="1145">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gee... When you’re in a cave, wild\nPokémon can appear anytime!\n</language>
	</row>
	<row id="narc_0558_01146" index="1146">
		<attribute name="window_context_name">used</attribute>
		<language name="English">To celebrate my getting through this\ncave, I’m going to battle you!\r</language>
	</row>
	<row id="narc_0558_01147" index="1147">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Well, I guess losing is something\nto commemorate, too...\n</language>
	</row>
	<row id="narc_0558_01148" index="1148">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Getting through that cave feels\nlike an adventure.\n</language>
	</row>
	<row id="narc_0558_01149" index="1149">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m a Veteran, yes, but don’t you\ndare treat me like a senior citizen!\r</language>
	</row>
	<row id="narc_0558_01150" index="1150">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hnuuurgh...\nSo much skill for one so young!\n</language>
	</row>
	<row id="narc_0558_01151" index="1151">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ll always remain young at heart.\nNever let them say you’re too old!\n</language>
	</row>
	<row id="narc_0558_01152" index="1152">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01153" index="1153">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01154" index="1154">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01155" index="1155">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01156" index="1156">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01157" index="1157">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01158" index="1158">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01159" index="1159">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01160" index="1160">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01161" index="1161">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, hvad er det her? Min sidste!\nDet er her, vi gør vores standpunkt!\r</language>
	</row>
	<row id="narc_0558_01162" index="1162">
		<attribute name="window_context_name">used</attribute>
		<language name="English">We’re not done yet!\nThere’s no giving up!\n</language>
	</row>
	<row id="narc_0558_01163" index="1163">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hmm!\nMy sturdy Pokémon, defeated!\n</language>
	</row>
	<row id="narc_0558_01164" index="1164">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Aiyaah! We’re coming out swinging\nwith super-heavy judo chops!\r</language>
	</row>
	<row id="narc_0558_01165" index="1165">
		<attribute name="window_context_name">used</attribute>
		<language name="English">That was...\nA complete trashing!\n</language>
	</row>
	<row id="narc_0558_01166" index="1166">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I must rededicate myself to training.\nThe road extends into infinity...\n</language>
	</row>
	<row id="narc_0558_01167" index="1167">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Op og ned går du på lifterne.\nMig? Jeg kan lide at kæmpe!\r</language>
	</row>
	<row id="narc_0558_01168" index="1168">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’ve got me feeling down!\n</language>
	</row>
	<row id="narc_0558_01169" index="1169">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg kan ikke blive ved med det her!\nJeg går tilbage til at arbejde på elevatorerne.\n</language>
	</row>
	<row id="narc_0558_01170" index="1170">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et Pokémon Gym handler ikke kun om at se\nhvor hård din Pokémon tilfældigvis er.\rDet er så meget dybere end bare det.\nDet er en test af dig som person.\r</language>
	</row>
	<row id="narc_0558_01171" index="1171">
		<attribute name="window_context_name">used</attribute>
		<language name="English">That move was devastating!\n</language>
	</row>
	<row id="narc_0558_01172" index="1172">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg kommer på arbejde hele dagen med min\nPokémon, og endda kamp nogle gange.\rJeg får alt det sjov, jeg har brug for hver dag!</language>
	</row>
	<row id="narc_0558_01173" index="1173">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et es har viden og\nerfaring med at kæmpe på højt niveau.\rJeg vil demonstrere, hvad det betyder\nen noob som dig!\r</language>
	</row>
	<row id="narc_0558_01174" index="1174">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wow...\nJeg er i humør til at synge en vuggevise...\n</language>
	</row>
	<row id="narc_0558_01175" index="1175">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Your earnest enthusiasm...\nI guess that kinda makes you an ace.\rMaybe you’re a Trainer who has the\npotential to surpass aces!\n</language>
	</row>
	<row id="narc_0558_01176" index="1176">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ved kun at fokusere på én type kan du\nvirkelig se styrkerne og\fsvaghederne ved den Pokémon.\r</language>
	</row>
	<row id="narc_0558_01177" index="1177">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My focus was too narrow minded...</language>
	</row>
	<row id="narc_0558_01178" index="1178">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Start by becoming friendly with your\nPokémon. I mean really friendly.\rIf you do that, you’ll learn naturally\nhow you should battle with it.\n</language>
	</row>
	<row id="narc_0558_01179" index="1179">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Steel represents an unbending spirit!\rIf one refuses to accept defeat,\nthe path to victory reveals itself!\r</language>
	</row>
	<row id="narc_0558_01180" index="1180">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I never gave up, but still I failed to\nwin...\n</language>
	</row>
	<row id="narc_0558_01181" index="1181">
		<attribute name="window_context_name">used</attribute>
		<language name="English">If you give up, well, that’s when\neverything ends for you!\n</language>
	</row>
	<row id="narc_0558_01182" index="1182">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pokémon and people have worked\ntogether for many years.\rLet us show you an example of that\nhistory!\r</language>
	</row>
	<row id="narc_0558_01183" index="1183">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Et spektakulært tab!\nMen det er stadig et tab!\n</language>
	</row>
	<row id="narc_0558_01184" index="1184">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den måde I hjalp hinanden på...\nDet var det, der fik dig til at sejre!\n</language>
	</row>
	<row id="narc_0558_01185" index="1185">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What do you think you’re doing to my\nPokémon?!</language>
	</row>
	<row id="narc_0558_01186" index="1186">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dette kan ikke være?! jeg tabte?!\nDin... din overvældende møgunge!\n</language>
	</row>
	<row id="narc_0558_01187" index="1187">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I ain’t fooling around, kid.\nThis is how a professional does it!\r</language>
	</row>
	<row id="narc_0558_01188" index="1188">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You messed up my job...\nNow I’m not gonna get a bonus...\n</language>
	</row>
	<row id="narc_0558_01189" index="1189">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I hear they’re going to do something\nwith electricity, I think.\n</language>
	</row>
	<row id="narc_0558_01190" index="1190">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Indsamling af elektricitet fra dalen\nWindworks... Det er vores mission.\r</language>
	</row>
	<row id="narc_0558_01191" index="1191">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I really don’t like kids who also\nhappen to be tough Trainers...\n</language>
	</row>
	<row id="narc_0558_01192" index="1192">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du aner ikke hvad\nTeam Galactic forsøger at opnå!\rSelvfølgelig fortæller de ikke et grynt\nkan lide mig hvad som helst... Men alligevel!\n</language>
	</row>
	<row id="narc_0558_01193" index="1193">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...This is why I’m gonna be stuck as\na grunt forever...\n</language>
	</row>
	<row id="narc_0558_01194" index="1194">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...If only I had some decent\nPokémon...\n</language>
	</row>
	<row id="narc_0558_01195" index="1195">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Don’t get cocky, kid!\nThis isn’t over yet!\n</language>
	</row>
	<row id="narc_0558_01196" index="1196">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My Pokémon’s HP is low...\nThis could be a close fight.\n</language>
	</row>
	<row id="narc_0558_01197" index="1197">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What just happened?\nI lost?!\n</language>
	</row>
	<row id="narc_0558_01198" index="1198">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Don’t get cocky, kid!\nThis isn’t over yet!\n</language>
	</row>
	<row id="narc_0558_01199" index="1199">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My Pokémon’s HP is low...\nThis could be a close fight.\n</language>
	</row>
	<row id="narc_0558_01200" index="1200">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What just happened?\nI lost?!\n</language>
	</row>
	<row id="narc_0558_01201" index="1201">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi havde en heftig diskussion\nover Pokémon, som samlere gør.\r</language>
	</row>
	<row id="narc_0558_01202" index="1202">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Knowledge alone isn’t everything,\nyou know...\n</language>
	</row>
	<row id="narc_0558_01203" index="1203">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m more knowledgeable than the\nrest when it comes to collecting.\rI have rare Pokémon!\rBut a Collector doesn’t make a good\nbattler necessarily...\n</language>
	</row>
	<row id="narc_0558_01204" index="1204">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m a Collector, and I’m proud of\nwhat I know about Pokémon.\rWould you like me to test your\nknowledge?\r</language>
	</row>
	<row id="narc_0558_01205" index="1205">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er noget viden du har\nder!\n</language>
	</row>
	<row id="narc_0558_01206" index="1206">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I don’t like people who are more\nknowledgeable than me! Go away!\n</language>
	</row>
	<row id="narc_0558_01207" index="1207">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Velkomst!\nDette sted er min stolthed og glæde!\r</language>
	</row>
	<row id="narc_0558_01208" index="1208">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I take losses with an unusually big\nsmile! Do you find that odd at all?\n</language>
	</row>
	<row id="narc_0558_01209" index="1209">
		<attribute name="window_context_name">used</attribute>
		<language name="English">After a match, you should have some\nMoomoo Milk to quench your thirst!\rJust chug it right down! Glug glug!\n</language>
	</row>
	<row id="narc_0558_01210" index="1210">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
