		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00885" index="885">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00886" index="886">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00887" index="887">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00888" index="888">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXX</language>
	</row>
	<row id="narc_0558_00889" index="889">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00890" index="890">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det kræver både hjerne og styrke\nnår du er ude på havet.\rJa, det er ikke et let job\nSømands liv!\r</language>
	</row>
	<row id="narc_0558_00891" index="891">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Glub, glub, glub!</language>
	</row>
	<row id="narc_0558_00892" index="892">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis du skulle blive sømand, er jeg det\nsikker på du ville gøre en god en!\n</language>
	</row>
	<row id="narc_0558_00893" index="893">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ll beat you this time and convince\nyou to become a Sailor!\r</language>
	</row>
	<row id="narc_0558_00894" index="894">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, vi rider på havet,\ni en båd, kun dig og mig!\rSådan er sømandens måde!\nSømandens vej. Syng det!\r</language>
	</row>
	<row id="narc_0558_00895" index="895">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Din Pokémon...\nDe ser gode ud!\n</language>
	</row>
	<row id="narc_0558_00896" index="896">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du burde tænke på at blive\nselv en sømand.\rDet har været dejligt at kunne besøge\nforskellige steder rundt om i verden.\n</language>
	</row>
	<row id="narc_0558_00897" index="897">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, vi rider på havet,\ni en båd, kun dig og mig!\rSådan er sømandens måde!\nSømandens vej. Du synger også!\r</language>
	</row>
	<row id="narc_0558_00898" index="898">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Who’s there?!\nWhat do you think you’re doing?!\r</language>
	</row>
	<row id="narc_0558_00899" index="899">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I happen to be rather jumpy, so\neveryone looks suspicious to me.\n</language>
	</row>
	<row id="narc_0558_00900" index="900">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m easy to scare, and yet here I am\non patrol. Funny how things go.\n</language>
	</row>
	<row id="narc_0558_00901" index="901">
		<attribute name="window_context_name">used</attribute>
		<language name="English">At night, I get tense and nervous.\nI don’t know why.\n</language>
	</row>
	<row id="narc_0558_00902" index="902">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ll repeat myself! Who’s there?!\nWhat do you think you’re doing?!\r</language>
	</row>
	<row id="narc_0558_00903" index="903">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg keder mig ret meget.\nVil du bryde monotonien?\r</language>
	</row>
	<row id="narc_0558_00904" index="904">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The monotony was broken, but...\n</language>
	</row>
	<row id="narc_0558_00905" index="905">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg vil hvile mig på hotellet.\nJeg har fået nok af det her.\n</language>
	</row>
	<row id="narc_0558_00906" index="906">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ah, det er dig. jeg keder mig igen.\nVil du bryde monotonien?\r</language>
	</row>
	<row id="narc_0558_00907" index="907">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00908" index="908">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00909" index="909">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00910" index="910">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00911" index="911">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00912" index="912">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00913" index="913">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Efter at have nydt et måltid på hotellet\nrestaurant, har man en kamp.\rDet er den sociale etikette.\r</language>
	</row>
	<row id="narc_0558_00914" index="914">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Enchanting.\n</language>
	</row>
	<row id="narc_0558_00915" index="915">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Personally, I would rather just play\nwith Pokémon than battle with them.\n</language>
	</row>
	<row id="narc_0558_00916" index="916">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg ser først ud til at støde på dig bagefter\nJeg går til restauranten.\rEtikette kalder på kamp efter en\nmåltid. Skal vi?\r</language>
	</row>
	<row id="narc_0558_00917" index="917">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Look, look! Look at my Pokémon!\nIt’s really cool!\r</language>
	</row>
	<row id="narc_0558_00918" index="918">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wowee! I had to hold on tight to\nmy inner tube!\n</language>
	</row>
	<row id="narc_0558_00919" index="919">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Pools er OK, men jeg kan godt lide havet\nfordi Pokémon bor der.\n</language>
	</row>
	<row id="narc_0558_00920" index="920">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Yay! You came to see my Pokémon\nagain, right? Look, look!\r</language>
	</row>
	<row id="narc_0558_00921" index="921">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hør, hør! Kan du fortælle mig hvad\nen slags Pokémon du har?\r</language>
	</row>
	<row id="narc_0558_00922" index="922">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re so tough. I’m stunned...\n</language>
	</row>
	<row id="narc_0558_00923" index="923">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I want to hang on to a BUIZEL and\njust bob around.\n</language>
	</row>
	<row id="narc_0558_00924" index="924">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Listen, listen! Did you find any new\nkinds of Pokémon?\r</language>
	</row>
	<row id="narc_0558_00925" index="925">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00926" index="926">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00927" index="927">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00928" index="928">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00929" index="929">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00930" index="930">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00931" index="931">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00932" index="932">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00933" index="933">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00934" index="934">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00935" index="935">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00936" index="936">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg kom herud, fordi jeg gerne ville\nse Pokémon League for mig selv.\r</language>
	</row>
	<row id="narc_0558_00937" index="937">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m shocked...\nNo, really, I am.\n</language>
	</row>
	<row id="narc_0558_00938" index="938">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Som jeg kæmper nu, ja, det kan jeg\nse kun på Pokémon League!\rDu, fortsæt! Du går til Pokémon\nLiga for mig også!\n</language>
	</row>
	<row id="narc_0558_00939" index="939">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg har trænet her i håb om\ngår til Pokémon League.\r</language>
	</row>
	<row id="narc_0558_00940" index="940">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg har bestemt mig! Hvis jeg kan slå dig, er jeg det\nskal til Pokémon League!\r</language>
	</row>
	<row id="narc_0558_00941" index="941">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Bblblblugh...\n</language>
	</row>
	<row id="narc_0558_00942" index="942">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er i orden. Lad mig bare flyde væk\nsom drivtømmer...\n</language>
	</row>
	<row id="narc_0558_00943" index="943">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg har bestemt mig! Hvis jeg endelig slår dig,\nJeg udfordrer Pokémon League!\r</language>
	</row>
	<row id="narc_0558_00944" index="944">
		<attribute name="window_context_name">used</attribute>
		<language name="English">It might not look like it, but I’m\ntraveling now.\r</language>
	</row>
	<row id="narc_0558_00945" index="945">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du har overtaget på mig.\n</language>
	</row>
	<row id="narc_0558_00946" index="946">
		<attribute name="window_context_name">used</attribute>
		<language name="English">But you can be sure that there will\nbe bigger challenges in front of you.\rGo! Go as far as you can! You alone can\nbroaden your horizons.\n</language>
	</row>
	<row id="narc_0558_00947" index="947">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m still on my journey...\nLet’s have a battle!\r</language>
	</row>
	<row id="narc_0558_00948" index="948">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The sea around here is harsh.\nIt’s made me just as harsh!\r</language>
	</row>
	<row id="narc_0558_00949" index="949">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The world is so harsh...\n</language>
	</row>
	<row id="narc_0558_00950" index="950">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What? You’ve got that many Gym\nBadges? No wonder you’re so tough...\n</language>
	</row>
	<row id="narc_0558_00951" index="951">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er mig igen! Det barske hav her\nburde have skærpet mig mere!\r</language>
	</row>
	<row id="narc_0558_00952" index="952">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Min drøm er at svømme i havet\nhver region under solen!\r</language>
	</row>
	<row id="narc_0558_00953" index="953">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Boo!\nJeg er ikke færdig med min drøm!\n</language>
	</row>
	<row id="narc_0558_00954" index="954">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg spekulerer på, hvordan havene er i\nKanto og Hoenn...?\n</language>
	</row>
	<row id="narc_0558_00955" index="955">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My new dream is to challenge all the\nPokémon Leagues in every region!\r</language>
	</row>
	<row id="narc_0558_00956" index="956">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Yes, I know I can surf, but I’d\nrather swim instead.\rIt does seem weird, I agree.\r</language>
	</row>
	<row id="narc_0558_00957" index="957">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Kaploosh!\n</language>
	</row>
	<row id="narc_0558_00958" index="958">
		<attribute name="window_context_name">used</attribute>
		<language name="English">If you don’t know how, I’m willing to\nshow you how to swim.\n</language>
	</row>
	<row id="narc_0558_00959" index="959">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis du stoler på dine Pokémon, er alle\ntid, vil du aldrig lære at svømme!\r</language>
	</row>
	<row id="narc_0558_00960" index="960">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I train at a Pokémon Gym, too.\rDon’t think you’re going to win\neasily!\r</language>
	</row>
	<row id="narc_0558_00961" index="961">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Master Wake...\nI’m so sorry to have failed you...\n</language>
	</row>
	<row id="narc_0558_00962" index="962">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvad skal man gøre... Træn i gymnastiksalen igen,\neller træne selv...\n</language>
	</row>
	<row id="narc_0558_00963" index="963">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg trænede i gymnastiksalen efter du slog\nmig. Lad os gøre det, bande!\r</language>
	</row>
	<row id="narc_0558_00964" index="964">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg er fast besluttet på at gå til Pokémon\nLiga, uanset hvor svært det er.\r</language>
	</row>
	<row id="narc_0558_00965" index="965">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det her er så svært...\n</language>
	</row>
	<row id="narc_0558_00966" index="966">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Losing won’t make me give up. The\nPokémon League isn’t going anywhere.\n</language>
	</row>
	<row id="narc_0558_00967" index="967">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er lige meget hvor lang tid det tager,\nJeg skal til Pokémon League!\r</language>
	</row>
	<row id="narc_0558_00968" index="968">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Excuse me for wearing my bikini!\r</language>
	</row>
	<row id="narc_0558_00969" index="969">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Var jeg multitasking for meget, kæmpende\nog svømning på samme tid?\n</language>
	</row>
	<row id="narc_0558_00970" index="970">
		<attribute name="window_context_name">used</attribute>
		<language name="English">When I’m in my bikini, I’m at a loss\nabout where to carry my Poké Balls!\n</language>
	</row>
	<row id="narc_0558_00971" index="971">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Giggle...\nExcuse me for wearing my bikini!\r</language>
	</row>
	<row id="narc_0558_00972" index="972">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Deep breathing before battle!\r</language>
	</row>
	<row id="narc_0558_00973" index="973">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Inhale... Exhale...</language>
	</row>
	<row id="narc_0558_00974" index="974">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Deep breathing after battle, too!\n</language>
	</row>
	<row id="narc_0558_00975" index="975">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Don’t get careless, even if you’re\nfacing someone familiar.\rDo your deep-breathing exercises...\r</language>
	</row>
	<row id="narc_0558_00976" index="976">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Din Pokémon er dog ikke træt\nden bærer dig på ryggen.\rLad mig se, hvor stærk den Pokémon\ner okay?\r</language>
	</row>
	<row id="narc_0558_00977" index="977">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ve had my fill...\n</language>
	</row>
	<row id="narc_0558_00978" index="978">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m tired of swimming, so I’ll just\nfloat around and get some rest.\n</language>
	</row>
	<row id="narc_0558_00979" index="979">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvor meget stærkere har din Pokémon\nblive?\rLad mig tjekke dem ud, okay?\r</language>
	</row>
	<row id="narc_0558_00980" index="980">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vidste du, at jeg blev kronet som\nmester i en badedragt konkurrence!\rSå nu prøver jeg at vinde en titel\nved en Pokémon-konkurrence!\r</language>
	</row>
	<row id="narc_0558_00981" index="981">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ve been sunk!\n</language>
	</row>
	<row id="narc_0558_00982" index="982">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ll need to rework my strategy!\n</language>
	</row>
	<row id="narc_0558_00983" index="983">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg blev mester i en badedragt\nkonkurrence... Jeg er en super dygtig pige!\rJeg udfordrer dig, så jeg kan blive\nmester i en Pokémon-konkurrence!\r</language>
	</row>
	<row id="narc_0558_00984" index="984">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Min yndlingstype er nogen\ndet ser godt ud på det åbne hav!\r</language>
	</row>
	<row id="narc_0558_00985" index="985">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Tidevandet er ved at gå ud...\n</language>
	</row>
	<row id="narc_0558_00986" index="986">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...Though there’s a mysterious nature\nthat surrounds a mountain man...\n</language>
	</row>
	<row id="narc_0558_00987" index="987">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hej igen! Du er den træner, der\nser ivrig ud med din Pokémon!\r</language>
	</row>
	<row id="narc_0558_00988" index="988">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fine, all righty then.\nJust a quick battle on my break!\r</language>
	</row>
	<row id="narc_0558_00989" index="989">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wahaha!\nMercy, I cry mercy!\n</language>
	</row>
	<row id="narc_0558_00990" index="990">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg må hellere komme tilbage på arbejde...\rDu ved, jeg vil hellere rejse\nrundt med Pokémon, som du gør.\n</language>
	</row>
	<row id="narc_0558_00991" index="991">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m gonna let you in on a secret...\nI snuck my Pokémon to work!\r</language>
	</row>
	<row id="narc_0558_00992" index="992">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Well, now aren’t you something!\n</language>
	</row>
	<row id="narc_0558_00993" index="993">
		<attribute name="window_context_name">used</attribute>
		<language name="English">OK, OK, time for work! I’ll work up\na thirst with my Pokémon!\n</language>
	</row>
	<row id="narc_0558_00994" index="994">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
