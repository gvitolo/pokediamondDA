	<row id="narc_0558_01834" index="1834">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01835" index="1835">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01836" index="1836">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01837" index="1837">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01838" index="1838">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01839" index="1839">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01840" index="1840">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01841" index="1841">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01842" index="1842">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I just got worked over!\nAnd by a kid no less...\n</language>
	</row>
	<row id="narc_0558_01843" index="1843">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...!\nAgain and again...\n</language>
	</row>
	<row id="narc_0558_01844" index="1844">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er vores mission at stoppe dig.\nUndskyld, men vi skal gøre vores arbejde.\r</language>
	</row>
	<row id="narc_0558_01845" index="1845">
		<attribute name="window_context_name">used</attribute>
		<language name="English">At miste var også en del af mit job.\n...Jeg har det bedre ved at sige det.\n</language>
	</row>
	<row id="narc_0558_01846" index="1846">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi vil ikke tillade nogen at stoppe os\nfra at samle de tre Pokémons\ffra de tre søer.\n</language>
	</row>
	<row id="narc_0558_01847" index="1847">
		<attribute name="window_context_name">used</attribute>
		<language name="English">In order for us to bring peace to\nthe world, we must control it!\r</language>
	</row>
	<row id="narc_0558_01848" index="1848">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re too young to understand.\n</language>
	</row>
	<row id="narc_0558_01849" index="1849">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vores chef havde altid planer om\nde tre søer...\rMens du var lykkeligt uvidende,\nvores arbejde gik videre...\n</language>
	</row>
	<row id="narc_0558_01850" index="1850">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg slår din Pokémon i kredsløb!\r</language>
	</row>
	<row id="narc_0558_01851" index="1851">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My mind is going orbital!\n</language>
	</row>
	<row id="narc_0558_01852" index="1852">
		<attribute name="window_context_name">used</attribute>
		<language name="English">The Pokémon here has already been\ntaken to our HQ in Veilstone City.\rIt’s far too late for a child like\nyou to make any difference.\n</language>
	</row>
	<row id="narc_0558_01853" index="1853">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis denne mission lykkes, vil vi\nvil få en god bonus.\r</language>
	</row>
	<row id="narc_0558_01854" index="1854">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m heartbroken...\n</language>
	</row>
	<row id="narc_0558_01855" index="1855">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I want Team Galactic to become\npowerful. That is all I want.\n</language>
	</row>
	<row id="narc_0558_01856" index="1856">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...Du, min ven, er hård!\nJeg kan se hvorfor du trodser os så...\n</language>
	</row>
	<row id="narc_0558_01857" index="1857">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi sætter den galaktiske bombe i gang!\nDens sprængkraft var fænomenal!\r</language>
	</row>
	<row id="narc_0558_01858" index="1858">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dit Pokémon-angreb med fænomenal\nmagt...\n</language>
	</row>
	<row id="narc_0558_01859" index="1859">
		<attribute name="window_context_name">used</attribute>
		<language name="English">So, you’re tough. Big deal.\nWhat do you think you can accomplish?\rThere’s one of you up against the\nentire Team Galactic.\rBy now, another crew should be on\ntheir way to Lake Verity near that\fpuny little Twinleaf Town!\n</language>
	</row>
	<row id="narc_0558_01860" index="1860">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ll punish you in place of our\nboss for defying Team Galactic!\r</language>
	</row>
	<row id="narc_0558_01861" index="1861">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Grr...\nJeg tog straffen...\n</language>
	</row>
	<row id="narc_0558_01862" index="1862">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi er Team Galactic!\nNr. 1 syndikat i verden!\rAt trodse os er at trodse universet!\n</language>
	</row>
	<row id="narc_0558_01863" index="1863">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...Vil du være med i MAGIKARP\nog flop rundt i mudderet?\r</language>
	</row>
	<row id="narc_0558_01864" index="1864">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...Overwhelming!\n</language>
	</row>
	<row id="narc_0558_01865" index="1865">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg spillede dig for et barn og betalte\nen hård pris for min arrogance...\rDu er dog alt for sent ude.\rTeam Galactic har allerede fundet\nsunket ø under søen.\rOg Pokémonen der lå i den?\nNå, hvad synes du?\n</language>
	</row>
	<row id="narc_0558_01866" index="1866">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du er hård, knægt!\nMen jeg har stadig ondt af dem som dig.\n</language>
	</row>
	<row id="narc_0558_01867" index="1867">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Well, what have we here?\nA Trainer who’s lost their way?\r</language>
	</row>
	<row id="narc_0558_01868" index="1868">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re lost but you won!\nThat burns me up to eleven!\n</language>
	</row>
	<row id="narc_0558_01869" index="1869">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You barged right into our HQ?\nYou must not know what fear is, kid!\n</language>
	</row>
	<row id="narc_0558_01870" index="1870">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du er den første ubuden gæst, vi har haft\ni vores hovedkvarter!\r</language>
	</row>
	<row id="narc_0558_01871" index="1871">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, sure. Why don’t you just get\nall cocky about it!\n</language>
	</row>
	<row id="narc_0558_01872" index="1872">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Without our special card key, you’re\nnot going to get very far.\rWell, non-Team Galactic member?\nWhat’s your next move?\n</language>
	</row>
	<row id="narc_0558_01873" index="1873">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvem tror du, du er?\nAt vanhellige hallerne i vores hovedkvarter?!\r</language>
	</row>
	<row id="narc_0558_01874" index="1874">
		<attribute name="window_context_name">used</attribute>
		<language name="English">En hård lille træner er hvad du\ner...\n</language>
	</row>
	<row id="narc_0558_01875" index="1875">
		<attribute name="window_context_name">used</attribute>
		<language name="English">We get around in Galactic HQ by\na system of round warp panels.\rDo you think you will ever learn\nthe way they connect? Good luck!\n</language>
	</row>
	<row id="narc_0558_01876" index="1876">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Nogle mennesker, som dig, gør det bare ikke\nforstå, hvorfor vi gør, som vi gør.\rDu forstår ikke Team Galactic.\nSå hvorfor er det, at du trodser os?!\r</language>
	</row>
	<row id="narc_0558_01877" index="1877">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I couldn’t understand the\nbattle or your toughness...\n</language>
	</row>
	<row id="narc_0558_01878" index="1878">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg gik ud af min måde at levere min\nseje linjer før kampen!\rDu skulle have ladet mig vinde!\nFå fat i virkeligheden allerede!\n</language>
	</row>
	<row id="narc_0558_01879" index="1879">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m, like, this close to getting my\npromotion to Commander.\rI’ll impress our great boss by making\nyou my newest trophy!\r</language>
	</row>
	<row id="narc_0558_01880" index="1880">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...I wish this never happened.</language>
	</row>
	<row id="narc_0558_01881" index="1881">
		<attribute name="window_context_name">used</attribute>
		<language name="English">At tabe sætter mig tilbage til udgangspunktet...\rJeg bliver nok busted ned til\nden grynteste af gryntene... Humph!</language>
	</row>
	<row id="narc_0558_01882" index="1882">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01883" index="1883">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01884" index="1884">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01885" index="1885">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01886" index="1886">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01887" index="1887">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_01888" index="1888">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Intruder alert!\nThere’s something smelly about you!\r</language>
	</row>
	<row id="narc_0558_01889" index="1889">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, det var min egen Pokémons lugt...\n</language>
	</row>
	<row id="narc_0558_01890" index="1890">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er ikke noget, der lugter ved os!\nVi er på forkant med tingene!\n</language>
	</row>
	<row id="narc_0558_01891" index="1891">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Having fun scampering around our HQ,\nyou sneaky intruder?\rYour trail blazing will go out in\na blaze of glory right now!\r</language>
	</row>
	<row id="narc_0558_01892" index="1892">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Your trailblazing streak lives on!\n</language>
	</row>
	<row id="narc_0558_01893" index="1893">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Så hvad, du har momentum...\nDet er for sent. Eksperimentet er udført!\n</language>
	</row>
	<row id="narc_0558_01894" index="1894">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You should be tired out by now.\nIt’s Team Galactic’s turn to shine!\r</language>
	</row>
	<row id="narc_0558_01895" index="1895">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What? I don’t get it.\nWhat’s your rush?\n</language>
	</row>
	<row id="narc_0558_01896" index="1896">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Er Pokémon så vigtige for dig?\nEr det det, det hele handler om?\n</language>
	</row>
	<row id="narc_0558_01897" index="1897">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Nyder du din ueskorterede,\nuautoriseret og foruroligende tur\faf Team Galactic HQ?\r</language>
	</row>
	<row id="narc_0558_01898" index="1898">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Let me do what I want!\n</language>
	</row>
	<row id="narc_0558_01899" index="1899">
		<attribute name="window_context_name">used</attribute>
		<language name="English">It doesn’t matter what happens to\nthe Team Galactic HQ building.\rSoon, all will belong to Team\nGalactic, anyway!\n</language>
	</row>
	<row id="narc_0558_01900" index="1900">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hey there, little Trainer!\nYou’re famous among Team Galactic.\rThe order has been issued--we get\na promotion if we put you down!\r</language>
	</row>
	<row id="narc_0558_01901" index="1901">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I just blew my promotion...\n</language>
	</row>
	<row id="narc_0558_01902" index="1902">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What’s so special about you anyway?\rYou’re just like any other little kid\nTrainer you can find anywhere!</language>
	</row>
	<row id="narc_0558_01903" index="1903">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Our time has come!\nIt’s Team Galactic’s time now!\r</language>
	</row>
	<row id="narc_0558_01904" index="1904">
		<attribute name="window_context_name">used</attribute>
		<language name="English">When’s it gonna be my turn...\n</language>
	</row>
	<row id="narc_0558_01905" index="1905">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er for sent!\rIngen mængde af desperation fra et barn\nsom om du vil gøre en forskel!\n</language>
	</row>
	<row id="narc_0558_01906" index="1906">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Our time will come.\nA time for only us!\rI’m going to turn back your time!\nTo a time before Pokémon!\r</language>
	</row>
	<row id="narc_0558_01907" index="1907">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gyah!\n</language>
	</row>
	<row id="narc_0558_01908" index="1908">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du kan kæmpe alt hvad du vil, men\ndu kan ikke stoppe Team Galactic alene!\rDet er ligegyldigt hvor mange Pokémon\ndu prøver at bruge som dine værktøjer!\n</language>
	</row>
	<row id="narc_0558_01909" index="1909">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Team Galactic er alle magtfulde!\rKun en tåbe ville vise trods mod\nden mægtige magt i Team Galactic!\r</language>
	</row>
	<row id="narc_0558_01910" index="1910">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ikke at stå op til den mægtige er\ntåbeligt, siger du...\n</language>
	</row>
	<row id="narc_0558_01911" index="1911">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er lige meget, om du er voksen\neller et barn, hvis du har Pokémon...\rPokémon er equalizerne.\nJeg burde have indset det før...</language>
	</row>
	<row id="narc_0558_01912" index="1912">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg kan ikke tro, du jagtede mig her...\nOK, lad os se, hvor hård du er.\r</language>
	</row>
	<row id="narc_0558_01913" index="1913">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Where do you get that power?!\n</language>
	</row>
	<row id="narc_0558_01914" index="1914">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Mt. Coronet...\rI might be just a grunt, but even I\ncan tell it has a weird energy!\n</language>
	</row>
	<row id="narc_0558_01915" index="1915">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Dette er vores sidste operation.\nIngen vil blande sig!\r</language>
	</row>
	<row id="narc_0558_01916" index="1916">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du vendte blikket mod mig...\nJeg kalder interferens...\n</language>
	</row>
	<row id="narc_0558_01917" index="1917">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jo tættere du er på toppen,\njo tættere er du på rummet!\rSnart vil Team Galactic... Øh...\nTeam Galactic vil opnå storhed!\n</language>
	</row>
	<row id="narc_0558_01918" index="1918">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Team Galactic will take control of\neverything!\rYou can try all you want, but you\ncan’t do anything alone!\r</language>
	</row>
	<row id="narc_0558_01919" index="1919">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det eneste du gav mig var smagen af\nnederlag...\n</language>
	</row>
	<row id="narc_0558_01920" index="1920">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...Is our boss about to ditch us\nand claim everything for himself?</language>
	</row>
	<row id="narc_0558_01921" index="1921">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi grynter har fået tildelt to\nædle jobs.\rEt, sikre vores succes\noperation på topmødet!\rTo, fuldstændig ødelægge enhver, der\ntør blande sig!\r</language>
	</row>
	<row id="narc_0558_01922" index="1922">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg accepterer ikke dette!\nJeg vil ikke acceptere dette!\n</language>
	</row>
	<row id="narc_0558_01923" index="1923">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Join Team Galactic and then abide\nby our rules.\rThat would solve all our problems!\n</language>
	</row>
	<row id="narc_0558_01924" index="1924">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sig, hør, indser du, at du er\nknuse hjerter ved at have succes?\rDet er din skyld, at Team Galactic\nmedlemmer har så ondt...\r</language>
	</row>
	<row id="narc_0558_01925" index="1925">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Se? Du har efterladt mig knust,\nogså...\n</language>
	</row>
	<row id="narc_0558_01926" index="1926">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Someone’s joy is another person’s\nsorrow...\rEveryone be happy and laughing?\nHow ridiculous!\rTeam Galactic should be doing all the\nlaughing!\n</language>
	</row>
	<row id="narc_0558_01927" index="1927">
		<attribute name="window_context_name">used</attribute>
		<language name="English">...Vores chef vil gøre noget\nstort på toppen.\rMen her har jeg at gøre med nogle irriterende\nubuden gæst.\rDu ødelægger stemningen.\nDu kan tabe hurtigt, ikke?\r</language>
	</row>
	<row id="narc_0558_01928" index="1928">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du skal ikke arbejde mig\nover sådan.\n</language>
	</row>
	<row id="narc_0558_01929" index="1929">
		<attribute name="window_context_name">used</attribute>
		<language name="English">All my excitement’s gone now...\rThis whole Mt. Coronet trip is too\nrough, long, and draining...\n</language>
	</row>
	<row id="narc_0558_01930" index="1930">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’ve worked so hard to get here.\nYou should be proud of yourself!\rAnd now, I’ll send you packing home\nwith only that happy thought!\r</language>
	</row>
	<row id="narc_0558_01931" index="1931">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wh-- How dare you! That’s how you\nrespond to my generosity?\n</language>
	</row>
	<row id="narc_0558_01932" index="1932">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vi kunne ikke stoppe dig...\nVi bliver kasseret som ubrugelige...\rVores chef er hensynsløs på den måde...\n</language>
	</row>
	<row id="narc_0558_01933" index="1933">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, yeah?\nI’ll show you something wicked, too!\n</language>
	</row>
	<row id="narc_0558_01934" index="1934">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What the?! We’re in trouble?!\nBut there’s no giving up on me!\n</language>
	</row>
	<row id="narc_0558_01935" index="1935">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What just happened?!\nYou’re telling me I lost?!\n</language>
	</row>
	<row id="narc_0558_01936" index="1936">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, yeah?\nI’ll show you something wicked, too!\n</language>
	</row>
