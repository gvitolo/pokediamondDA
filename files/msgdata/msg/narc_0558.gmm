	</row>
	<row id="narc_0558_00229" index="229">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00230" index="230">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00231" index="231">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00232" index="232">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hi, hi!\nI’m a Pokémon!\r</language>
	</row>
	<row id="narc_0558_00233" index="233">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m so angry...\n</language>
	</row>
	<row id="narc_0558_00234" index="234">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I want to be a Pokémon when I grow\nup!\n</language>
	</row>
	<row id="narc_0558_00235" index="235">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hi, hi!\nI’m a Pokémon!\r...I think you already know, but\nwe’re going to battle again!\r</language>
	</row>
	<row id="narc_0558_00236" index="236">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00237" index="237">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00238" index="238">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00239" index="239">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ty: Du skal ikke trænge dig ind\npå min tid med Sue!\r</language>
	</row>
	<row id="narc_0558_00240" index="240">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ty: I only have eyes for Sue.\nMaybe that’s why we lost?\n</language>
	</row>
	<row id="narc_0558_00241" index="241">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ty: Sue, even in defeat, you’re\nso beautiful...!\n</language>
	</row>
	<row id="narc_0558_00242" index="242">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ty: I don’t want to do anything\nwithout Sue...\rBring two Pokémon at least, OK?\n</language>
	</row>
	<row id="narc_0558_00243" index="243">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ty: Did you come back to intrude\non my time with Sue?\r</language>
	</row>
	<row id="narc_0558_00244" index="244">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sue: Huh?\nYou want to battle with me?\rI will if I can team with Ty!\r</language>
	</row>
	<row id="narc_0558_00245" index="245">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sue: I’m sorry, Ty!\n</language>
	</row>
	<row id="narc_0558_00246" index="246">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sue: We lost... Ty, I need a hug\nto make it all better!\n</language>
	</row>
	<row id="narc_0558_00247" index="247">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sue: Jeg vil kun gøre ting\nmed Ty!\rHar du ikke to Pokémons?\n</language>
	</row>
	<row id="narc_0558_00248" index="248">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sue: Åh, det er dig igen!\nJeg vil kæmpe, hvis jeg kan holde sammen med Ty!\r</language>
	</row>
	<row id="narc_0558_00249" index="249">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00250" index="250">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXX</language>
	</row>
	<row id="narc_0558_00251" index="251">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
