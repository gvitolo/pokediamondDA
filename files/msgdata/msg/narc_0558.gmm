	<row id="narc_0558_02027" index="2027">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, tak for sidst.\rMå jeg venligst plage dig for\nendnu en kamp?\r</language>
	</row>
	<row id="narc_0558_02028" index="2028">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh...\nYou’re so strong...\n</language>
	</row>
	<row id="narc_0558_02029" index="2029">
		<attribute name="window_context_name">used</attribute>
		<language name="English">So, listen. Tell me you’ve grown to\nlike bug Pokémon since we last met.\r</language>
	</row>
	<row id="narc_0558_02030" index="2030">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg vil ikke være i stand til at forklare\ncharmen ved bug Pokémon på denne måde!\n</language>
	</row>
