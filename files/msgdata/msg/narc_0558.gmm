<?xml version='1.0' encoding='UTF-8'?>
<body language="English">
	<row id="narc_0558_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Forget it!\nThis isn’t over yet!\n</language>
	</row>
	<row id="narc_0558_00001" index="1">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My Pokémon’s HP is low...\nThis could be a bit tight.\n</language>
	</row>
	<row id="narc_0558_00002" index="2">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What’s going on here?\nWhat, I lost?!\n</language>
	</row>
	<row id="narc_0558_00003" index="3">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Tror du kan tage ned \nnæste Pokémon som du gjorde tidligere?\n</language>
	</row>
	<row id="narc_0558_00004" index="4">
		<attribute name="window_context_name">used</attribute>
		<language name="English">No way! Not yet!\nNot giving up!\n</language>
	</row>
	<row id="narc_0558_00005" index="5">
		<attribute name="window_context_name">used</attribute>
		<language name="English">W-what? That can’t be!\nMy buffed-up Pokémon!\n</language>
	</row>
	<row id="narc_0558_00006" index="6">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Undgik du den lange vej rundt?\nLad os se, hvorfor du ville gøre det!\r</language>
	</row>
	<row id="narc_0558_00007" index="7">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Now I understand why you decided to\nbattle with me.\n</language>
	</row>
	<row id="narc_0558_00008" index="8">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du bør gå den vej du end har\nønsker, genvej eller den lange vej!\n</language>
	</row>
	<row id="narc_0558_00009" index="9">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Only those who want to win can\nchallenge a Pokémon Gym!\r</language>
	</row>
	<row id="narc_0558_00010" index="10">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gggh...\nThis is humiliating!\n</language>
	</row>
	<row id="narc_0558_00011" index="11">
		<attribute name="window_context_name">used</attribute>
		<language name="English">One day, I’m going to become a tough\nTrainer like you.\n</language>
	</row>
	<row id="narc_0558_00012" index="12">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re a Pokémon Trainer!\nI happen to be a Pokémon Trainer!\rOur eyes met, so battle we must!\r</language>
	</row>
	<row id="narc_0558_00013" index="13">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Too strong!\nToo strong!</language>
	</row>
	<row id="narc_0558_00014" index="14">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Don’t be shy about talking to\nTrainers you’d like to battle.\rPokémon grow stronger and stronger\nfrom battling.</language>
	</row>
	<row id="narc_0558_00015" index="15">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Did you get better since we met?\nI... Well, here, just look!\r</language>
	</row>
	<row id="narc_0558_00016" index="16">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lad os tage en Pokémon-kamp!\nHumph! Men jeg vinder!\r</language>
	</row>
	<row id="narc_0558_00017" index="17">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re, like, wow!</language>
	</row>
	<row id="narc_0558_00018" index="18">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er sjovt at kæmpe mod andre!\nJeg vil kæmpe mod alle mulige mennesker!</language>
	</row>
	<row id="narc_0558_00019" index="19">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lad os tage endnu en Pokémon-kamp!\nDenne gang vinder jeg!\r</language>
	</row>
	<row id="narc_0558_00020" index="20">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I spy, with my little eye...\nA Trainer!\rA battle, please!\r</language>
	</row>
	<row id="narc_0558_00021" index="21">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, boo!\nI can’t win!</language>
	</row>
	<row id="narc_0558_00022" index="22">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My Pokémon are all tuckered out!\nI need to go to a Poké Center!</language>
	</row>
	<row id="narc_0558_00023" index="23">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, hi!\nI remember you, Trainer!\rA battle, please!\r</language>
	</row>
	<row id="narc_0558_00024" index="24">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m full of energy because I get\npower from my Pokémon!\r</language>
	</row>
	<row id="narc_0558_00025" index="25">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh! My poor BIDOOF and ZUBAT!</language>
	</row>
	<row id="narc_0558_00026" index="26">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Undgå højt græs...\nEller undgå trænere...\fHar du problemer med at beslutte dig?\n</language>
	</row>
	<row id="narc_0558_00027" index="27">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You look familiar, Trainer.\nCan I have another match?\r</language>
	</row>
	<row id="narc_0558_00028" index="28">
		<attribute name="window_context_name">used</attribute>
		<language name="English">We’re always together.\nI’ll show you how we’ve bonded!\r</language>
	</row>
	<row id="narc_0558_00029" index="29">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det fik mig ned...\n</language>
	</row>
	<row id="narc_0558_00030" index="30">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I don’t bear grudges over losing.\nBut I promise I’ll get tougher!\n</language>
	</row>
	<row id="narc_0558_00031" index="31">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m always with my Pokémon.\rActually, you’re always with your\nPokémon too, aren’t you?\r</language>
	</row>
	<row id="narc_0558_00032" index="32">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Giv mig en kamp, ​​så jeg kan se, om jeg er\nklar til Pokémon Gym-udfordringen!\r</language>
	</row>
	<row id="narc_0558_00033" index="33">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I guess it means I’m not ready for\nthe Gym challenge yet...\n</language>
	</row>
	<row id="narc_0558_00034" index="34">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I guess if you don’t have a single\nGym Badge, you’re a total nobody...\n</language>
	</row>
	<row id="narc_0558_00035" index="35">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg er ved at tage Pokémon Gym\nudfordring.\rMen før jeg går, vil jeg sparre med\ndu.\r</language>
	</row>
	<row id="narc_0558_00036" index="36">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I got a nifty-keen Gym Badge from\nthe Gym Leader in Oreburgh City!\r</language>
	</row>
	<row id="narc_0558_00037" index="37">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, I lost! Lalala!\n</language>
	</row>
	<row id="narc_0558_00038" index="38">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m going to collect lots of Gym\nBadges! I’ll work with my Pokémon!\n</language>
	</row>
	<row id="narc_0558_00039" index="39">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I got a nifty-keen Gym Badge from\nthe Gym Leader in Oreburgh City!\r...Did I show you already?\r</language>
	</row>
	<row id="narc_0558_00040" index="40">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I found a Trainer while looking for\nsome Pokémon!\r</language>
	</row>
	<row id="narc_0558_00041" index="41">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hunh? You’re finished so soon?\n</language>
	</row>
	<row id="narc_0558_00042" index="42">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg går gennem højt græs, indtil jeg\nfinde den Pokémon, jeg vil have.\n</language>
	</row>
	<row id="narc_0558_00043" index="43">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I found a familiar-looking Trainer!\r</language>
	</row>
	<row id="narc_0558_00044" index="44">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, a weak-looking Trainer...\nDo you want to have a go?\r</language>
	</row>
	<row id="narc_0558_00045" index="45">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Aww...\nI should have said no.\n</language>
	</row>
	<row id="narc_0558_00046" index="46">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I didn’t know you’re so tough...\nI’m going to train harder too!\n</language>
	</row>
	<row id="narc_0558_00047" index="47">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hi, pretty-tough Trainer!\nWill you give me a rematch?\r</language>
	</row>
	<row id="narc_0558_00048" index="48">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My dad gave me some Pokémon!\nThey’re gonna win for me!\r</language>
	</row>
	<row id="narc_0558_00049" index="49">
		<attribute name="window_context_name">used</attribute>
		<language name="English">But they’re Pokémon I got from my\ndad...\n</language>
	</row>
	<row id="narc_0558_00050" index="50">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvem gav dig din første Pokémon?\rDin første Pokémon er den med\nde bedste minder, synes jeg.\n</language>
	</row>
	<row id="narc_0558_00051" index="51">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m gonna win this time with the\nPokémon I got from my dad!\r</language>
	</row>
	<row id="narc_0558_00052" index="52">
		<attribute name="window_context_name">used</attribute>
		<language name="English">May I please trouble you for a\nbattle?\r</language>
	</row>
	<row id="narc_0558_00053" index="53">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh...\nYou’re so strong...\n</language>
	</row>
	<row id="narc_0558_00054" index="54">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Maybe I could have won if my Pokémon\nwas holding a Berry...\n</language>
	</row>
	<row id="narc_0558_00055" index="55">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, tak for sidst.\rMå jeg venligst plage dig for\nendnu en kamp?\r</language>
	</row>
	<row id="narc_0558_00056" index="56">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Say, listen. What’s your opinion on\nbug Pokémon?\r</language>
	</row>
	<row id="narc_0558_00057" index="57">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg vil ikke være i stand til at forklare\ncharmen ved bug Pokémon på denne måde!\n</language>
	</row>
	<row id="narc_0558_00058" index="58">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Bug Pokémon grow quickly, and they do\nstuff like poison and paralyze, and\fthey’re cute and yet cool.\rYou gotta believe me. They’re good!\n</language>
	</row>
	<row id="narc_0558_00059" index="59">
		<attribute name="window_context_name">used</attribute>
		<language name="English">So, listen. Tell me you’ve grown to\nlike bug Pokémon since we last met?\r</language>
	</row>
	<row id="narc_0558_00060" index="60">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lad os kæmpe, mens vi lugter\nduften af ​​blomster!\r</language>
	</row>
	<row id="narc_0558_00061" index="61">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Even though I lost, I’m not angry\nbecause it smells so nice.\n</language>
	</row>
	<row id="narc_0558_00062" index="62">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Måske tager jeg noget tilbehør på\nmin Pokémon på tv-stationen i\fJubilife City.\n</language>
	</row>
	<row id="narc_0558_00063" index="63">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du kom tilbage til mig, fordi du\nkunne ikke glemme duften af ​​blomster!\r</language>
	</row>
	<row id="narc_0558_00064" index="64">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liv: We can one-shot this Trainer,\ncan’t we, Liz?\r</language>
	</row>
	<row id="narc_0558_00065" index="65">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liv: Oh, oh, oh?\n</language>
	</row>
	<row id="narc_0558_00066" index="66">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liv: Awww! That is so bad!\n</language>
	</row>
	<row id="narc_0558_00067" index="67">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liv: You only have one Pokémon?\nThat’s so boring!</language>
	</row>
	<row id="narc_0558_00068" index="68">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liv: Oh! You’re that Trainer!\nLet’s get payback, Liz!\r</language>
	</row>
	<row id="narc_0558_00069" index="69">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liz: Vi er de stærkeste i vores\nklasse!\r</language>
	</row>
	<row id="narc_0558_00070" index="70">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liz: Oh, but, wait!\n</language>
	</row>
	<row id="narc_0558_00071" index="71">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liz: I wish I could be strong like\nyou when I get bigger.\n</language>
	</row>
	<row id="narc_0558_00072" index="72">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liz: Um, will you battle with us?\nMe and Liv?\n</language>
	</row>
	<row id="narc_0558_00073" index="73">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Liz: Vi er de bedste i vores klasse.\nVi kan ikke være tabere hele tiden!\r</language>
	</row>
	<row id="narc_0558_00074" index="74">
		<attribute name="window_context_name">used</attribute>
		<language name="English">How about a quick battle before\nI leave for Eterna Forest?\r</language>
	</row>
	<row id="narc_0558_00075" index="75">
		<attribute name="window_context_name">used</attribute>
		<language name="English">That really dampened my spirits.\n</language>
	</row>
	<row id="narc_0558_00076" index="76">
		<attribute name="window_context_name">used</attribute>
		<language name="English">They say there are rough Pokémon\nin Eterna Forest.\rI’d better be more prepared than\nthis.\n</language>
	</row>
	<row id="narc_0558_00077" index="77">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du har været i Eterna Forest\nallerede, ikke? Hvordan var det?\r</language>
	</row>
	<row id="narc_0558_00078" index="78">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er langt mellem Floaroma\nog Eterna City. Så lad os kæmpe!\r</language>
	</row>
	<row id="narc_0558_00079" index="79">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wawawaah!\nI’m out of Pokémon that can go!\n</language>
	</row>
	<row id="narc_0558_00080" index="80">
		<attribute name="window_context_name">used</attribute>
		<language name="English">With my Pokémon by my side, I’m\nsure any camping will be a blast!\n</language>
	</row>
	<row id="narc_0558_00081" index="81">
		<attribute name="window_context_name">used</attribute>
		<language name="English">While I was enjoying camping, my\nPokémon got all buffed up!\r</language>
	</row>
	<row id="narc_0558_00082" index="82">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What kinds of Pokémon live around\nhere, I wonder?\r</language>
	</row>
	<row id="narc_0558_00083" index="83">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m shocked!\nHow did I lose?\n</language>
	</row>
	<row id="narc_0558_00084" index="84">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvad kan jeg fortælle dig om Pokémon?\rTja, der er hanner og hunner.\nOg nogle, som du ikke kan fortælle!</language>
	</row>
	<row id="narc_0558_00085" index="85">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, hi! We meet again!\nHave you seen any rare Pokémon?\r</language>
	</row>
	<row id="narc_0558_00086" index="86">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, I don’t know.\nShould I play a little?\r</language>
	</row>
	<row id="narc_0558_00087" index="87">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, boo!\nHow insulting!\n</language>
	</row>
	<row id="narc_0558_00088" index="88">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lyt meget godt efter...\nKan du høre skrig fra Pokémon?\n</language>
	</row>
	<row id="narc_0558_00089" index="89">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, I don’t know.\nShould I play a little again?\r</language>
	</row>
	<row id="narc_0558_00090" index="90">
		<attribute name="window_context_name">used</attribute>
		<language name="English">There’s no mountain here, but I’m\ndressed to hike! Gahaha! Here goes!\r</language>
	</row>
	<row id="narc_0558_00091" index="91">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, ja!\nDet var en forfriskende kamp!\n</language>
	</row>
	<row id="narc_0558_00092" index="92">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du kan finde de samme slags\nPokémon alle mulige steder.\rDer er ingen lov, der siger, at en vandrer ikke kan\nsøg i bjergene!\n</language>
	</row>
	<row id="narc_0558_00093" index="93">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis du møder nogen i bjergene,\nde er ikke længere fremmede.\rMød dem to gange, og de er dine\nven!\r</language>
	</row>
	<row id="narc_0558_00094" index="94">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Of all places possible, I’ve lost\nmy way here...\r</language>
	</row>
	<row id="narc_0558_00095" index="95">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Efter at have tabt sig, tabte træneren\nkampen også...\n</language>
	</row>
	<row id="narc_0558_00096" index="96">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fra at være fortabt i bjergene så\nlænge, ​​jeg blev en Hiker...\n</language>
	</row>
	<row id="narc_0558_00097" index="97">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ve lost my way again... I’m\nbetrayed by my sense of direction.\r</language>
	</row>
	<row id="narc_0558_00098" index="98">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Osu!\nI’m not trained to hold back!\r</language>
	</row>
	<row id="narc_0558_00099" index="99">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I... I concede!\nYou’re in a different class...\n</language>
	</row>
	<row id="narc_0558_00100" index="100">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You taught me how I measure up!\nThank you!\n</language>
	</row>
	<row id="narc_0558_00101" index="101">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Osu!\nThis time, I’m fully committed!\r</language>
	</row>
	<row id="narc_0558_00102" index="102">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I love Pokémon that smell sweet.\nLike this one--get a whiff of this!\r</language>
	</row>
	<row id="narc_0558_00103" index="103">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Did you understand what I meant?\nDidn’t my Pokémon smell nice?\n</language>
	</row>
	<row id="narc_0558_00104" index="104">
		<attribute name="window_context_name">used</attribute>
		<language name="English">If you plant lots of Berries, you\ncan be surrounded by sweet scents.\n</language>
	</row>
	<row id="narc_0558_00105" index="105">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Snif... Åh?\nDin Pokémon dufter dejligt!\r</language>
	</row>
	<row id="narc_0558_00106" index="106">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Nothing’s biting...\nI could use a break, I suppose.\r</language>
	</row>
	<row id="narc_0558_00107" index="107">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, well. I should’ve been a little\nmore serious about this.\n</language>
	</row>
	<row id="narc_0558_00108" index="108">
		<attribute name="window_context_name">used</attribute>
		<language name="English">!\rYank your fishing rod when that\nappears. That’s how you fish.\n</language>
	</row>
	<row id="narc_0558_00109" index="109">
		<attribute name="window_context_name">used</attribute>
		<language name="English">All right! I caught some tough\nPokémon. I’m ready for battle!\r</language>
	</row>
	<row id="narc_0558_00110" index="110">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I landed myself a feisty Trainer!\nLet’s go!\r</language>
	</row>
	<row id="narc_0558_00111" index="111">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I let a big win slip away...\n</language>
	</row>
	<row id="narc_0558_00112" index="112">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Har du en fiskestang?\nFang nogle store!\n</language>
	</row>
	<row id="narc_0558_00113" index="113">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hej, din fede tyk! Jeg fangede en stor\nen! Lad os kæmpe igen!\r</language>
	</row>
	<row id="narc_0558_00114" index="114">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I fished up some tough Pokémon!\nLet’s have ourselves a battle!\r</language>
	</row>
	<row id="narc_0558_00115" index="115">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Losing has my emotions all knotted\nup!\n</language>
	</row>
	<row id="narc_0558_00116" index="116">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My feet are tangled, too!\nOuch! Ouch!\n</language>
	</row>
	<row id="narc_0558_00117" index="117">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m going to win this time!\nI said I’ll win, and I mean it!\r</language>
	</row>
	<row id="narc_0558_00118" index="118">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Yo!\nHaving a good time cycling?\r</language>
	</row>
	<row id="narc_0558_00119" index="119">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hej, ikke dårligt, du!\n</language>
	</row>
	<row id="narc_0558_00120" index="120">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Cycling Road’s teeming with\nPokémon Trainers, too!\n</language>
	</row>
	<row id="narc_0558_00121" index="121">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m sure I’ve seen your face before.\nDid we maybe battle?\r</language>
	</row>
	<row id="narc_0558_00122" index="122">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hey! Watch where you’re going!\nOr did you want to challenge me?\r</language>
	</row>
	<row id="narc_0558_00123" index="123">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My efforts were meaningless...\n</language>
	</row>
	<row id="narc_0558_00124" index="124">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I might try racing through Cycling\nRoad in one long shot.\n</language>
	</row>
	<row id="narc_0558_00125" index="125">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Der er du!\rJeg har redet på dette sted, så jeg ville\nfå en revanche med dig!\r</language>
	</row>
	<row id="narc_0558_00126" index="126">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Din cykel er den type, der kan skifte\ngear, hva?\rLad mig se, om du ved, hvordan man rider\ndet ordentligt.\r</language>
	</row>
	<row id="narc_0558_00127" index="127">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Crash! Tinkle...\n</language>
	</row>
	<row id="narc_0558_00128" index="128">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvad? Jeg skulle tjekke\nhvis du ved, hvordan man skifter gear.\fHvorfor tjekker jeg din Pokémon ud?\n</language>
	</row>
	<row id="narc_0558_00129" index="129">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Let me see if you’ve learned how to\nride your Bike properly.\fI’ll check you out again!\r</language>
	</row>
	<row id="narc_0558_00130" index="130">
		<attribute name="window_context_name">used</attribute>
		<language name="English">A Bicycle can only take you as far as\nyour energy will allow.\r</language>
	</row>
	<row id="narc_0558_00131" index="131">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gasp... Gasp... Gasp...\n</language>
	</row>
	<row id="narc_0558_00132" index="132">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My Pokémon are out of gas.\nSo am I.\rI’m going to head home soon...\n</language>
	</row>
	<row id="narc_0558_00133" index="133">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg fik masser af hvile derhjemme.\nJeg taber ikke denne gang!\r</language>
	</row>
	<row id="narc_0558_00134" index="134">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg fik en god sved på at ride!\nJeg har det godt! Lad os kæmpe!\r</language>
	</row>
	<row id="narc_0558_00135" index="135">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Whew!\nYou worked us over.\n</language>
	</row>
	<row id="narc_0558_00136" index="136">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Do you find yourself pedaling\nbackward going downhill?\n</language>
	</row>
	<row id="narc_0558_00137" index="137">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I worked up a good sweat riding!\nI feel ready for a rematch!\r</language>
	</row>
	<row id="narc_0558_00138" index="138">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You and I, we’re both riding\nBikes.\rAnd you’ve got Pokémon.\nI don’t want to lose to you!\r</language>
	</row>
	<row id="narc_0558_00139" index="139">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, geez...\nI seem to have fallen off my Bike.</language>
	</row>
	<row id="narc_0558_00140" index="140">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Instead of a battle, I should’ve\nchallenged you to a Bike race!\n</language>
	</row>
	<row id="narc_0558_00141" index="141">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I hate knowing you’ve beaten me.\nThis time, I’m going to win!\r</language>
	</row>
	<row id="narc_0558_00142" index="142">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I love my Bike!\rBut I’m not very good at fixing flat\ntires...\r</language>
	</row>
	<row id="narc_0558_00143" index="143">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Kerrrash!</language>
	</row>
	<row id="narc_0558_00144" index="144">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg beundrer folk, der forstår\ngadgets.\rJeg ved ikke, hvordan min Pokétch\nvirker.\n</language>
	</row>
	<row id="narc_0558_00145" index="145">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I want to practice repairing flat\ntires...\rBut I’ve been practicing with my\nPokémon to get our revenge!\r</language>
	</row>
	<row id="narc_0558_00146" index="146">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Nogle mennesker konkurrerer om hastighed, og\nnogle konkurrerer om teknik.\rHvilken slags er du?\r</language>
	</row>
	<row id="narc_0558_00147" index="147">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You’re a speedy technician!\n</language>
	</row>
	<row id="narc_0558_00148" index="148">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg nyder landskabet.\rTror du ikke området nedenfor\nSer cykelvejen flot ud?\n</language>
	</row>
	<row id="narc_0558_00149" index="149">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I polished up both my speed and\ntechniques. Can you beat me now?\r</language>
	</row>
	<row id="narc_0558_00150" index="150">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Whoa! You startled me!\nWell, we may as well battle!\r</language>
	</row>
	<row id="narc_0558_00151" index="151">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Your power startles me!\n</language>
	</row>
	<row id="narc_0558_00152" index="152">
		<attribute name="window_context_name">used</attribute>
		<language name="English">We Hikers are bighearted guys!\nLosing doesn’t bother us!\n</language>
	</row>
	<row id="narc_0558_00153" index="153">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Whoa! You startled me!\nWe may as well have a rematch!\r</language>
	</row>
	<row id="narc_0558_00154" index="154">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg har shorts på hele året!\nJeg har energi til at brænde!\r</language>
	</row>
	<row id="narc_0558_00155" index="155">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Having lots of energy isn’t good\nenough...\n</language>
	</row>
	<row id="narc_0558_00156" index="156">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My Pokémon don’t wear anything.\nI worry that they’ll be cold.\n</language>
	</row>
	<row id="narc_0558_00157" index="157">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg har shorts på! Jeg har masser af\nenergi! Jeg taber ikke til dig!\r</language>
	</row>
	<row id="narc_0558_00158" index="158">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Go for it, my Pokémon!\nI’ll do my best, too!\r</language>
	</row>
	<row id="narc_0558_00159" index="159">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh...\nWe lost...\n</language>
	</row>
	<row id="narc_0558_00160" index="160">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Vidste du det? Du kan grave fossiler op\ni undergrunden!\rDe fossiler kan forvandles tilbage til\nPokémon på minemuseet!\n</language>
	</row>
	<row id="narc_0558_00161" index="161">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Go for it, my Pokémon!\nI’ll do more than my best this time!\r</language>
	</row>
	<row id="narc_0558_00162" index="162">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Go do it, my Pokémon!\nI’ll work hard, too!\r</language>
	</row>
	<row id="narc_0558_00163" index="163">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh...\nWe lost...</language>
	</row>
	<row id="narc_0558_00164" index="164">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg tror, ​​vi vil besøge tv-stationen\ni Jubilife City næste gang.\n</language>
	</row>
	<row id="narc_0558_00165" index="165">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ummm... Du er træneren, der slog\nos før, er du ikke?\rVi har det godt i dag, så lad os\nhav endnu en kamp!\r</language>
	</row>
	<row id="narc_0558_00166" index="166">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wahaha!\nLaughter brings good fortune!\r</language>
	</row>
	<row id="narc_0558_00167" index="167">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wahahaha! There’s nothing that\nI can do but laugh!\n</language>
	</row>
	<row id="narc_0558_00168" index="168">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wahaha!\n...Go ahead and laugh at me.\n</language>
	</row>
	<row id="narc_0558_00169" index="169">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wahaha!\rLaughter brings good fortune!\nForgetting your gloves brings a cold!\r</language>
	</row>
	<row id="narc_0558_00170" index="170">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg er lige kommet igennem Mt. Coronet, men\nvi har stadig brændstof på tanken!\r</language>
	</row>
	<row id="narc_0558_00171" index="171">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Whoops!\nDidn’t take much to beat us!\n</language>
	</row>
	<row id="narc_0558_00172" index="172">
		<attribute name="window_context_name">used</attribute>
		<language name="English">We need to rest up in Oreburgh City\nbefore heading to Mt. Coronet again.\n</language>
	</row>
	<row id="narc_0558_00173" index="173">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I just got through Mt. Coronet,\nand who do I see?\rA Trainer who we’ve battled before!\r</language>
	</row>
	<row id="narc_0558_00174" index="174">
		<attribute name="window_context_name">used</attribute>
		<language name="English">OK, OK!\nLet’s be quick about this!\r</language>
	</row>
	<row id="narc_0558_00175" index="175">
		<attribute name="window_context_name">used</attribute>
		<language name="English">No way! Give us another battle!\n...Oh, right. I’m out of Pokémon.\n</language>
	</row>
	<row id="narc_0558_00176" index="176">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ja!\nJeg kan godt lide den måde, du kæmper på.\n</language>
	</row>
	<row id="narc_0558_00177" index="177">
		<attribute name="window_context_name">used</attribute>
		<language name="English">What took you so long?\nWe’ve waited here a long time for\fa rematch with you!\r</language>
	</row>
	<row id="narc_0558_00178" index="178">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gahahaha! You’re just a little kid!\rHow’re you supposed to beat a big\nman like me?\r</language>
	</row>
	<row id="narc_0558_00179" index="179">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’m a grown-up, but I got served by\nsome little kid!\n</language>
	</row>
	<row id="narc_0558_00180" index="180">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Wow, you’re sure impressive!\rI guess it makes no difference if\nyou’re young or old in battles.\n</language>
	</row>
	<row id="narc_0558_00181" index="181">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hey, you, tough little kid!\nThrow us a rematch, will you?\r</language>
	</row>
	<row id="narc_0558_00182" index="182">
		<attribute name="window_context_name">used</attribute>
		<language name="English">De kalder mig The Echo Man!\nKæmp med mig! Yahoo!\r</language>
	</row>
	<row id="narc_0558_00183" index="183">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Ohh... Yo...\nYodelay...\n</language>
	</row>
	<row id="narc_0558_00184" index="184">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lad The Echo Man give dig et godt ord\naf råd!\rHvis du ikke ved, hvor du skal\nskal afsted, tjek bykortet.\n</language>
	</row>
	<row id="narc_0558_00185" index="185">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, hej! Kan du huske os?\nJeg er ekkomanden!\rLad os tage endnu en kamp!\nYahoo!\r</language>
	</row>
	<row id="narc_0558_00186" index="186">
		<attribute name="window_context_name">used</attribute>
		<language name="English">If I beat you, will you share some\nfood with me?\r</language>
	</row>
	<row id="narc_0558_00187" index="187">
		<attribute name="window_context_name">used</attribute>
		<language name="English">We were starved for food, and now\nwe’re starved for a win...\n</language>
	</row>
	<row id="narc_0558_00188" index="188">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Sigh... I feel even hungrier...\nMaybe I’ll chow down some Berries...\rBut that’s kind of gross.\nWhat am I, a Pokémon?\n</language>
	</row>
	<row id="narc_0558_00189" index="189">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I, uh, chowed down my packed lunch\nbefore we started climbing.\rIf I beat you this time, share some\nfood with me!\r</language>
	</row>
	<row id="narc_0558_00190" index="190">
		<attribute name="window_context_name">used</attribute>
		<language name="English">This karate man will pulverize you!\r</language>
	</row>
	<row id="narc_0558_00191" index="191">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I still lack power...\n</language>
	</row>
	<row id="narc_0558_00192" index="192">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I need to work out more.\nMy Pokémon do, too!\n</language>
	</row>
	<row id="narc_0558_00193" index="193">
		<attribute name="window_context_name">used</attribute>
		<language name="English">This karate man hasn’t forgotten\nbeing pulverized by you!\r</language>
	</row>
	<row id="narc_0558_00194" index="194">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Muhihi...\nI’ll haul you up and out!\r</language>
	</row>
	<row id="narc_0558_00195" index="195">
		<attribute name="window_context_name">used</attribute>
		<language name="English">My favorite word is restraint.\nEspecially in battle.\n</language>
	</row>
	<row id="narc_0558_00196" index="196">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You need a Good Rod if you want to\ncatch good Pokémon.\n</language>
	</row>
	<row id="narc_0558_00197" index="197">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Muhihi... There won’t be any\nrestraint this time, OK?\r</language>
	</row>
	<row id="narc_0558_00198" index="198">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, vil du have en kamp?\rJeg havde til hensigt at deltage i en konkurrence,\nmen det tager ikke lang tid at slå dig...\r</language>
	</row>
	<row id="narc_0558_00199" index="199">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, du har slået os.\n</language>
	</row>
	<row id="narc_0558_00200" index="200">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Du og din Pokémon har så meget\nenergi.\rJeg tror, ​​du ville klare dig godt\nOgså konkurrencer.\n</language>
	</row>
	<row id="narc_0558_00201" index="201">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Åh, har vi ikke mødt hinanden før?\rJeg havde til hensigt at deltage i en konkurrence,\nmen lad os tage en hurtig kamp først.\r</language>
	</row>
	<row id="narc_0558_00202" index="202">
		<attribute name="window_context_name">used</attribute>
		<language name="English">You and I!\rLet us create a scene!\nA fantastic tableau of battle!\r</language>
	</row>
	<row id="narc_0558_00203" index="203">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Magnificent!\nI am aglow with inspiration!\n</language>
	</row>
	<row id="narc_0558_00204" index="204">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Den kamp bliver helt sikkert en\nfantastisk mesterværk maleri!\rJeg vil titulere det...\r"Min Pokémon er kamp"!\n</language>
	</row>
	<row id="narc_0558_00205" index="205">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Nøglen til at blive en god maler\ner at være opmærksom.\rDet er det samme for kamp.\nMan skal være opmærksom!\r</language>
	</row>
	<row id="narc_0558_00206" index="206">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Lad mig se, hvor meget du har rejst\ndin Pokémon.\r</language>
	</row>
	<row id="narc_0558_00207" index="207">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Gode ​​ting! Dine Pokémon er med\nupåklagelig stand.\n</language>
	</row>
	<row id="narc_0558_00208" index="208">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Det er tydeligt, at du rejser din Pokémon\nmed en masse kærlighed.\n</language>
	</row>
	<row id="narc_0558_00209" index="209">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I’ve raised my Pokémon since we met.\nHow much have you raised yours?\r</language>
	</row>
	<row id="narc_0558_00210" index="210">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hør, hvis du ikke har noget imod det, vil jeg gerne\nhave en kamp med din Pokémon.\r</language>
	</row>
	<row id="narc_0558_00211" index="211">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Giggle...\nThey’re raised with a lot of care!\n</language>
	</row>
	<row id="narc_0558_00212" index="212">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hvis du behandler din Pokémon med omhu,\nde vil belønne dig med venskab\fog loyalitet.</language>
	</row>
	<row id="narc_0558_00213" index="213">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I don’t want to ever battle with\npeople who don’t treat Pokémon nice!\rBut I know you treat yours kindly.\nI’ll battle you anytime!\r</language>
	</row>
	<row id="narc_0558_00214" index="214">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Hi, there! Where’re you from?\nWhat kinds of Pokémon have you got?\r</language>
	</row>
	<row id="narc_0558_00215" index="215">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Fancy folk som dig har lyst\nPokémon også, ser det ud til.\n</language>
	</row>
	<row id="narc_0558_00216" index="216">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I hope my pa didn’t spy me slacking\noff from work here.\n</language>
	</row>
	<row id="narc_0558_00217" index="217">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oh, howdy! Come visiting again?\nWhat kinds of Pokémon’d you bring?\r</language>
	</row>
	<row id="narc_0558_00218" index="218">
		<attribute name="window_context_name">used</attribute>
		<language name="English">I jog every morning to keep my\nPokémon fit.\r</language>
	</row>
	<row id="narc_0558_00219" index="219">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Oops!\nYou threw off my running rhythm.\n</language>
	</row>
	<row id="narc_0558_00220" index="220">
		<attribute name="window_context_name">used</attribute>
		<language name="English">At være sund er nummer et!\nHvorfor kommer du ikke løbende med mig?\n</language>
	</row>
	<row id="narc_0558_00221" index="221">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Do you jog every morning, too?\n</language>
	</row>
	<row id="narc_0558_00222" index="222">
		<attribute name="window_context_name">used</attribute>
		<language name="English">When I go on my jogs, I pass by lots\nof people.\rI have trouble remembering faces,\nbut we did meet before, right?\r</language>
	</row>
	<row id="narc_0558_00223" index="223">
		<attribute name="window_context_name">garbage</attribute>
		<language name="English" />
		<language name="日本語">XXXXXXXXXXXXXXXXXXXXXX</language>
	</row>
