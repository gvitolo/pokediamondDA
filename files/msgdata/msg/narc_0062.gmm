	<row id="narc_0062_00000" index="0">
		<attribute name="window_context_name">used</attribute>
		<language name="English">Jeg bliver bedre venner.\nmed denne person jeg kender, så jeg kan\fRegistrer hende i min Pal Pad.\rEller skal jeg registrere folk?\ni min Pal Pad, og derefter blive\fVenner med dem?</language>
	</row>
</body>